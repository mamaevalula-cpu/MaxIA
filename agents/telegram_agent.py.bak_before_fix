                        BotCommand("status",    "Статус системы"),
                        BotCommand("health",      "Самодиагностика"),
                        BotCommand("resilience", "Статус retry/очереди"),
                        BotCommand("trading",   "Дашборд торгового бота"),
                        BotCommand("analysis",  "Анализ рынка [SYMBOL]"),
                        BotCommand("server",    "Ресурсы сервера"),
                        BotCommand("balance",   "Баланс Bybit"),
                        BotCommand("positions", "Открытые позиции"),
                        BotCommand("pnl",       "P&L за сегодня"),
                        BotCommand("ask",       "Задать вопрос AI"),
                        BotCommand("news",      "Крипто-новости"),
                        BotCommand("math",      "Вычислить выражение"),
                        BotCommand("cot",       "Chain-of-Thought отчёт"),
                        BotCommand("memory",    "Статистика памяти и знаний"),
                        BotCommand("tools",     "Список инструментов"),
                        BotCommand("task",      "Запустить автономную задачу"),
                        BotCommand("tasks",     "Список задач агента"),
                        BotCommand("freelance", "Поиск работы / proposal / заработок"),
                        BotCommand("pay",       "Платёжные системы: Stripe/PayPal/крипто"),
                        BotCommand("backup",    "Резервная копия системы"),
                    ])
                    log.info("Bot commands menu registered")
                except Exception as _cmd_err:
                    log.warning("Could not register bot commands menu: %s", _cmd_err)

                # Start approval watcher background task
                _approval_task = asyncio.ensure_future(_approval_watcher_task())
                log.info('Order approval watcher started')

                # Получить username бота
                bot_me = await app.bot.get_me()
                self._bot_username = bot_me.username
                log.info("Bot: @%s", self._bot_username)

                # ── Conflict detector ─────────────────────────────────────────
                # PTB retries Conflicts internally forever without raising.
                # We hook into the error handler to count consecutive conflicts
                # and force a restart after 3 within 30s.
                _conflict_times: list = []
                _force_restart = asyncio.Event()

                from telegram.error import Conflict as _TgConflict, NetworkError as _TgNet

                async def _error_handler(update: object, ctx: object) -> None:
                    err = getattr(ctx, "error", None)
                    if err is None:
                        return
                    log.debug("PTB error handler: %s %s", type(err).__name__, err)
                    if isinstance(err, _TgConflict):
                        now = asyncio.get_running_loop().time()
                        _conflict_times.append(now)
                        _conflict_times[:] = [t for t in _conflict_times if now - t < 90]
                        log.warning("Telegram Conflict #%d in last 90s", len(_conflict_times))
                        if len(_conflict_times) >= 2:
                            log.error("Persistent Conflict — forcing restart")
                            _force_restart.set()
                    elif isinstance(err, _TgNet):
                        log.debug("Telegram NetworkError (transient): %s", err)
                    else:
                        from telegram.error import TimedOut as _TgTO, RetryAfter as _TgRA, BadRequest as _TgBR
                        if isinstance(err, _TgTO):
                            log.debug("Telegram TimedOut (transient)")
                        elif isinstance(err, _TgRA):
                            log.warning("Telegram RetryAfter: wait %ds", err.retry_after)
                        elif isinstance(err, _TgBR):
                            log.warning("Telegram BadRequest: %s", err)
                        else:
                            log.error("Unhandled Telegram error [%s]: %s",
                                      type(err).__name__, err, exc_info=False)

                app.add_error_handler(_error_handler)

                try:
                    await app.updater.start_polling(
                        drop_pending_updates=True,
                        allowed_updates=["message", "callback_query"],
                    )
                except Exception as _poll_err:
                    log.error("Telegram start_polling failed: %s", _poll_err)
                    raise
                log.info("Telegram bot polling started (attempt #%d)", self._reconnect_attempt)
                self._reconnect_attempt = 0

                # Уведомление о запуске владельцу
                if self._owner_id:
                    try:
                        await app.bot.send_message(
                            chat_id=self._owner_id,
                            text=(
                                f"🚀 <b>Personal AI v4.0 запущен!</b>\n\n"
                                f"🔐 Режим: <b>Invite-Only</b>\n"
                                f"👤 Только авторизованные пользователи могут использовать бота.\n\n"
                                f"📋 Полезные команды:\n"
                                f"/invite — создать инвайт-ссылку\n"
                                f"/users — все пользователи\n"
                                f"/status — статус системы\n"
                                f"/trading — торговый бот\n"
                                f"/help — все команды"
                            ),
                            parse_mode=ParseMode.HTML
                        )
                    except Exception as e:
                        log.warning("Could not send startup message: %s", e)

                # Основной цикл — выходим если stop_event ИЛИ persistent conflict
                while not self._stop_event.is_set() and not _force_restart.is_set():
                    await asyncio.sleep(1)

                try:
                    _approval_task.cancel()
                    await asyncio.gather(_approval_task, return_exceptions=True)
                except Exception:
                    pass
                await app.updater.stop()
                await app.stop()

                if _force_restart.is_set() and not self._stop_event.is_set():
                    raise RuntimeError("Telegram persistent Conflict — forced restart")
            except Exception as _awith_exc:
                log.error("Telegram async-with-app raised: %s", _awith_exc, exc_info=True)
                raise

        try:
            self._loop.run_until_complete(_run_async())
        except Exception as e:
            log.error("Telegram _run_bot error: %s", e)
            raise
        finally:
            try:
                if self._resilient:
                    self._resilient.mark_disconnected()
                    self._resilient.stop()
            except Exception:
                pass
            try:
                self._loop.close()
            except Exception:
                pass
            self._application = None
            self._loop = None