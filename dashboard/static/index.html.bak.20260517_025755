            <div key={k} style={{display:'flex',gap:8,marginBottom:5,fontSize:13}}>
              <span style={{color:'var(--text3)',minWidth:90,flexShrink:0}}>{k}:</span>
              <span style={{wordBreak:'break-all'}}>{String(v||'—').slice(0,90)}</span>
            </div>
          ))}
        </div>
        <div className="card">
          <div className="section-title">🤖 AI Провайдеры</div>
          {Object.entries(cfg.llm_providers||{}).map(([k,v])=>(
            <div key={k} style={{display:'flex',gap:8,marginBottom:8,alignItems:'center',fontSize:13}}>
              <span style={{width:8,height:8,borderRadius:'50%',flexShrink:0,
