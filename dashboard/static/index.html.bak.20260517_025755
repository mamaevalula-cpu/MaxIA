function KnowledgeTab() {
  const [items, setItems] = useState([]);
  const [query, setQuery] = useState('');
  const [category, setCategory] = useState('');
  const [categories, setCategories] = useState([]);
  const [expanded, setExpanded] = useState(null);
  const [loading, setLoading] = useState(false);

  const load = async (q = '', cat = '') => {
    setLoading(true);
    let url;
    if (q) {
      url = `/api/knowledge/search?q=${encodeURIComponent(q)}`;
    } else {
      const params = new URLSearchParams();
      if (cat) params.set('category', cat);
      url = `/api/knowledge?${params}`;
    }
    const r = await apiFetch(url);
    if (r.ok) {
      const raw = r.data;
      const data = Array.isArray(raw) ? raw : (raw?.results || raw?.entries || raw?.items || []);
      setItems(data);
      if (!q) {
        const cats = [...new Set(data.map(i => i.category).filter(Boolean))];
        setCategories(cats);
      }
    }
    setLoading(false);
  };

  useEffect(() => { load(); }, []);

  const handleSearch = e => { e.preventDefault(); load(query, category); };

  return (
    <div>
      <div className="tab-title">📚 База знаний</div>
      <form onSubmit={handleSearch} style={{display:'flex',gap:8,marginBottom:16}}>
        <input className="input flex-1" placeholder="Поиск..." value={query} onChange={e => setQuery(e.target.value)} />
        <select className="input" style={{width:180}} value={category} onChange={e => setCategory(e.target.value)}>
          <option value="">Все категории</option>
          {categories.map(c => <option key={c} value={c}>{c}</option>)}
        </select>
        <button className="btn btn-primary" type="submit">Найти</button>
      </form>

      {loading ? <div className="empty-state"><span className="spinner"></span></div> :
        items.length === 0 ? <div className="empty-state">Ничего не найдено</div> :
        items.map((item, i) => (
          <div key={i} className="know-card" onClick={() => setExpanded(expanded === i ? null : i)}>
            <div className="know-title">{item.title || item.name}</div>
            <div className="know-snippet">{(item.content || item.text || item.snippet || '').slice(0, 150)}...</div>
            <div className="know-footer">
              {item.category && <span className="badge badge-blue">{item.category}</span>}
              <span style={{fontSize:11,color:'var(--text2)'}}>
                {item.created_at || item.updated_at || item.timestamp || ''}
              </span>
            </div>
            {expanded === i && (
              <div className="know-full" onClick={e => e.stopPropagation()}>
                {item.content || item.text || 'Нет полного содержимого'}
              </div>
            )}
          </div>
        ))
      }
    </div>
  );
}

