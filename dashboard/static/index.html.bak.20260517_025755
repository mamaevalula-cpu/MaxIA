                style={{padding:'5px 12px',cursor:'pointer',color:'var(--text3)'}}
                onMouseEnter={e=>e.currentTarget.style.background='var(--hover)'}
                onMouseLeave={e=>e.currentTarget.style.background=''}>
                ⬆ ..
              </div>
              {fileList.map((f,i)=>(
                <div key={i}
                  onClick={()=>{if(f.type==='dir'||f.is_dir){setCwd(f.path||cwd+'/'+f.name);}else{openFile(f.path||cwd+'/'+f.name);}}}
                  style={{padding:'5px 12px',cursor:'pointer',display:'flex',gap:6,alignItems:'center'}}
                  onMouseEnter={e=>e.currentTarget.style.background='var(--hover)'}
                  onMouseLeave={e=>e.currentTarget.style.background=''}>
                  <span>{(f.type==='dir'||f.is_dir)?'📁':'📄'}</span>
                  <span style={{flex:1,overflow:'hidden',textOverflow:'ellipsis',whiteSpace:'nowrap'}}>{f.name}</span>
                  {f.size&&<span style={{color:'var(--text3)',fontSize:10}}>{Math.round((f.size||0)/1024)}k</span>}
                </div>
              ))}
            </div>
          </div>
          <div>
            {filePath?(
              <div>
                <div style={{fontSize:11,color:'var(--text3)',marginBottom:6,fontFamily:'monospace'}}>{filePath}</div>
                <textarea value={fileContent} onChange={e=>setFileContent(e.target.value)}
                  style={{width:'100%',height:440,background:'#0d1117',color:'#e8e8e8',
                    fontFamily:'"Fira Code",monospace',fontSize:12,padding:12,borderRadius:8,
                    border:'1px solid #30363d',lineHeight:1.5,resize:'none',boxSizing:'border-box'}}/>
                <button className="btn" onClick={saveFile}
                  style={{marginTop:8,background:'#2ecc71',color:'#000',fontWeight:700}}>💾 Сохранить файл</button>
              </div>
            ):(
              <div className="empty-state">Выберите файл из дерева слева</div>
            )}
          </div>
        </div>
      )}
    </div>
  );
}

