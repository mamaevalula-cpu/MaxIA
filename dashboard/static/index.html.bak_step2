async function loadScout() {
  const d = await api(HYP+'/api/v2/scout/status');
  if (!d) return;
  const lr=d.latest_run||{}, doms=d.research_domains||[];

  $('sct-kpis').innerHTML = [
    statCard(d.db_skill_nodes||0,'Skill Nodes в БД','','stat-acc'),
    statCard(d.scout_findings_total||0,'Находок сохранено','',''),
    statCard(doms.length,'Доменов исследований','',''),
    statCard(lr.opportunities||0,'Возможностей найдено','в последнем прогоне','stat-grn'),
  ].join('');

  const domRu = {saas:'SaaS продукты',b2b_automation:'B2B автоматизация',ai_agents:'AI агенты',depin:'DePIN',freelance:'Фриланс',crypto:'Крипто',content:'Контент',lead_gen:'Лиды'};
  $('sct-domains').innerHTML = doms.map(d =>
    `<div class="row"><span class="row-left" style="font-family:'Consolas',monospace;font-size:11px">${esc(domRu[d]||d)}</span>${bdg('запланирован','b')}</div>`
  ).join('') || '<div style="color:var(--txt3);padding:10px">Нет доменов</div>';

  const fs=lr.findings_summary||[];
  $('sct-finds').innerHTML = fs.length?fs.map(f =>
    `<div style="margin-bottom:12px;padding:10px;background:#030810;border-radius:var(--r2);border-left:3px solid var(--acc)">
      <div style="color:var(--acc);font-size:11px;font-weight:700;margin-bottom:4px">${esc(domRu[f.domain]||f.domain||'')}</div>
      <div style="color:var(--txt2);font-size:11px">${esc(f.recommendation||'')}</div>
    </div>`
  ).join('') : `<div style="color:var(--txt3);padding:10px;font-size:12px">Следующий запуск: <span style="font-family:'Consolas',monospace;color:var(--acc)">${esc(d.scout_cron||'02:00 ежедневно')}</span></div>`;

  const logEl = $('sct-log');
  logEl.textContent = (d.log_tail||[]).join('\n') || 'Скаут ещё не запускался.';
  logEl.scrollTop = logEl.scrollHeight;
}

async function runScout() {
  const btn = $('scout-btn');
  btn.disabled = true; btn.textContent = '⏳ Запуск...';
  const r = await api(HYP+'/api/v2/scout/run',{method:'POST',headers:{'Content-Type':'application/json'},body:'{}'});
  btn.disabled = false; btn.textContent = '🔭 Запустить Скаут сейчас';
  if (r) {
    showFb('scout-fb','✓ Скаут запущен — результаты через ~30с',true);
    setTimeout(() => { loaded.scout=false; loadScout(); }, 35000);
  } else {
    showFb('scout-fb','❌ Ошибка запуска',false);
  }
}

