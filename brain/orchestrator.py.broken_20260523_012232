class Orchestrator:
    def __init__(self, llm_router: LLMRouter, memory_store: MemoryStore, rage_engine: RAGEngine):
        self.llm_router = llm_router
        self.memory_store = memory_store
        self.rage_engine = rage_engine
        self.event_bus = EventBus()

    def process_request(self, request: OrchestratorRequest) -> OrchestratorResponse:
        try:
            # Classify   — определить намерение (trading / code / analysis / chat / ...)
            intent = self.classify_intent(request.text)

            # RAG        — загрузить релевантный контекст из памяти
            context = self.rage_engine.get_relevant_context(request.text)

            # Route      — выбрать путь: агент (Coder/Trading/...) или DEBATE
            if intent == "code":
                agent = "coder"
            elif intent == "analysis":
                agent = "analyst"
            else:
                agent = "chat"

            # DEBATE     — декомпозиция → параллельные специалисты → дебаты → синтез
            if agent == "chat":
                response = self.chat_debate(request.text, context)
            else:
                response = self.agent_debate(request.text, context, agent)

            # Apply      — если в ответе есть код → применить через CoderAgent
            if "code" in response.text:
                self.apply_code(response.text)

            # Learn      — сохранить удачные паттерны в MemoryStore
            self.memory_store.save_successful_pattern(request.text, response.text)

            # Notify     — вернуть ответ в GUI/Telegram
            return OrchestratorResponse(response.text, intent=intent, agent_used=agent)
        except Exception as e:
            log.error(f"Error processing request: {e}")
            return OrchestratorResponse("Ошибка обработки запроса.", intent="error")

