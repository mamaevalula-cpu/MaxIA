#   positions = ex.get_positions()                    # open positions
#
# ── 5. SCIPY / СТАТИСТИКА ────────────────────────────────────────
#   from scipy import stats
#   z = stats.zscore(price_series)
#   corr, pval = stats.pearsonr(series1, series2)
#   stats.linregress(x, y)  # линейная регрессия
#
# ── 6. MACHINE LEARNING (если нужно) ─────────────────────────────
#   import torch
#   from sentence_transformers import SentenceTransformer
#   from sklearn.preprocessing import StandardScaler
#
# ── 7. БЭКТЕСТИНГ ────────────────────────────────────────────────
