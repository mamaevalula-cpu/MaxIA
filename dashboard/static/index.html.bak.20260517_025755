function LlmTab() {
  const [providers, setProviders] = useState([]);
  const [testing, setTesting] = useState({});
  const [results, setResults] = useState({});

  useEffect(() => {
    apiFetch('/api/llm').then(r => {
      if (r.ok) {
        const p = r.data?.providers || (Array.isArray(r.data) ? r.data : []);
        setProviders(p);
      }
    });
  }, []);

  const testProvider = async (name) => {
    setTesting(prev => ({ ...prev, [name]: true }));
    const t0 = Date.now();
    const r = await apiFetch('/api/llm/test', {
      method: 'POST',
      body: JSON.stringify({ provider: name, message: 'Say: OK' }),
    });
    const latency = Date.now() - t0;
    setTesting(prev => ({ ...prev, [name]: false }));
    if (r.ok) {
      setResults(prev => ({
        ...prev,
        [name]: { ok: true, latency, preview: (r.data?.response || r.data?.message || JSON.stringify(r.data)).slice(0, 80) },
      }));
    } else {
      setResults(prev => ({ ...prev, [name]: { ok: false, latency, preview: r.data?.error || 'Ошибка' } }));
    }
  };

  return (
    <div>
      <div className="tab-title">🧠 Модели LLM</div>
      <div className="table-wrap">
        <table className="table">
          <thead>
            <tr>
              <th>Провайдер</th>
              <th>Статус</th>
              <th>Модели</th>
              <th>Результат теста</th>
              <th>Действие</th>
            </tr>
          </thead>
          <tbody>
            {providers.length === 0 ? (
              <tr><td colSpan={5} className="empty-state" style={{padding:20}}>Нет данных</td></tr>
            ) : providers.map((p, i) => {
              const res = results[p.name];
              return (
                <tr key={i}>
                  <td style={{fontWeight:600}}>{p.name}</td>
                  <td>
                    <span className={`badge ${p.configured ? 'badge-green' : 'badge-gray'}`}>
                      {p.configured ? 'Настроен' : 'Не настроен'}
                    </span>
                  </td>
                  <td style={{color:'var(--text2)',fontSize:12}}>{Array.isArray(p.models) ? p.models.join(', ') : (p.model || '—')}</td>
                  <td>
                    {res ? (
                      <span style={{color: res.ok ? 'var(--accent2)' : 'var(--danger)', fontSize:12}}>
                        {res.ok ? `✓ ${res.latency}ms — ${res.preview}` : `✗ ${res.preview}`}
                      </span>
                    ) : '—'}
                  </td>
                  <td>
                    <button
                      className="btn btn-ghost btn-sm"
                      onClick={() => testProvider(p.name)}
                      disabled={testing[p.name]}
                    >
                      {testing[p.name] ? <span className="spinner" style={{width:14,height:14}}></span> : 'Тест'}
                    </button>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>
  );
}

