function EmailTab() {

  const [status, setStatus] = useState(null);

  const [emails, setEmails] = useState([]);

  const [keys, setKeys] = useState([]);

  const [loading, setLoading] = useState(false);

  const [keysLoading, setKeysLoading] = useState(false);

  const [selected, setSelected] = useState(null);

  const [searchQ, setSearchQ] = useState('');

  const [tab2, setTab2] = useState('inbox');



  const loadStatus = useCallback(async () => {

    const r = await apiFetch('/api/email/status');

    if (r.ok) setStatus(r.data);

  }, []);



  useEffect(() => { loadStatus(); }, []);



  const loadInbox = async () => {

    setLoading(true);

    const r = await apiFetch('/api/email/inbox?count=30');

    setLoading(false);

    if (r.ok) setEmails(r.data.emails || []);

  };



  const scanKeys = async () => {

    setKeysLoading(true);

    const r = await apiFetch('/api/email/keys');

    setKeysLoading(false);

    if (r.ok) setKeys(r.data.keys || []);

  };



  const connColor = status?.connected ? '#10b981' : '#ef4444';



  return (

    <div>

      <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', marginBottom: 16 }}>

        <div className="tab-title" style={{ marginBottom: 0 }}>Электронная почта</div>

        <div style={{ display: 'flex', alignItems: 'center', gap: 8 }}>

          <div style={{ width: 8, height: 8, borderRadius: '50%', background: connColor }} />

          <span style={{ fontSize: 12, color: connColor }}>

            {status ? (status.connected ? 'Подключен' : 'Нет подключения') : 'Проверка...'}

          </span>

        </div>

      </div>



      {status && (

        <div className="card" style={{ padding: 12, marginBottom: 16, display: 'flex', gap: 16, alignItems: 'center', flexWrap: 'wrap' }}>

          <div style={{ flex: 1 }}>

            <div style={{ fontSize: 13, fontWeight: 600 }}>{status.address || 'Не настроено'}</div>

            <div style={{ fontSize: 11, color: 'var(--text2)' }}>

              Писем в inbox: {status.inbox_count} | Кэш: {status.cached}

            </div>

          </div>

          {!status.connected && (

            <div style={{ fontSize: 12, color: '#f59e0b' }}>

              ⚠ Google требует App Password. Создайте на myaccount.google.com/apppasswords

            </div>

          )}

        </div>

      )}



      <div style={{ display: 'flex', gap: 8, marginBottom: 16, flexWrap: 'wrap' }}>

        {['inbox', 'keys'].map(t => (

          <button

            key={t}

            onClick={() => setTab2(t)}

            style={{

              padding: '6px 16px', borderRadius: 20, border: '1px solid var(--border)',

              background: tab2 === t ? 'var(--accent)' : 'transparent',

              color: tab2 === t ? '#fff' : 'var(--text)', cursor: 'pointer', fontSize: 13,

            }}

          >

            {t === 'inbox' ? '📥 Входящие' : '🔑 API ключи'}

          </button>

        ))}

      </div>



      {tab2 === 'inbox' && (

        <div>

          <div style={{ display: 'flex', gap: 8, marginBottom: 12 }}>

            <button className="btn-primary" onClick={loadInbox} disabled={loading}>

              {loading ? 'Загрузка...' : '↻ Обновить inbox'}

            </button>

            <input

              className="input"

              style={{ flex: 1 }}

              placeholder="Поиск по теме..."

              value={searchQ}

              onChange={e => setSearchQ(e.target.value)}

            />

          </div>

          {emails.length === 0 ? (

            <div className="card" style={{ textAlign: 'center', padding: 40 }}>

              <div style={{ fontSize: 32, marginBottom: 8 }}>📭</div>

              <div style={{ color: 'var(--text2)' }}>

                {loading ? 'Загрузка...' : 'Нажмите "Обновить inbox" для загрузки писем'}

              </div>

            </div>

          ) : (

            <div style={{ display: 'flex', flexDirection: 'column', gap: 2 }}>

              {emails

                .filter(e => !searchQ || e.subject?.toLowerCase().includes(searchQ.toLowerCase()) || e.from?.toLowerCase().includes(searchQ.toLowerCase()))

                .map((em, i) => (

                  <div

                    key={i}

                    onClick={() => setSelected(selected?.id === em.id ? null : em)}

                    style={{

                      padding: '10px 14px', background: 'var(--card)', borderRadius: 6,

                      cursor: 'pointer', border: '1px solid var(--border)',

                      borderLeft: em.has_key ? '3px solid #10b981' : '1px solid var(--border)',

                    }}

                  >

                    <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start' }}>

                      <div style={{ flex: 1, minWidth: 0 }}>

                        <div style={{ fontSize: 13, fontWeight: 500, color: 'var(--text)',

                          display: 'flex', alignItems: 'center', gap: 4 }}>

                          {em.has_key && <span title="Содержит API ключ">🔑</span>}

                          <span style={{ overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' }}>

                            {em.subject || '(без темы)'}

                          </span>

                        </div>

                        <div style={{ fontSize: 11, color: 'var(--text2)' }}>{em.from}</div>

                      </div>

                      <div style={{ fontSize: 10, color: 'var(--text2)', whiteSpace: 'nowrap', marginLeft: 8 }}>

                        {em.date?.slice(0, 16)}

                      </div>

                    </div>

                    {selected?.id === em.id && (

                      <div style={{ marginTop: 8, padding: 8, background: 'var(--bg2)',

                        borderRadius: 4, fontSize: 12, color: 'var(--text)', whiteSpace: 'pre-wrap' }}>

                        {em.body || '(пусто)'}

                      </div>

                    )}

                  </div>

                ))}

            </div>

          )}

        </div>

      )}



      {tab2 === 'keys' && (

        <div>

          <button className="btn-primary" onClick={scanKeys} disabled={keysLoading} style={{ marginBottom: 12 }}>

            {keysLoading ? 'Сканирование...' : '🔍 Сканировать почту на API ключи'}

          </button>

          {keys.length === 0 ? (

            <div className="card" style={{ textAlign: 'center', padding: 40 }}>

              <div style={{ fontSize: 32, marginBottom: 8 }}>🔑</div>

              <div style={{ color: 'var(--text2)' }}>

                Нажмите "Сканировать" чтобы найти API ключи в письмах

              </div>

            </div>

          ) : (

            <div style={{ display: 'flex', flexDirection: 'column', gap: 8 }}>

              {keys.map((k, i) => (

                <div key={i} className="card" style={{ padding: 14, borderLeft: '3px solid #10b981' }}>

                  <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>

                    <div style={{ fontWeight: 600, fontSize: 14 }}>{k.provider_name}</div>

                    <span style={{ fontSize: 11, color: '#10b981', fontWeight: 600 }}>НАЙДЕН</span>

                  </div>

                  <div style={{ fontFamily: 'monospace', fontSize: 12, color: 'var(--text2)', marginTop: 4 }}>

                    {k.key?.slice(0, 12)}...{k.key?.slice(-4)}

                  </div>

                  <div style={{ fontSize: 11, color: 'var(--text2)', marginTop: 2 }}>

                    Из письма: {k.email_subject}

                  </div>

                </div>

              ))}

            </div>

          )}

        </div>

      )}

    </div>

  );

}



