            </>
          )}
          {(trends.niches||[]).length > 0 && (
            <>
              <div style={{fontSize:11, color:'var(--text2)', margin:'8px 0 4px', fontWeight:500}}>POD \u043D\u0438\u0448\u0438:</div>
