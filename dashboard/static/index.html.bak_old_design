function formatUptime(s) {

  if (!s && s !== 0) return '—';

  const d = Math.floor(s / 86400);

  const h = Math.floor((s % 86400) / 3600);

  const m = Math.floor((s % 3600) / 60);

  return `${d}д ${h}ч ${m}м`;

}



function ServiceStatusBlock({ data }) {

  // Accept dict {name: status} OR array [{name, status, info}]

  let services;

  if (Array.isArray(data)) {

    services = data;

  } else if (data && typeof data === 'object') {

    services = Object.entries(data).map(([name, status]) => ({

      name, status: typeof status === 'string' ? status : 'unknown', info: ''

    }));

  } else {

    services = [

      { name: 'personal-ai', status: 'unknown', info: '' },

      { name: 'bybit-monitor', status: 'unknown', info: '' },

    ];

  }

  const dotClass = s => {

    if (s === 'active' || s === 'running' || s === 'ok') return 'sdot-green';

    if (s === 'warning' || s === 'slow') return 'sdot-yellow';

    if (s === 'error' || s === 'down') return 'sdot-red';

