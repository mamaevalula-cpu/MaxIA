<!-- ═══════════════════ БРАУЗЕР ═══════════════════ -->
<div id="sc-browser" class="sc">
  <div style="display:flex;gap:12px;flex-wrap:wrap;align-items:flex-start">

    <!-- Left: Screenshot -->
    <div style="flex:1.4;min-width:360px">
      <div class="card">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px">
          <span style="font-weight:700;font-size:1.05rem">🖥 Браузер</span>
          <span id="br-state-chip" class="badge b-b">UNKNOWN</span>
          <span id="br-owner-chip" class="badge" style="background:#0b1525;color:var(--txt3)">no owner</span>
          <div style="margin-left:auto;display:flex;gap:6px">
            <button class="btn btn-g" onclick="browserStart()" style="font-size:.78rem;padding:4px 10px">▶ Start</button>
            <button class="btn btn-r" onclick="browserStop()" style="font-size:.78rem;padding:4px 10px">■ Stop</button>
          </div>
        </div>
        <div style="display:flex;gap:6px;margin-bottom:10px">
          <input id="br-url-input" type="text" placeholder="https://..." class="inp" style="flex:1;font-size:.82rem" />
          <button class="btn btn-b" onclick="browserNavigate()" style="font-size:.8rem;padding:5px 14px">Go</button>
        </div>
        <div style="background:#040a14;border-radius:6px;overflow:hidden;min-height:260px;border:1px solid var(--brd);position:relative">
          <img id="br-screenshot" src="" alt="" style="width:100%;display:block" onerror="this.style.opacity=0" />
          <div id="br-no-screen" style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;color:var(--txt3);font-size:.85rem">нет скриншота</div>
        </div>
        <div style="margin-top:6px;display:flex;justify-content:space-between;align-items:center">
          <span id="br-current-url" style="font-size:.72rem;color:var(--txt3);word-break:break-all;max-width:82%">—</span>
          <button class="btn" onclick="loadBrowser()" style="font-size:.72rem;padding:2px 8px">↻</button>
        </div>
      </div>
    </div>

    <!-- Right: Controls -->
    <div style="flex:1;min-width:300px;display:flex;flex-direction:column;gap:10px">

      <!-- Lease -->
      <div class="card">
        <div class="card-title"><span class="card-title-ico">🔑</span>Управление</div>
        <div style="display:flex;gap:6px;flex-wrap:wrap">
          <button class="btn" onclick="browserAcquireLease()" style="font-size:.78rem;background:#0f766e;color:#fff">Acquire Lease</button>
          <button class="btn" onclick="browserReleaseLease()" style="font-size:.78rem">Release</button>
          <button class="btn" onclick="browserTakeoverRequest()" style="font-size:.78rem;background:var(--yel2);color:#000">Human Takeover</button>
          <button class="btn" onclick="browserTakeoverRelease()" style="font-size:.78rem">↩ Release</button>
          <button class="btn" onclick="browserReconcile()" style="font-size:.78rem">⚖ Reconcile</button>
          <button class="btn" onclick="browserRecover()" style="font-size:.78rem;background:var(--pur2);color:#fff">🔄 Recover</button>
        </div>
        <div style="margin-top:8px;font-size:.75rem;color:var(--txt3)">
          Token: <code id="br-token-display" style="color:var(--yel);font-size:.7rem;word-break:break-all">—</code>
        </div>
      </div>

      <!-- Action -->
      <div class="card">
        <div class="card-title"><span class="card-title-ico">⚡</span>Действие</div>
        <div style="display:flex;gap:6px;margin-bottom:6px">
          <select id="br-action-select" class="inp" style="flex:1;font-size:.8rem">
            <option value="inspect">inspect</option>
            <option value="get_text">get_text</option>
            <option value="screenshot">screenshot</option>
            <option value="validate">validate</option>
            <option value="scroll">scroll</option>
            <option value="navigate">navigate</option>
            <option value="click">click</option>
            <option value="type">type</option>
          </select>
          <button class="btn btn-b" onclick="browserExecuteAction()" style="font-size:.78rem;padding:5px 12px">Run</button>
        </div>
        <textarea id="br-action-params" rows="2" placeholder='{"selector":"","value":""}' class="inp" style="width:100%;font-size:.75rem;resize:vertical;min-height:42px"></textarea>
      </div>

      <!-- Checkpoints -->
      <div class="card">
        <div class="card-title"><span class="card-title-ico">💾</span>Чекпоинты</div>
        <div id="br-checkpoints-list" style="font-size:.75rem;color:var(--txt3);max-height:80px;overflow-y:auto">—</div>
      </div>
    </div>
  </div>

  <!-- Log -->
  <div class="card" style="margin-top:12px">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
      <span class="card-title" style="margin:0">📋 Лог действий</span>
      <button class="btn" onclick="$('br-log').innerHTML=''" style="font-size:.72rem;padding:2px 8px">Очистить</button>
    </div>
    <div id="br-log" class="logbox" style="height:160px;min-height:80px;font-size:.75rem"></div>
  </div>
</div>

<!-- ═══════════════════ JAVASCRIPT ═══════════════════ -->
<script>
'use strict';
const HYP = '/api/hyperion';
const $ = id => document.getElementById(id);
const esc = s => String(s??'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
const fmtN = v => v==null?'—':typeof v==='number'?v.toLocaleString('ru-RU'):esc(String(v));
const fmtT = iso => { try{const d=new Date(iso);return isNaN(d)?esc(String(iso)):d.toLocaleTimeString('ru-RU');}catch{return '—';} };
const fmtDT = iso => { try{const d=new Date(iso);return isNaN(d)?esc(String(iso)):d.toLocaleString('ru-RU');}catch{return '—';} };
const fmtMs = v => v>1000?(v/1000).toFixed(1)+'с':Math.round(v||0)+'мс';
const clamp = (v,a,b) => Math.min(Math.max(v||0,a),b);

let curTab='dash', loaded={}, autoT=null, autologT=null;

// ─── API call ──────────────────────────────────────────────────────────────
// 800ms debounce utility
function debounce(fn, ms) {
  let timer;
  return function(...args) {
    clearTimeout(timer);
    timer = setTimeout(() => fn.apply(this, args), ms);
  };
}
const debouncedLoadLogs = debounce(loadLogs, 800);

async function api(path, opts={}) {
  try {
    const r = await fetch(path, {signal:AbortSignal.timeout(14000),...opts});
    if (!r.ok) throw new Error('HTTP '+r.status+' '+r.statusText);
    return await r.json();
  } catch(e) {
    console.warn('API', path, e.message);
    return null;
  }
}

// ─── Feedback helper ───────────────────────────────────────────────────────
function showFb(id, msg, ok=true) {
  const el = $(id);
  if (!el) return;
  el.textContent = msg;
  el.className = 'fb show ' + (ok ? 'fb-ok' : 'fb-err');
  setTimeout(() => { el.className = 'fb'; }, 4000);
}

// ─── Badge / Dot helpers ───────────────────────────────────────────────────
function bdg(t, cls='b') { return `<span class="badge b-${cls}">${esc(String(t??''))}</span>`; }
function dot(ok) { return `<span class="dot dot-${ok?'g':'r'}"></span>`; }
function bar(pct, cls='acc') {
  const w = clamp(pct,0,100);
  return `<div class="pb"><div class="pb-f pb-${cls}" style="width:${w}%"></div></div>`;
}
function statCard(val, lbl, sub='', cls='') {
  return `<div class="stat ${cls}"><div class="stat-val">${esc(String(val??'—'))}</div><div class="stat-lbl">${lbl}</div>${sub?`<div class="stat-sub">${sub}</div>`:''}</div>`;
}

// ─── Clock ─────────────────────────────────────────────────────────────────
setInterval(() => $('hdr-time').textContent = new Date().toLocaleTimeString('ru-RU'), 1000);

// ─── Header refresh ────────────────────────────────────────────────────────
async function refreshHeader() {
  const d = (window.__ST__ && window.__ST__.brain) ? window.__ST__ : await api('/api/status');
  window.__ST__ = null;
  if (!d) return;
  const ok = d.service === 'ok';
  const chip = $('chip-svc');
  chip.innerHTML = `<span class="pulse"></span><span>${ok?'ОНЛАЙН':'СБОЙ'}</span>`;
  chip.className = 'hchip ' + (ok ? 'hchip-g' : 'hchip-r');
  $('chip-agents').textContent = (d.agents_count||0) + ' агентов';
  const t = d.tasks||{};
  $('chip-tasks').textContent = (t.running||0) + ' активных';
  $('chip-cost').textContent = '$'+(+(d.daily_cost_usd||0)).toFixed(4);
  const tr = d.trading||{};
  if (tr.balance_usdt) {
    const bal = $('chip-balance');
    bal.textContent = '$'+fmtN(tr.balance_usdt||0);
    bal.className = 'hchip hchip-g';
  }
  const pnl = tr.daily_pnl_usdt||0;
  const pnlEl = $('chip-pnl');
  pnlEl.textContent = 'PnL '+(pnl>=0?'+':'')+fmtN(pnl)+'$';
  pnlEl.className = 'hchip '+(pnl>0?'hchip-g':pnl<0?'hchip-r':'hchip-b');
}
window.__ST2__ = window.__ST__;
refreshHeader();
setInterval(refreshHeader, 20000);

// ─── Tab switching ─────────────────────────────────────────────────────────
const TABS = ['dash','revenue','agents','tasks','quality','failures','evolution','platforms','skills','scout','llm','chat','logs','browser'];

// Russian status label map
const RU_STATUS = {
  'ok':              'Онлайн',
  'error':           'Ошибка',
  'connecting':      'Синхронизация шлюзов...',
  'CONNECTING':      'Синхронизация автономных шлюзов...',
  'REVENUE_ACTIVE':  'Генерация прибыли активна',
  'REVENUE_PAUSED':  'Генерация прибыли приостановлена',
  'MAINTENANCE':     'Техническое обслуживание',
  'active':          'Активен',
  'inactive':        'Неактивен',
  'failed':          'Ошибка запуска',
  'running':         'Выполняется',
  'pending':         'Ожидание',
  'completed':       'Завершено',
};
function ruStatus(s) { return RU_STATUS[s] || s; }

function go(tab) {
  document.querySelectorAll('.tb').forEach((el,i) => el.classList.toggle('on', TABS[i]===tab));
  TABS.forEach(t => { const s=$('sc-'+t); if(s) s.classList.toggle('on',t===tab); });
  curTab = tab;
  if (!loaded[tab]) { loaded[tab]=true; loadTab(tab); }
  clearInterval(autoT);
  autoT = setInterval(() => { loaded[tab]=false; loaded[tab]=true; loadTab(tab); }, 30000);
}
function loadTab(t) {
  const m = {
    dash:loadDash, revenue:loadRevenue, agents:loadAgents, tasks:loadTasks,
    quality:loadQuality, failures:loadFailures, evolution:loadEvolution,
    platforms:loadPlatforms, skills:loadSkills, scout:loadScout,
    llm:loadLLM, chat:()=>{}, logs:loadLogs, browser:loadBrowser
  };
  if (m[t]) m[t]();
}
function refreshAll() {
  loaded[curTab] = false;
  loaded[curTab] = true;
  loadTab(curTab);
  refreshHeader();
}

// ═══════════════════════════════════════════════════════════════════════════
//  ГЛАВНАЯ
// ═══════════════════════════════════════════════════════════════════════════
async function loadDash() {
  const _sSt = window.__ST2__;
  const _sHm = window.__HM__;
  window.__ST2__ = null; window.__HM__ = null;
  const [st, hm] = _sSt && _sHm
    ? [_sSt, _sHm]
    : await Promise.all([api('/api/status'), api(HYP+'/api/v1/overview/metrics')]);

  if (st) {
    const t = st.tasks||{};
    $('dash-kpis').innerHTML = [
      statCard(st.agents_count||0, 'Агентов загружено', '', 'stat-acc'),
      statCard(t.running||0, 'Активных задач', '', 'stat-grn'),
      statCard(t.completed||0, 'Завершено', 'всего'),
      statCard(t.failed||0, 'С ошибками', '', t.failed>0?'stat-red':''),
      statCard('$'+(+(st.daily_cost_usd||0)).toFixed(4), 'Расходы сегодня', 'лимит $'+st.cost_limit_usd),
    ].join('');
    // Trading stats block
    const tr = st.trading||{};
    const trPnl = tr.daily_pnl_usdt||0;
    $('dash-kpis').innerHTML += [
      statCard('$'+fmtN(tr.balance_usdt||0), 'Баланс Bybit', tr.online?'онлайн':'офлайн', 'stat-grn'),
      statCard((trPnl>=0?'+':'')+fmtN(trPnl)+'$', 'PnL сегодня', (tr.daily_pnl_pct||0).toFixed(2)+'%', trPnl>=0?'stat-grn':'stat-red'),
    ].join('');

    const statusMap = {ok:'g', error:'r', degraded:'y'};
    $('dash-params').innerHTML = [
      ['Сервис', bdg(st.service||'?', statusMap[st.service]||'b')],
      ['Brain', bdg(st.brain||'?', statusMap[st.brain]||'b')],
      ['Watchdog', bdg(st.watchdog||'?', statusMap[st.watchdog]||'b')],
      ['Автономия', bdg(st.autonomy_enabled?'включена':'выкл', st.autonomy_enabled?'g':'y')],
      ['Groq-only', bdg(st.groq_only_mode?'ВКЛ':'ВЫКЛ', st.groq_only_mode?'y':'g')],
      ['Уровень защиты', bdg(st.guardrail_level||0, 'b')],
    ].map(([l,v]) => `<div class="row"><span class="row-left">${esc(l)}</span>${v}</div>`).join('');
    // Trading status
    const tr2 = st.trading||{};
    $('dash-params').innerHTML += [
      ['Bybit торговля', bdg(tr2.online?'активна':'стоп', tr2.online?'g':'r')],
    ].map(([l,v]) => `<div class="row"><span class="row-left">${esc(l)}</span>${v}</div>`).join('');
  }

  // Load trading positions and signals
  try {
    const [posData, sigData] = await Promise.all([
      api('/api/trading/positions'),
      api('/api/trading/signals'),
    ]);
    // Positions
    const positions = (posData||{}).positions||[];
    if (positions.length > 0) {
      $('dash-positions').innerHTML = positions.map(p => {
        const pnlPos = (p.pnl||0) >= 0;
        const pnlStr = (p.pnl>=0?'+':'')+fmtN(p.pnl||0);
        return `<div class="row" style="border-bottom:1px solid var(--brd2);padding-bottom:4px;margin-bottom:4px">
          <span class="row-left"><b style="color:${p.side==='Buy'?'var(--grn)':'var(--red)'}">${p.side==='Buy'?'▲':'▼'} ${esc(p.symbol)}</b>
          <span style="font-size:10px;color:var(--txt3);margin-left:6px">×${p.leverage||1}x qty=${p.size||0}</span></span>
          <span style="color:${pnlPos?'var(--grn)':'var(--red)'};font-weight:700">${pnlStr}$</span>
        </div>
        <div class="row" style="font-size:11px;color:var(--txt3);margin-top:-4px;margin-bottom:6px">
          <span>Вход: ${(p.entry_price||0).toFixed(3)}</span>
          <span>Текущ: ${(p.mark_price||0).toFixed(3)}</span>
          <span>SL: ${(p.stop_loss||0).toFixed(3)}</span>
          <span>TP: ${(p.take_profit||0).toFixed(3)}</span>
        </div>`;
      }).join('');
    } else {
      $('dash-positions').innerHTML = '<div style="color:var(--txt3);padding:12px;font-size:12px;text-align:center">Нет открытых позиций</div>';
    }
    // Signals summary
    const sigs = (sigData||{}).signals||[];
    if (sigs.length > 0) {
      $('dash-signals').innerHTML = sigs.map(sym_data => {
        const sym = sym_data.symbol||'';
        const actionable = (sym_data.strategies||[]).filter(s => s.action!=='HOLD' && s.strength>=0.5);
        if (actionable.length === 0) {
          const best = (sym_data.strategies||[]).reduce((a,b) => (b.strength||0)>(a.strength||0)?b:a, {strategy:'',strength:0,reason:'HOLD'});
          return `<div class="row"><span class="row-left" style="font-size:11px"><b>${esc(sym)}</b></span><span style="color:var(--txt3);font-size:10px">HOLD</span></div>`;
        }
        return actionable.map(s => `<div class="row">
          <span class="row-left"><b style="color:${s.action==='BUY'?'var(--grn)':'var(--red)'}">${s.action} ${esc(sym)}</b>
          <span style="font-size:10px;color:var(--txt3);margin-left:4px">${esc(s.strategy)}</span></span>
          ${bdg((s.strength*100).toFixed(0)+'%', s.strength>=0.8?'g':'y')}
        </div>`).join('');
      }).join('');
    } else {
      $('dash-signals').innerHTML = '<div style="color:var(--txt3);padding:12px;font-size:12px;text-align:center">Нет данных сигналов</div>';
    }
  } catch(e) {
    $('dash-positions').innerHTML = '<div style="color:var(--txt3);padding:8px;font-size:11px">Ошибка загрузки позиций</div>';
  }

  if (hm) {
    const kpi=hm.kpi||{}, h=hm.subsystems_health||{}, al=hm.alert_strip||{};
    const hp = hm.health_percent||0;
    $('dash-health').innerHTML = Object.entries(h).map(([k,v]) => {
      const ok = v==='GREEN';
      const labels = {db:'База данных',amqp:'Очередь сообщ.',pipeline:'Pipeline',evolution:'Эволюция',revenue:'Доходы',quality:'Качество'};
      return `<div class="row">
        <span class="row-left">${dot(ok)}<span>${labels[k]||esc(k.replace(/_/g,' '))}</span></span>
        ${bdg(ok?'ОК':v, ok?'g':'r')}
      </div>`;
    }).join('') || '<div style="color:var(--txt3);padding:8px;font-size:12px">Нет данных о подсистемах</div>';

    $('dash-hkpi').innerHTML = [
      ['Пропускная способность', fmtN((kpi.throughput||{}).value||0)+' з/с'],
      ['Чистая маржа', fmtN((kpi.net_margin||{}).value||0)+'%'],
      ['Глубина очереди', fmtN((kpi.queue_depth||{}).value||0)],
      ['ROI токенов', fmtN((kpi.token_roi||{}).value||0)+'%'],
      ['Здоровье системы', hp+'%'],
    ].map(([l,v]) => `<div class="row"><span class="row-left">${esc(l)}</span><span style="color:var(--acc);font-weight:700">${v}</span></div>`).join('');

    const firing = al.current_firing_incidents||0;
    $('dash-alerts').innerHTML = `
      ${firing>0?`<div class="alert alert-r">🚨 ${firing} активных инцидентов!</div>`:'<div class="alert alert-g">✅ Инцидентов нет</div>'}
      <div class="row"><span class="row-left">Подавлено алертов</span>${bdg(al.active_suppressed_alerts||0,'y')}</div>
      <div class="row"><span class="row-left">Здоровье</span>${bdg(hp+'%', hp>=100?'g':hp>=70?'y':'r')}</div>
      ${bar(hp, hp>=100?'grn':hp>=70?'yel':'red')}
      <div style="font-size:10px;color:var(--txt3);margin-top:3px">${hp}% подсистем в норме</div>
    `;
  }
}

// ═══════════════════════════════════════════════════════════════════════════
//  ДОХОДЫ
// ═══════════════════════════════════════════════════════════════════════════
async function loadRevenue() {
  const d = await api(HYP+'/api/v1/revenue/radar');
  if (!d) { showNoData(['rev-kpis','rev-tbl','rev-phases']); return; }
  const streams = d.revenue_streams||[], pct = +(d.progress_pct||0);
  $('rev-kpis').innerHTML = [
    statCard('$'+fmtN(d.total_revenue_usd||0), 'Общий доход', '', 'stat-grn'),
    statCard('$'+fmtN(d.monthly_target_usd||0), 'Месячная цель'),
    statCard(pct.toFixed(1)+'%', 'Прогресс к цели', bar(pct,'yel'), 'stat-yel'),
    statCard(streams.length, 'Активных потоков', '', 'stat-acc'),
  ].join('');

  $('rev-tbl').innerHTML = streams.map(s => `<tr>
    <td><b style="color:var(--acc)">${esc(s.name||'')}</b></td>
    <td style="font-size:11px;color:var(--txt3);font-family:'Consolas',monospace">${esc(s.agent||'')}</td>
    <td style="color:var(--grn);font-weight:700">$${fmtN(s.revenue_usd||0)}</td>
    <td>${bdg(s.status||'?', s.status==='ACTIVE'?'g':s.status==='SETUP'?'y':'b')}</td>
  </tr>`).join('') || '<tr><td colspan="4" style="text-align:center;padding:20px;color:var(--txt3)">Нет данных о потоках доходов</td></tr>';

  const phases = [
    {k:'phase_1_target', n:'Фаза 1 — Россия/Казахстан/Беларусь/Украина'},
    {k:'phase_2_target', n:'Фаза 2 — Глобальный английский рынок'},
    {k:'phase_3_target', n:'Фаза 3 — APAC (Азия-Пацифик)'},
  ];
  $('rev-phases').innerHTML = phases.map(p => {
    const t=d[p.k]||0, pg=t>0?Math.min((d.total_revenue_usd||0)/t*100,100):0;
    const cls = pg>=100?'grn':pg>=50?'yel':'acc';
    return `<div class="phase-item">
      <div class="phase-head"><span class="phase-name">${p.n}</span><span class="phase-target">$${fmtN(t)}</span></div>
      ${bar(pg,cls)}
      <div class="phase-pct">${pg.toFixed(1)}% от цели — текущий доход $${fmtN(d.total_revenue_usd||0)}</div>
    </div>`;
  }).join('');
}

// ═══════════════════════════════════════════════════════════════════════════
//  АГЕНТЫ
// ═══════════════════════════════════════════════════════════════════════════
async function loadAgents() {
  const [lo, lh] = await Promise.all([api('/api/agents'), api(HYP+'/api/v1/agents/fleet')]);
  const fleet = lh?(lh.fleet||[]):(lo?(lo.agents||[]):[]);
  const total = lh?lh.total_agents:fleet.length;
  const byR = lh?(lh.by_rank||{}):{};
  const byD = lh?(lh.by_department||{}):{};
  const avgQ = lh?(lh.avg_quality||0):0;

  $('ag-kpis').innerHTML = [
    statCard(total||0,'Всего агентов','','stat-acc'),
    statCard(avgQ,'Ср. качество','/100',avgQ>=80?'stat-grn':''),
    statCard(byR.ELITE||0,'Элитных','уровень ELITE','stat-pur'),
    statCard(Object.keys(byD).length,'Отделов','',''),
  ].join('');

  const rCls = {ELITE:'p',SENIOR:'b',MID:'g',JUNIOR:'y'};
  const rName = {ELITE:'Элита',SENIOR:'Старший',MID:'Средний',JUNIOR:'Новичок'};
  $('ag-rank').innerHTML = Object.entries(byR).map(([r,n]) =>
    `<div class="row"><span class="row-left">${bdg(rName[r]||r, rCls[r]||'b')}</span><b style="color:#ddeeff;font-size:14px">${n}</b></div>`
  ).join('') || '<div style="color:var(--txt3);padding:10px;font-size:12px">Данные по уровням недоступны</div>';

  $('ag-dept').innerHTML = Object.entries(byD).map(([dep,n]) =>
    `<div class="row"><span class="row-left">${esc(dep)}</span><span style="color:var(--acc);font-weight:700">${n}</span></div>`
  ).join('') || '<div style="color:var(--txt3);padding:10px;font-size:12px">Данные по отделам недоступны</div>';

  $('ag-tbl').innerHTML = fleet.slice(0,120).map(a => {
    const q = +(a.quality_score||0);
    const qc = q>=90?'#00d880':q>=75?'#3ab8e8':q>=60?'#ffb800':'#ff3050';
    return `<tr>
      <td style="font-family:'Consolas',monospace;font-size:11px;color:#ddeeff">${esc(a.name||a.file||'?')}</td>
      <td style="font-size:11px;color:var(--txt2)">${esc(a.department||'—')}</td>
      <td>${bdg(rName[a.rank]||a.rank||'MID', rCls[a.rank||'MID']||'b')}</td>
      <td><span style="color:${qc};font-weight:700">${q||'—'}</span></td>
      <td>${bdg(a.status==='active'?'активен':a.status||'?', a.status==='active'?'g':'y')}</td>
      <td style="font-size:11px;color:var(--txt3);max-width:200px">${esc((a.desc||a.schedule||'—').slice(0,50))}</td>
    </tr>`;
  }).join('') || '<tr><td colspan="6" style="text-align:center;padding:20px;color:var(--txt3)">Нет данных о флоте агентов</td></tr>';
}

// ═══════════════════════════════════════════════════════════════════════════
//  ЗАДАЧИ
// ═══════════════════════════════════════════════════════════════════════════
async function loadTasks() {
  const d = await api('/api/tasks');
  if (!d) return;
  const tasks = d.tasks||[], st = d.stats||{};
  $('task-kpis').innerHTML = [
    statCard(tasks.length,'Задач всего','',''),
    statCard(st.running||0,'Активных','','stat-grn'),
    statCard(st.completed||0,'Завершено','','stat-acc'),
    statCard(st.failed||0,'Ошибок','',st.failed>0?'stat-red':''),
  ].join('');

  const stMap = {running:'g',completed:'b',failed:'r',pending:'y'};
  const stName = {running:'активна',completed:'завершена',failed:'ошибка',pending:'ожидание'};
  $('task-tbl').innerHTML = tasks.slice(0,60).map(t => `<tr>
    <td style="font-family:'Consolas',monospace;font-size:10px;color:var(--txt3)">${esc((t.id||'').slice(0,18))}</td>
    <td style="font-size:11px;color:var(--acc)">${esc(t.agent||'—')}</td>
    <td style="max-width:240px;font-size:11px">${esc((t.description||'').slice(0,70))}</td>
    <td>${bdg(stName[t.status]||t.status||'?', stMap[t.status]||'y')}</td>
    <td style="font-size:11px;color:var(--txt3)">${esc(t.source||'—')}</td>
    <td style="font-size:11px;color:var(--txt3);white-space:nowrap">${fmtT(t.updated_at||t.created_at)}</td>
  </tr>`).join('') || '<tr><td colspan="6" style="text-align:center;padding:20px;color:var(--txt3)">Задач пока нет</td></tr>';
}

async function runPipeline() {
  const goal = $('pipe-goal').value.trim() || 'Общий анализ';
  const tagsRaw = $('pipe-tags').value.trim() || 'general';
  const tags = tagsRaw.split(',').map(s=>s.trim()).filter(Boolean);
  const prompt = $('pipe-prompt').value.trim() || goal;
  const btn = $('pipe-btn');
  btn.disabled = true; btn.textContent = '⏳ Выполняется...';
  $('pipe-res').textContent = 'Выполняется pipeline...';
  $('pipe-info').textContent = '';

  const r = await api(HYP+'/api/v2/pipeline/run',{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({task_id:'ui_'+Date.now(), goal, tags, prompt})
  });

  btn.disabled = false; btn.textContent = '▶ Запустить';
  if (!r) { showFb('pipe-fb','Ошибка выполнения',false); $('pipe-res').textContent='Ошибка: нет ответа от сервера'; return; }

  const ok = r.status === 'completed';
  showFb('pipe-fb', ok?'✓ Успешно':'⚠ '+r.status, ok);
  $('pipe-info').textContent = `Статус: ${r.status} | Время: ${r.elapsed_ms||0}мс | Навыки: ${(r.skills_used||[]).join(', ')||'—'}`;
  $('pipe-res').textContent = JSON.stringify(r, null, 2);
}

// ═══════════════════════════════════════════════════════════════════════════
//  КАЧЕСТВО + SLO
// ═══════════════════════════════════════════════════════════════════════════
async function loadQuality() {
  const [ql,sl] = await Promise.all([
    api(HYP+'/api/v1/quality/lab'),
    api(HYP+'/api/v1/task-flow/slo')
  ]);

  if (ql) {
    const g=ql.grade_distribution||{}, bl=ql.improvement_backlog||[];
    const avg=ql.avg_score||0;
    $('ql-kpis').innerHTML = [
      statCard(avg,'Средний балл','/100',avg>=80?'stat-grn':avg>=60?'':'stat-red'),
      statCard(ql.agents_audited||0,'Проверено агентов',''),
      statCard(bl.length,'В очереди улучш.',''),
      statCard(ql.last_audit==='never'?'Нет':fmtT(ql.last_audit),'Последний аудит',''),
    ].join('');

    const gcls = {A:'g',B:'b',C:'y',D:'r',F:'r'};
    const gname = {A:'Отлично',B:'Хорошо',C:'Удовлетворит.',D:'Плохо',F:'Провал'};
    $('ql-grades').innerHTML = Object.entries(g).map(([gr,n]) => {
      const p = ql.agents_audited?Math.round(n/ql.agents_audited*100):0;
      return `<div style="margin-bottom:12px">
        <div class="row">
          <span class="row-left"><span class="grade-${gr.toLowerCase()}">${gr}</span><span style="font-size:12px"> — ${gname[gr]||gr}</span></span>
          <b style="color:#ddeeff">${n} (${p}%)</b>
        </div>
        ${bar(p, gr==='A'||gr==='B'?'grn':gr==='C'?'yel':'red')}
      </div>`;
    }).join('') || '<div class="alert alert-b">ℹ Аудит ещё не проводился. Quality Guardian запускается каждые 6 часов.</div>';

    $('ql-backlog').innerHTML = bl.slice(0,12).map(i =>
      `<div class="row"><span class="row-left" style="font-size:11px">${esc(i.agent||String(i))}</span>${bdg(i.priority==='high'?'высокий':i.priority==='low'?'низкий':'средний',i.priority==='high'?'r':'y')}</div>`
    ).join('') || '<div class="alert alert-g">✅ Очередь пуста — все агенты в порядке</div>';
  }

  if (sl) {
    const s=sl.slo_status||{}, pipe=sl.pipeline||{};
    const p95 = s.p95_latency_ms||0, tgt = sl.slo_target_p95_ms||1500;
    $('slo-kpis').innerHTML = [
      statCard(fmtMs(s.p50_latency_ms||0),'Медиана (P50)','цель: 500мс'),
      statCard(fmtMs(p95),'Перцентиль P95',sl.slo_breach?'⚠ НАРУШЕНИЕ SLO':'в норме',p95>tgt?'stat-red':'stat-grn'),
      statCard(fmtMs(s.p99_latency_ms||0),'Перцентиль P99',''),
      statCard((sl.throughput_tasks_per_min||0).toFixed(2),'Задач/минуту',''),
    ].join('');

    $('slo-lat').innerHTML = [
      {l:'P50',v:s.p50_latency_ms||0,t:500,n:'Медиана'},
      {l:'P95',v:p95,t:tgt,n:'95-й перц.'},
      {l:'P99',v:s.p99_latency_ms||0,t:tgt*2,n:'99-й перц.'}
    ].map(p => {
      const pct=clamp(p.t>0?p.v/p.t*100:0,0,100), c=pct<70?'grn':pct<90?'yel':'red';
      return `<div style="margin-bottom:12px">
        <div class="row"><span class="row-left"><b>${p.l}</b> ${p.n}</span><span style="color:#ddeeff;font-weight:700">${fmtMs(p.v)}</span></div>
        ${bar(pct,c)}<div style="font-size:10px;color:var(--txt3);margin-top:3px">цель: ${fmtMs(p.t)} | ${pct.toFixed(0)}%</div>
      </div>`;
    }).join('');

    $('slo-pipe').innerHTML = Object.entries(pipe).map(([k,v]) =>
      `<div class="row"><span class="row-left">${esc(k)}</span><span style="color:var(--acc)">${fmtN(v)}</span></div>`
    ).join('') || '<div style="color:var(--txt3);padding:10px;font-size:12px">Нет данных Pipeline</div>';
  }
}

// ═══════════════════════════════════════════════════════════════════════════
//  ИНЦИДЕНТЫ
// ═══════════════════════════════════════════════════════════════════════════
async function loadFailures() {
  const [fc,lg] = await Promise.all([
    api(HYP+'/api/v1/failures/clusters'),
    api(HYP+'/api/v1/ledger')
  ]);

  if (fc) {
    const cl=fc.clusters||[], active=cl.filter(c=>!c.suppressed).length;
    $('fail-kpis').innerHTML = [
      statCard(fc.total||0,'Кластеров ошибок','',fc.total>0?'stat-red':''),
      statCard(active,'Активных','','',active>0?'stat-red':''),
      statCard(fc.alert_governor_active?'ВКЛ':'ВЫКЛ','Управление алертами','',fc.alert_governor_active?'stat-yel':''),
    ].join('');

    $('fail-tbl').innerHTML = cl.map(c => {
      const sv=+(c.severity_score||0), sc=sv>0.7?'r':sv>0.4?'y':'g';
      return `<tr>
        <td style="font-family:'Consolas',monospace;font-size:10px;color:var(--txt3)">${esc((c.cluster_hash||'').slice(0,20))}</td>
        <td style="font-size:11px;max-width:180px">${esc((c.root_cause_shortlist||c.root_cause||'—').slice(0,60))}</td>
        <td style="color:var(--acc);font-weight:700">${c.hit_count||0}</td>
        <td>${bdg(sv.toFixed(2),sc)}</td>
        <td style="font-size:11px;color:var(--txt3)">${fmtDT(c.last_seen)}</td>
        <td>${bdg(c.suppressed?'подавлен':'активен',c.suppressed?'b':'r')}</td>
      </tr>`;
    }).join('') || '<tr><td colspan="6" style="text-align:center;padding:20px;color:var(--txt3)">✅ Кластеров ошибок нет — система стабильна</td></tr>';
  }

  if (lg) {
    const entries=lg.entries||[];
    const actMap={'kill_switch':'Kill Switch','block_retries':'Блок ретраев','rollback':'Откат','switch_backup':'Резерв'};
    $('lgr-tbl').innerHTML = entries.map(e => `<tr>
      <td style="font-size:10px;color:var(--txt3);white-space:nowrap">${fmtDT(e.ts)}</td>
      <td>${bdg(esc(e.initiator||'?'),'b')}</td>
      <td>${bdg(actMap[e.action_type]||esc(e.action_type||'?'),e.action_type==='kill_switch'?'r':'g')}</td>
      <td style="font-size:11px;font-family:'Consolas',monospace">${esc(e.target||'—')}</td>
      <td style="font-size:11px;color:var(--txt3);max-width:180px">${esc((e.reason||'').slice(0,60))}</td>
    </tr>`).join('') || '<tr><td colspan="5" style="text-align:center;padding:14px;color:var(--txt3)">Журнал пуст</td></tr>';
  }
}

async function doIncident(action) {
  const actionNames = {kill_switch:'KILL SWITCH',block_retries:'Блокировка ретраев',rollback:'Откат',switch_backup:'Переключение на резерв'};
  const fb = $('incident-feedback');
  fb.innerHTML = `<div class="alert alert-b">⏳ Выполняется: ${actionNames[action]||action}...</div>`;

  const r = await api(HYP+'/api/v1/incidents/action',{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({action, target:'all', reason:'ручное управление из панели'})
  });

  if (r) {
    fb.innerHTML = `<div class="alert alert-g">✅ Выполнено: ${actionNames[action]||action} — ${r.status||'ok'}</div>`;
    setTimeout(() => { loaded.failures=false; loadFailures(); }, 1000);
  } else {
    fb.innerHTML = `<div class="alert alert-r">❌ Ошибка выполнения команды ${actionNames[action]||action}</div>`;
  }
  setTimeout(() => fb.innerHTML='', 5000);
}

