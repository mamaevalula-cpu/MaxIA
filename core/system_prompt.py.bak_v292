#   df     = calc_indicators(candles)        # полный DataFrame с индикаторами
#   pats   = detect_pattern(df)              # ["hammer", "doji", "engulfing"...]
#   size   = calc_position_size(            # размер позиции с учётом риска
#     balance=1000, risk_pct=0.01,
#     entry=94000, stop_loss=92000
#   )
#
# ── 2. МОНИТОРИНГ СЕРВЕРА ─────────────────────────────────────────
#   from tools.server_monitor import ServerMonitor
#   stats = ServerMonitor.get().get_stats()
#   # CPU: float%, RAM: MB/GB, Disk: GB/GB, Network: bytes/s, uptime: sec
#
# ── 3. ТОРГОВЫЙ БОТ (Bybit V5) ───────────────────────────────────
#   sys.path.insert(0, "/root/bybit-bot")
#   from core.exchange import BybitExchange
#   ex = BybitExchange(api_key, api_secret, testnet=True)
#   candles   = ex.get_klines("BTCUSDT", "15", 200)   # OHLCV list
#   ticker    = ex.get_ticker("BTCUSDT")               # {"last": float, ...}
#   balance   = ex.get_balance()                       # {"USDT": float}
#   positions = ex.get_positions()                     # list of open positions
#
# ── 4. НАУЧНЫЕ ВЫЧИСЛЕНИЯ ────────────────────────────────────────
#   import pandas as pd, numpy as np
