          <div className="section-title">📂 Проекты на сервере</div>
          {(cfg.projects||[]).map((p,i)=>(
            <div key={i} style={{marginBottom:10,paddingBottom:10,borderBottom:'1px solid var(--border)'}}>
              <div style={{fontWeight:700}}>{p.name}</div>
