TASK_ADDONS: dict[str, str] = {
    "code": """
РЕЖИМ: Элитное программирование.
- Пиши только рабочий, production-ready код.
- Type hints, docstring для публичных методов, логирование.
- После кода: как тестировать + возможные edge cases.
- Для веб: всегда проверяй на OWASP Top 10.
- Для платежей: PCI DSS, идемпотентность, retry с backoff.
""",
    "payment": """
РЕЖИМ: Платёжные системы.
- Всегда используй актуальные версии SDK (stripe>=7.0, paypalrestsdk).
- Webhook endpoint: всегда верифицируй подпись!
- Идемпотентность: idempotency_key для всех критичных операций.
- Секреты: никогда не в коде, только os.getenv().
- Тест перед продом: sandbox/test mode обязательно.
- После кода интеграции: чеклист безопасности.
""",
    "freelance": """
РЕЖИМ: Фриланс и поиск работы.
- Proposal: персонализированный, конкретный, показывай понимание задачи.
- Цена: обоснованная, не демпинг, не завышена.
- Структура proposal: крючок → понимание → подход → портфолио → CTA.
- Сроки: реалистичные + 20% буфер.
- Клиент красный флаг: расплывчатые требования, «тест» бесплатно, фиксированная цена без спеки.
""",
    "analysis": """
РЕЖИМ: Глубокий анализ.
- Структура: Факты → Анализ → Вывод → Риски → Действия.
- Конкретные цифры, не «около» без причины.
- Явно разделяй «что точно» и «что предположительно».
- В конце: 1-2 конкретных действия.
""",
    "trading": """
РЕЖИМ: Трейдинг / Bybit.
- Указывай: пара, таймфрейм, вход/выход, стоп-лосс, тейк-профит.
- Риск на сделку: ≤ 1% депозита. Не обсуждается.
- Добавляй: «Это не финансовый совет. Торгуй на свой страх и риск.»
""",
    "math": """
РЕЖИМ: Математика и финансы.
КРИТИЧЕСКИ ВАЖНО: Ты НЕ считаешь математику в голове. Никогда.
Всегда используешь MathAgent с точными движками.

Алгоритм:
  1. Идентифицируй тип: уравнение / производная / финансы / статистика / симуляция
  2. Назови движок: «[MathAgent] → FinanceEngine.npv()»
  3. Покажи ТОЧНЫЙ результат с единицами
  4. Объясни практический смысл
""",
    "chat": """
РЕЖИМ: Общение.
- По делу, без воды.
- Если вопрос предполагает действие — предлагай сделать прямо сейчас.
- Используй знания из памяти (RAG-контекст выше).
""",
}


# ══════════════════════════════════════════════════════════════════════════════
# ФУНКЦИЯ СБОРКИ ФИНАЛЬНОГО ПРОМТА
# ══════════════════════════════════════════════════════════════════════════════

def _get_model_knowledge_text() -> str:
    try:
        from brain.model_profiler import ModelProfiler
        profiler = ModelProfiler.get()
        return profiler.get_model_knowledge_text()
    except Exception:
        return ""


def _get_provider_status_text() -> str:
    try:
        from brain.llm_router import LLMRouter
        router = LLMRouter.get()
        report = router.status_report()
        available = [p for p, s in report.items() if s["available"]]
        unavailable = [p for p, s in report.items()
                       if not s["available"] and not s["tokens_exhausted"]]
        exhausted = [p for p, s in report.items() if s["tokens_exhausted"]]
        lines = []
        if available:
            lines.append(f"✅ Активны: {', '.join(available)}")
        if exhausted:
            lines.append(f"⚠️ Лимит исчерпан: {', '.join(exhausted)}")
        if unavailable:
            lines.append(f"❌ Нет ключа: {', '.join(unavailable)}")
        return "\n".join(lines)
    except Exception:
        return ""


def build_system_prompt(
    task_type: str = "chat",
    rag_context: str = "",
    projects: Optional[list] = None,
    agent_statuses: Optional[dict] = None,
    include_model_knowledge: bool = True,
) -> str:
    """
    Собрать финальный системный промт для конкретного запроса.

    Args:
        task_type: тип задачи ("code", "analysis", "trading", "payment", "freelance", "chat")
        rag_context: релевантный контекст из памяти
        projects: список активных проектов
        agent_statuses: текущие статусы агентов
        include_model_knowledge: добавить знания о доступных AI-моделях
    """
    parts = [BASE_SYSTEM_PROMPT]

    addon = TASK_ADDONS.get(task_type, TASK_ADDONS["chat"])
    parts.append(addon)

    context_parts = []

    if projects:
        names = ", ".join(p.get("name", "?") for p in projects[:5])
        context_parts.append(f"Активные проекты: {names}")

    if agent_statuses:
        running = [k for k, v in agent_statuses.items() if v == "running"]
        if running:
            context_parts.append(f"Агенты в работе: {', '.join(running)}")

    provider_status = _get_provider_status_text()
    if provider_status:
        context_parts.append(f"LLM провайдеры:\n{provider_status}")

    if context_parts:
        parts.append("\n--- ТЕКУЩИЙ КОНТЕКСТ СИСТЕМЫ ---\n" + "\n".join(context_parts))

    if include_model_knowledge:
        model_knowledge = _get_model_knowledge_text()
        if model_knowledge:
            parts.append(
                "\n--- ЗНАНИЯ О ДОСТУПНЫХ AI-МОДЕЛЯХ ---\n"
                + model_knowledge[:3000]
                + "\n\nИспользуй эти знания для умного выбора модели под задачу."
            )

    if rag_context and len(rag_context.strip()) > 50:
        parts.append(
            "\n--- РЕЛЕВАНТНЫЕ ЗНАНИЯ ИЗ ПАМЯТИ ---\n"
            + rag_context[:2000]
            + "\n(Используй эти знания при ответе)"
        )

    return "\n\n".join(parts)


