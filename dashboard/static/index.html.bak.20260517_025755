// DEVELOPER TERMINAL TAB — replaces Claude Code CLI
// ============================================================
function DeveloperTab() {
  const [cmd, setCmd] = React.useState('');
  const [cwd, setCwd] = React.useState('/root/my_personal_ai');
  const [output, setOutput] = React.useState('# ApexMind Terminal\n# Введите команду или выберите быструю кнопку\n');
  const [cmdHistory, setCmdHistory] = React.useState([]);
  const [histIdx, setHistIdx] = React.useState(-1);
  const [busy, setBusy] = React.useState(false);
  const [panel, setPanel] = React.useState('terminal');
  const [filePath, setFilePath] = React.useState('');
  const [fileContent, setFileContent] = React.useState('');
  const [srchQuery, setSrchQuery] = React.useState('');
  const [srchResults, setSrchResults] = React.useState(null);
  const [fileList, setFileList] = React.useState([]);
  const outRef = React.useRef(null);

  const loadFiles = async (path) => {
    const r = await apiFetch('/api/files?path='+encodeURIComponent(path||cwd));
    if(r.ok && r.data) setFileList(r.data.files||r.data.items||[]);
  };
  React.useEffect(()=>{ loadFiles(cwd); }, [cwd]);

  const execCmd = async () => {
    if(!cmd.trim()||busy) return;
    const c = cmd.trim();
    setCmd('');
    setBusy(true);
    setCmdHistory(h=>[c,...h.slice(0,49)]);
    setHistIdx(-1);
    const r = await apiFetch('/api/terminal/exec',{method:'POST',body:JSON.stringify({cmd:c,cwd})});
    setBusy(false);
    if(r.ok&&r.data) {
      const out = (r.data.stdout||'') + (r.data.stderr?'\n[stderr] '+r.data.stderr:'');
      const line = `\n$ ${c}\n${out.trim()}\n[exit:${r.data.exit_code} | ${r.data.duration_ms}ms]`;
      setOutput(prev=>prev+line+'\n');
    } else {
      setOutput(prev=>prev+`\n$ ${c}\n[Error: ${r.error||'unknown'}]\n`);
    }
    setTimeout(()=>outRef.current?.scrollTo(0,99999),50);
  };

  const openFile = async (path) => {
    setFilePath(path);
    setPanel('editor');
    const r = await apiFetch('/api/files/read?path='+encodeURIComponent(path));
    if(r.ok&&r.data) setFileContent(r.data.content||r.data.text||'');
  };

  const saveFile = async () => {
    if(!filePath) return;
    const r = await apiFetch('/api/files/write',{method:'POST',body:JSON.stringify({path:filePath,content:fileContent})});
    if(r.ok) setOutput(p=>p+`\n[Saved: ${filePath}]\n`);
    setPanel('terminal');
  };

  const doSearch = async () => {
    if(!srchQuery.trim()) return;
    const r = await apiFetch('/api/code/search',{method:'POST',body:JSON.stringify({query:srchQuery,path:cwd})});
    if(r.ok) setSrchResults(r.data);
  };

  const onKey = (e) => {
    if(e.key==='Enter'){execCmd();return;}
    if(e.key==='ArrowUp'){const i=Math.min(histIdx+1,cmdHistory.length-1);setHistIdx(i);if(cmdHistory[i])setCmd(cmdHistory[i]);}
    if(e.key==='ArrowDown'){const i=Math.max(histIdx-1,-1);setHistIdx(i);setCmd(i>=0?cmdHistory[i]:'');}
  };

  const quick = [
    {l:'git status',c:'git status --short'},
    {l:'git log',c:'git log --oneline -10'},
    {l:'ps python',c:'ps aux | grep -E "python|uvicorn" | grep -v grep'},
    {l:'bot logs',c:'tail -20 /root/my_personal_ai/logs/bot.log'},
    {l:'errors',c:'tail -10 /root/my_personal_ai/logs/errors.log'},
    {l:'restart AI',c:'systemctl restart personal-ai && sleep 5 && systemctl is-active personal-ai'},
    {l:'disk',c:'df -h / && du -sh /root/my_personal_ai'},
    {l:'mem',c:'free -h'},
    {l:'agents',c:"curl -s http://localhost:8080/api/agents | python3 -c \"import json,sys; d=json.load(sys.stdin); print([a['name'] for a in d['agents']])\""},
  ];

  return (
    <div>
      <div className="tab-title">💻 Терминал & Редактор (замена Claude Code)</div>
      <div style={{display:'flex',gap:8,marginBottom:12,flexWrap:'wrap'}}>
        {[['terminal','⌨️ Терминал'],['editor','📝 Редактор'],['search','🔍 Поиск кода'],['files','📁 Файлы']].map(([id,label])=>(
          <button key={id} className="btn" onClick={()=>setPanel(id)}
            style={{background:panel===id?'var(--accent)':'var(--card)',color:panel===id?'#000':'var(--text)'}}>
            {label}
          </button>
        ))}
        <span style={{marginLeft:'auto',fontSize:11,color:'var(--text3)',alignSelf:'center',fontFamily:'monospace'}}>
          📂 {cwd}
        </span>
      </div>

      {panel==='terminal'&&(
        <div>
          <div style={{display:'flex',gap:5,flexWrap:'wrap',marginBottom:8}}>
            {quick.map((q,i)=>(
              <button key={i} className="btn" style={{fontSize:11,padding:'3px 8px',background:'var(--bg)',border:'1px solid var(--border)'}}
                onClick={()=>setCmd(q.c)}>{q.l}</button>
            ))}
          </div>
          <div ref={outRef} style={{
            background:'#0d1117',color:'#00ff9d',fontFamily:'monospace',fontSize:12,
            padding:12,borderRadius:8,height:350,overflowY:'auto',whiteSpace:'pre-wrap',
            lineHeight:1.5,border:'1px solid #30363d'}}>
            {output}
          </div>
          <div style={{display:'flex',gap:8,marginTop:8,alignItems:'center'}}>
            <span style={{color:'#00ff9d',fontFamily:'monospace',fontSize:16}}>$</span>
            <input value={cmd} onChange={e=>setCmd(e.target.value)} onKeyDown={onKey}
              placeholder="bash команда... (↑↓ история)" disabled={busy}
              style={{flex:1,background:'#0d1117',border:'1px solid #30363d',borderRadius:6,
                padding:'8px 12px',color:'#e8e8e8',fontSize:13,fontFamily:'monospace'}}/>
            <button className="btn" onClick={execCmd} disabled={busy||!cmd.trim()}
              style={{background:'#2ecc71',color:'#000',fontWeight:700}}>
              {busy?'⏳':'▶ Run'}
            </button>
            <button className="btn" onClick={()=>setOutput('')} style={{background:'var(--card)'}}>🗑</button>
          </div>
          <div style={{marginTop:6}}>
            <input value={cwd} onChange={e=>setCwd(e.target.value)}
              placeholder="Рабочая директория..."
              style={{width:'100%',background:'var(--bg)',border:'1px solid var(--border)',
                borderRadius:6,padding:'5px 10px',color:'var(--text3)',fontSize:11,fontFamily:'monospace'}}/>
          </div>
        </div>
      )}

      {panel==='editor'&&(
        <div>
          <div style={{display:'flex',gap:8,marginBottom:8}}>
            <input value={filePath} onChange={e=>setFilePath(e.target.value)}
              placeholder="/root/my_personal_ai/path/to/file.py"
              style={{flex:1,background:'var(--card)',border:'1px solid var(--border)',
                borderRadius:6,padding:'8px 12px',color:'var(--text)',fontSize:13,fontFamily:'monospace'}}/>
            <button className="btn" onClick={()=>openFile(filePath)}>📂 Открыть</button>
            <button className="btn" onClick={saveFile} style={{background:'#2ecc71',color:'#000',fontWeight:700}}>💾 Сохранить</button>
          </div>
          <textarea value={fileContent} onChange={e=>setFileContent(e.target.value)}
            style={{width:'100%',height:480,background:'#0d1117',color:'#e8e8e8',
              fontFamily:'"Fira Code",monospace',fontSize:12,padding:12,borderRadius:8,
              border:'1px solid #30363d',lineHeight:1.5,resize:'vertical',boxSizing:'border-box'}}/>
        </div>
      )}

      {panel==='search'&&(
        <div>
          <div style={{display:'flex',gap:8,marginBottom:12}}>
            <input value={srchQuery} onChange={e=>setSrchQuery(e.target.value)}
              onKeyDown={e=>e.key==='Enter'&&doSearch()}
              placeholder="Поиск в коде проекта (grep)..."
              style={{flex:1,background:'var(--card)',border:'1px solid var(--border)',
                borderRadius:6,padding:'8px 12px',color:'var(--text)',fontSize:13}}/>
            <button className="btn" onClick={doSearch} style={{background:'var(--accent)',color:'#000',fontWeight:700}}>🔍 Найти</button>
          </div>
          {srchResults&&(
            <div className="card" style={{padding:0,overflow:'hidden'}}>
              <div style={{padding:'8px 14px',borderBottom:'1px solid var(--border)',
                fontSize:12,color:'var(--text2)'}}>
                Найдено {srchResults.count} совпадений: «{srchResults.query}» в {srchResults.path}
