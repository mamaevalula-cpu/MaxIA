{
  "name": "MaxAI Telegram Bot Builder",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "telegram-webhook"
      },
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "position": [
        250,
        300
      ]
    },
    {
      "parameters": {
        "url": "http://your-maxai-server:8090/api/chat",
        "method": "POST",
        "bodyParametersUi": {
          "parameter": [
            {
              "name": "message",
              "value": "={{ $json.body.message.text }}"
            }
          ]
        }
      },
      "name": "MaxAI Chat",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        450,
        300
      ]
    },
    {
      "parameters": {
        "url": "https://api.telegram.org/bot{{ $env.TELEGRAM_BOT_TOKEN }}/sendMessage",
        "method": "POST",
        "bodyParametersUi": {
          "parameter": [
            {
              "name": "chat_id",
              "value": "={{ $json.body.message.chat.id }}"
            },
            {
              "name": "text",
              "value": "={{ $node['MaxAI Chat'].json.response }}"
            }
          ]
        }
      },
      "name": "Send Reply",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        650,
        300
      ]
    }
  ],
  "connections": {
    "Webhook": {
      "main": [
        [
          {
            "node": "MaxAI Chat",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "MaxAI Chat": {
      "main": [
        [
          {
            "node": "Send Reply",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}