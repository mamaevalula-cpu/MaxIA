import json
import logging
import re
import threading
import time
from dataclasses import dataclass, field
from typing import Any, Dict, List, Optional, Tuple

import httpx

from core.config import LLMProvider, cfg
try:
    from core.governance import gov as _llm_gov
except ImportError:
    class _GovStub:
