            {liveOpps.opportunities.map((o,i) => (

              <div key={i} style={{background:'var(--bg)',border:'1px solid var(--border)',borderRadius:6,padding:'8px 10px',textAlign:'center'}}>

                <div style={{fontWeight:600,fontSize:12,marginBottom:4}}>{o.symbol}</div>

                {o.error ? (

                  <div style={{fontSize:10,color:'#ef4444'}}>Error</div>

                ) : (<>

                  <div style={{fontSize:11,color:'var(--text2)'}}>Perp: <span style={{color:'var(--text)'}}>${(o.perp_price||0).toLocaleString()}</span></div>

                  <div style={{fontSize:11,color:'var(--text2)'}}>Spot: <span style={{color:'var(--text)'}}>${(o.spot_price||0).toLocaleString()}</span></div>

                  <div style={{fontSize:13,fontWeight:700,color:o.spread_pct>0?'#22c55e':o.spread_pct<-0.05?'#f59e0b':'#6b7280',marginTop:4}}>

                    {o.spread_pct > 0 ? '+' : ''}{(o.spread_pct||0).toFixed(4)}%

                  </div>

                  <div style={{fontSize:10,color:'var(--text2)',marginTop:2}}>

                    Funding: {((liveOpps.funding||{})[o.symbol]||0).toFixed(4)}%

                  </div>

                  {o.tradeable && <div style={{fontSize:10,color:'#22c55e',fontWeight:600,marginTop:2}}>&#9679; SPREAD OPP</div>}

                </>)}

              </div>

            ))}

          </div>

        </div>

      )}



      {/* Scan Results */}

      {scanResult && (

        <div style={{background:'#1a1a2e', border:'1px solid #333', borderRadius:8, padding:12, marginBottom:16}}>

          <h4 style={{margin:'0 0 8px', fontSize:13}}>\uD83D\uDD0D Last Scan Results — {scanResult.total_found} opportunities</h4>

          <div style={{display:'grid', gridTemplateColumns:'1fr 1fr', gap:8}}>

            <div>

              <div style={{fontSize:11, color:'#888', marginBottom:4}}>Spatial (Cross-Exchange)</div>

              {(scanResult.spatial_opportunities||[]).slice(0,3).map((o, i) => (

                <div key={i} style={{fontSize:10, padding:'3px 0', borderBottom:'1px solid #222'}}>

                  <span style={{color:'#0d6efd'}}>{o.pair}</span>

                  <span style={{color:'#888'}}> {o.buy_exchange}\u2192{o.sell_exchange}</span>

                  <span style={{color: o.net_profit_pct>0?'#28a745':'#dc3545', marginLeft:6}}>

                    {o.net_profit_pct}% | ${o.estimated_pnl}

                  </span>

                </div>

              ))}

              {!(scanResult.spatial_opportunities||[]).length && <div style={{color:'#555', fontSize:11}}>None detected</div>}

            </div>

            <div>

              <div style={{fontSize:11, color:'#888', marginBottom:4}}>Triangular (Intra-Exchange)</div>

              {(scanResult.triangular_opportunities||[]).slice(0,3).map((o, i) => (

                <div key={i} style={{fontSize:10, padding:'3px 0', borderBottom:'1px solid #222'}}>

                  <span style={{color:'#ffc107'}}>{o.pair}</span>

                  <span style={{color: o.net_profit_pct>0?'#28a745':'#dc3545', marginLeft:6}}>

                    {o.net_profit_pct}% | ${o.estimated_pnl}

                  </span>

                </div>

              ))}

              {!(scanResult.triangular_opportunities||[]).length && <div style={{color:'#555', fontSize:11}}>None detected</div>}

            </div>

          </div>

        </div>

      )}



      {/* Execution Log */}

      <div style={{background:'#1a1a2e', border:'1px solid #333', borderRadius:8, padding:12}}>

        <h4 style={{margin:'0 0 8px', fontSize:13}}>\uD83D\uDCC3 Execution Log</h4>

        {execLog.slice(0,10).map((entry, i) => {

          const ts = entry.ts ? new Date(entry.ts*1000).toLocaleTimeString() : '?';

          return (

            <div key={i} style={{fontSize:10, padding:'3px 0', borderBottom:'1px solid #222', color:'#aaa'}}>

              [{ts}]

              <span style={{color:'#0d6efd', marginLeft:4}}>{entry.type||entry.exchange}</span>

              <span style={{marginLeft:4}}>{entry.pair||entry.asset}</span>

              <span style={{color: entry.result?.status==='filled'?'#28a745':'#ffc107', marginLeft:4}}>

                {entry.result?.status || entry.status}

              </span>

              <span style={{color:'#666', marginLeft:4}}>${(entry.usd_value||entry.amount||0).toFixed(2)}</span>

            </div>

          );

        })}

        {!execLog.length && <div style={{color:'#555', fontSize:11}}>No executions yet</div>}

      </div>

    </div>

  );

}



// ============================================================

// FLOATING CHAT WIDGET

// ============================================================

function FloatingChat() {

  const [open, setOpen] = React.useState(false);

  const [msgs, setMsgs] = React.useState([{role:'assistant', text:'👋 Привет! Я ApexMind. Чем могу помочь?'}]);

  const [input, setInput] = React.useState('');

  const [busy, setBusy] = React.useState(false);

  const msgEndRef = React.useRef(null);



  React.useEffect(() => { if(open) msgEndRef.current?.scrollIntoView({behavior:'smooth'}); }, [msgs, open]);



  async function send() {

    if(!input.trim() || busy) return;

    const text = input.trim();

    setInput('');

    setMsgs(m => [...m, {role:'user', text}]);

    setBusy(true);

    try {

      const r = await fetch('/api/chat', {

        method:'POST', headers:{'Content-Type':'application/json'},

        body: JSON.stringify({message: text})

      });

      const d = await r.json();

      setMsgs(m => [...m, {role:'assistant', text: d.response || d.text || 'Ошибка ответа'}]);

    } catch(e) {

      setMsgs(m => [...m, {role:'assistant', text:'❌ Ошибка связи с сервером'}]);

    }

    setBusy(false);

  }



  return (

    <div style={{position:'fixed', bottom:20, right:20, zIndex:9999}}>

      {open && (

        <div style={{width:360, height:480, background:'#161b22', border:'1px solid #30363d', borderRadius:12, display:'flex', flexDirection:'column', marginBottom:8, boxShadow:'0 8px 32px rgba(0,0,0,0.5)'}}>

          <div style={{padding:'12px 16px', background:'#1f6feb', borderRadius:'12px 12px 0 0', display:'flex', justifyContent:'space-between', alignItems:'center'}}>

            <span style={{color:'#fff', fontWeight:700}}>🤖 ApexMind AI</span>

            <span onClick={()=>setOpen(false)} style={{color:'#fff', cursor:'pointer', fontSize:18}}>×</span>

          </div>

          <div style={{flex:1, overflowY:'auto', padding:12, display:'flex', flexDirection:'column', gap:8}}>

            {msgs.map((m,i) => (

              <div key={i} style={{alignSelf: m.role==='user'?'flex-end':'flex-start', maxWidth:'80%', background: m.role==='user'?'#1f6feb':'#21262d', color:'#e6edf3', padding:'8px 12px', borderRadius: m.role==='user'?'12px 12px 2px 12px':'12px 12px 12px 2px', fontSize:13, lineHeight:1.4}}>

                {m.text}

              </div>

            ))}

            {busy && <div style={{alignSelf:'flex-start', color:'#888', fontSize:12}}>⏳ ApexMind думает...</div>}

            <div ref={msgEndRef} />

          </div>

          <div style={{padding:12, borderTop:'1px solid #30363d', display:'flex', gap:8}}>

            <input value={input} onChange={e=>setInput(e.target.value)}

              onKeyDown={e=>e.key==='Enter'&&send()}

              placeholder="Напишите сообщение..."

              style={{flex:1, background:'#0d1117', border:'1px solid #30363d', borderRadius:6, padding:'6px 10px', color:'#e6edf3', fontSize:13, outline:'none'}} />

            <button onClick={send} disabled={busy}

              style={{background:'#1f6feb', color:'#fff', border:'none', borderRadius:6, padding:'6px 12px', cursor:'pointer'}}>➤</button>

          </div>

        </div>

      )}

      <button onClick={()=>setOpen(o=>!o)}

        style={{width:56, height:56, borderRadius:'50%', background:'#1f6feb', color:'#fff', border:'none', cursor:'pointer', fontSize:24, boxShadow:'0 4px 12px rgba(31,111,235,0.4)', display:'flex', alignItems:'center', justifyContent:'center'}}>

        {open ? '×' : '🤖'}

      </button>

    </div>

  );

}



const floatRoot = document.createElement('div');

floatRoot.id = 'float-root';

document.body.appendChild(floatRoot);

ReactDOM.createRoot(floatRoot).render(<ErrorBoundary><FloatingChat /></ErrorBoundary>);





</script>

</body>

</html>

