<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>MaxAI — Центр управления</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#060b16;--bg2:#0b1525;--bg3:#0f1e35;--bg4:#132440;
  --brd:#162040;--brd2:#1e3060;--brd3:#2a4080;
  --txt:#ccdaee;--txt2:#7a9abd;--txt3:#3a5575;
  --acc:#3ab8e8;--acc2:#2090c0;
  --grn:#00d880;--grn2:#00a860;
  --red:#ff3050;--red2:#c02040;
  --yel:#ffb800;--yel2:#c08800;
  --pur:#9050e0;--pur2:#6030b0;
  --ora:#ff7020;
  --r:7px;--r2:5px;--r3:3px;
  --sh:0 2px 12px rgba(0,0,0,.5);
}
body{background:var(--bg);color:var(--txt);font-family:'Segoe UI',system-ui,sans-serif;font-size:13px;min-height:100vh}
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-track{background:var(--bg)}
::-webkit-scrollbar-thumb{background:var(--brd2);border-radius:2px}
::-webkit-scrollbar-thumb:hover{background:var(--brd3)}

/* ═══ HEADER ═══ */
#hdr{
  height:52px;background:linear-gradient(90deg,#030810 0%,#0c1830 50%,#030810 100%);
  border-bottom:1px solid var(--brd2);display:flex;align-items:center;
  padding:0 24px;gap:14px;position:sticky;top:0;z-index:200;
  box-shadow:0 1px 20px rgba(0,0,0,.6)
}
#logo{display:flex;align-items:center;gap:10px;margin-right:4px}
#logo-icon{width:30px;height:30px;background:linear-gradient(135deg,#1a60c0,#3ab8e8);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:16px;box-shadow:0 0 12px #3ab8e840}
#logo-text{font-size:15px;font-weight:700;color:#e8f4ff;letter-spacing:1.5px}
#logo-ver{font-size:9px;color:var(--txt3);letter-spacing:.5px;margin-top:1px}
#hdr-chips{display:flex;gap:6px;flex:1}
.hchip{display:flex;align-items:center;gap:5px;padding:4px 10px;border-radius:20px;font-size:11px;font-weight:600;white-space:nowrap}
.hchip-g{background:#00d88015;border:1px solid #00d88040;color:var(--grn)}
.hchip-r{background:#ff305015;border:1px solid #ff305040;color:var(--red)}
.hchip-y{background:#ffb80015;border:1px solid #ffb80040;color:var(--yel)}
.hchip-b{background:#3ab8e815;border:1px solid #3ab8e840;color:var(--acc)}
.pulse{width:6px;height:6px;border-radius:50%;background:currentColor;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
#hdr-time{color:var(--txt3);font-size:11px;font-family:'Consolas',monospace;margin-left:8px}
#hdr-refresh{background:none;border:1px solid var(--brd2);color:var(--txt3);padding:4px 8px;border-radius:var(--r2);cursor:pointer;font-size:11px;transition:all .15s}
#hdr-refresh:hover{border-color:var(--acc);color:var(--acc)}

/* ═══ TABS ═══ */
#tabs{
  background:#040a14;border-bottom:1px solid var(--brd);
  display:flex;overflow-x:auto;padding:0 8px;
  position:sticky;top:52px;z-index:199;gap:2px;
}
#tabs::-webkit-scrollbar{height:2px}
.tb{
  display:flex;align-items:center;gap:6px;
  padding:10px 16px;cursor:pointer;color:var(--txt3);
  font-size:12px;font-weight:500;border-bottom:2px solid transparent;
  white-space:nowrap;transition:all .15s;user-select:none;border-radius:var(--r2) var(--r2) 0 0
}
.tb:hover{color:var(--txt);background:#080f1e}
.tb.on{color:var(--acc);border-bottom-color:var(--acc);background:#081525}
.tb-ico{font-size:14px;line-height:1}

/* ═══ CONTENT ═══ */
.sc{display:none;padding:20px;animation:fadeIn .2s ease}
.sc.on{display:block}
@keyframes fadeIn{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:none}}

/* ═══ GRIDS ═══ */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px}
.g3{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:14px}
.g4{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:14px}
.g5{display:grid;grid-template-columns:repeat(5,1fr);gap:10px;margin-bottom:14px}
@media(max-width:1100px){.g5{grid-template-columns:repeat(3,1fr)}.g4{grid-template-columns:repeat(2,1fr)}}
@media(max-width:700px){.g2,.g3,.g4,.g5{grid-template-columns:1fr}}

/* ═══ CARD ═══ */
.card{
  background:var(--bg2);border:1px solid var(--brd);border-radius:var(--r);
  padding:16px;box-shadow:var(--sh);transition:border-color .2s
}
.card:hover{border-color:var(--brd2)}
.card-title{
  color:var(--txt3);font-size:10px;text-transform:uppercase;
  letter-spacing:1.5px;margin-bottom:12px;font-weight:700;
  display:flex;align-items:center;gap:6px
}
.card-title-ico{font-size:12px;opacity:.7}

/* ═══ STAT CARD ═══ */
.stat{background:var(--bg2);border:1px solid var(--brd);border-radius:var(--r);padding:16px 18px;box-shadow:var(--sh)}
.stat:hover{border-color:var(--brd2)}
.stat-val{font-size:26px;font-weight:800;color:#ddeeff;line-height:1;margin-bottom:4px;letter-spacing:-.5px}
.stat-lbl{font-size:11px;color:var(--txt2);margin-bottom:2px}
.stat-sub{font-size:10px;color:var(--txt3)}
.stat-grn .stat-val{color:var(--grn)}
.stat-red .stat-val{color:var(--red)}
.stat-yel .stat-val{color:var(--yel)}
.stat-acc .stat-val{color:var(--acc)}

/* ═══ PROGRESS ═══ */
.pb{height:4px;background:var(--brd);border-radius:2px;margin-top:8px;overflow:hidden}
.pb-f{height:100%;border-radius:2px;transition:width .8s ease}
.pb-acc{background:linear-gradient(90deg,var(--acc2),var(--acc))}
.pb-grn{background:linear-gradient(90deg,var(--grn2),var(--grn))}
.pb-red{background:linear-gradient(90deg,var(--red2),var(--red))}
.pb-yel{background:linear-gradient(90deg,var(--yel2),var(--yel))}
.pb-pur{background:linear-gradient(90deg,var(--pur2),var(--pur))}

/* ═══ BADGES ═══ */
.badge{display:inline-flex;align-items:center;padding:2px 8px;border-radius:12px;font-size:10px;font-weight:700;letter-spacing:.3px}
.b-g{background:#00d88018;border:1px solid #00d88050;color:var(--grn)}
.b-r{background:#ff305018;border:1px solid #ff305050;color:var(--red)}
.b-y{background:#ffb80018;border:1px solid #ffb80050;color:var(--yel)}
.b-b{background:#3ab8e818;border:1px solid #3ab8e850;color:var(--acc)}
.b-p{background:#9050e018;border:1px solid #9050e050;color:var(--pur)}
.b-o{background:#ff702018;border:1px solid #ff702050;color:var(--ora)}

/* ═══ STATUS DOT ═══ */
.dot{display:inline-block;width:8px;height:8px;border-radius:50%;flex-shrink:0}
.dot-g{background:var(--grn);box-shadow:0 0 6px var(--grn)}
.dot-r{background:var(--red);box-shadow:0 0 6px var(--red)}
.dot-y{background:var(--yel);box-shadow:0 0 6px var(--yel)}
.dot-b{background:var(--acc);box-shadow:0 0 6px var(--acc)}

/* ═══ TABLE ═══ */
.tbl-wrap{overflow-x:auto;border-radius:var(--r2);border:1px solid var(--brd)}
table{width:100%;border-collapse:collapse}
thead{background:#0a1525}
th{color:var(--txt3);font-size:10px;text-transform:uppercase;letter-spacing:1px;padding:8px 12px;text-align:left;border-bottom:1px solid var(--brd);white-space:nowrap;font-weight:700}
td{padding:8px 12px;border-bottom:1px solid #080e18;font-size:12px;vertical-align:middle}
tr:last-child td{border-bottom:none}
tr:hover td{background:#0a1525}
tbody tr{transition:background .1s}

/* ═══ ROW ═══ */
.row{display:flex;align-items:center;justify-content:space-between;padding:7px 0;border-bottom:1px solid #0a1020}
.row:last-child{border:none}
.row-left{display:flex;align-items:center;gap:8px;color:var(--txt2)}
.row-right{font-weight:600;color:var(--txt)}

/* ═══ BUTTONS ═══ */
.btn{
  display:inline-flex;align-items:center;gap:6px;
  background:var(--bg3);border:1px solid var(--brd2);color:var(--acc);
  padding:7px 16px;border-radius:var(--r2);cursor:pointer;font-size:12px;
  font-weight:600;transition:all .15s;white-space:nowrap;letter-spacing:.3px
}
.btn:hover{background:var(--bg4);border-color:var(--acc);box-shadow:0 0 10px #3ab8e820}
.btn:active{transform:scale(.97)}
.btn:disabled{opacity:.4;cursor:not-allowed;pointer-events:none}
.btn-g{background:#00d88010;border-color:#00d88050;color:var(--grn)}
.btn-g:hover{background:#00d88020;border-color:var(--grn);box-shadow:0 0 10px #00d88020}
.btn-r{background:#ff305010;border-color:#ff305050;color:var(--red)}
.btn-r:hover{background:#ff305020;border-color:var(--red);box-shadow:0 0 10px #ff305020}
.btn-y{background:#ffb80010;border-color:#ffb80050;color:var(--yel)}
.btn-y:hover{background:#ffb80020;border-color:var(--yel)}
.btn-sm{padding:4px 10px;font-size:11px}

/* ═══ INPUT / TEXTAREA ═══ */
.inp{background:#030810;border:1px solid var(--brd2);color:var(--txt);padding:8px 12px;border-radius:var(--r2);font-size:12px;width:100%;outline:none;transition:border-color .15s}
.inp:focus{border-color:var(--acc);box-shadow:0 0 0 2px #3ab8e815}
.inp::placeholder{color:var(--txt3)}
textarea.inp{resize:vertical;font-family:'Consolas',monospace;line-height:1.6}
select.inp{cursor:pointer}

/* ═══ LOG BOX ═══ */
.logbox{
  background:#020709;border:1px solid var(--brd);border-radius:var(--r2);
  padding:12px;font-family:'Consolas',monospace;font-size:11px;color:#1a9090;
  line-height:1.8;overflow-y:auto;white-space:pre-wrap;word-break:break-word
}

/* ═══ SECTION TITLE ═══ */
.sec-title{
  font-size:11px;color:var(--txt3);text-transform:uppercase;letter-spacing:2px;
  font-weight:700;margin:18px 0 10px;padding-bottom:6px;
  border-bottom:1px solid var(--brd);display:flex;align-items:center;gap:8px
}
.sec-title span{flex:1}

/* ═══ ALERT BOX ═══ */
.alert{padding:10px 14px;border-radius:var(--r2);font-size:12px;margin-bottom:10px;display:flex;align-items:center;gap:8px}
.alert-r{background:#ff305010;border:1px solid #ff305040;color:var(--red)}
.alert-g{background:#00d88010;border:1px solid #00d88040;color:var(--grn)}
.alert-y{background:#ffb80010;border:1px solid #ffb80040;color:var(--yel)}
.alert-b{background:#3ab8e810;border:1px solid #3ab8e840;color:var(--acc)}

/* ═══ CHAT ═══ */
#chat-box{height:380px;overflow-y:auto;padding:12px;display:flex;flex-direction:column;gap:10px;background:#020709;border:1px solid var(--brd);border-radius:var(--r2) var(--r2) 0 0}
.msg-user{align-self:flex-end;background:linear-gradient(135deg,#1a3560,#1a4080);border:1px solid var(--brd2);padding:10px 14px;border-radius:14px 14px 3px 14px;max-width:72%;font-size:12px;color:#ddeeff}
.msg-ai{align-self:flex-start;background:var(--bg2);border:1px solid var(--brd);padding:10px 14px;border-radius:14px 14px 14px 3px;max-width:82%;font-size:12px}
.msg-ai pre{white-space:pre-wrap;word-break:break-word;margin:0;color:var(--txt);line-height:1.6}
.msg-time{font-size:10px;color:var(--txt3);margin-top:3px;text-align:right}
#chat-send-row{display:flex;gap:8px;background:#040c18;border:1px solid var(--brd);border-top:none;padding:10px;border-radius:0 0 var(--r2) var(--r2)}

/* ═══ PLATFORM CARD ═══ */
.plat-card{background:var(--bg2);border:1px solid var(--brd);border-radius:var(--r);padding:14px;transition:all .2s}
.plat-card:hover{border-color:var(--brd3);transform:translateY(-1px);box-shadow:0 4px 20px rgba(0,0,0,.4)}
.plat-name{font-size:12px;font-weight:700;color:#ddeeff;margin-bottom:4px}
.plat-cat{font-size:10px;color:var(--txt3);margin-bottom:8px}

/* ═══ SKILL CARD ═══ */
.skill-item{display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid #090f1c}
.skill-item:last-child{border:none}
.skill-rank{font-size:11px;color:var(--txt3);width:20px;text-align:center}
.skill-name{flex:1;font-size:11px;color:var(--txt2)}
.skill-ev{font-weight:700;font-size:13px}

/* ═══ LOADER ═══ */
.loader{display:inline-block;width:16px;height:16px;border:2px solid var(--brd2);border-top-color:var(--acc);border-radius:50%;animation:spin .7s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.loading-wrap{display:flex;align-items:center;justify-content:center;padding:40px;gap:10px;color:var(--txt3)}

/* ═══ INCIDENT BUTTONS ═══ */
.incident-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:14px}
@media(max-width:800px){.incident-grid{grid-template-columns:repeat(2,1fr)}}
.inc-btn{
  display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;
  padding:14px;border-radius:var(--r);cursor:pointer;font-size:11px;font-weight:700;
  border:1px solid;transition:all .2s;text-align:center;letter-spacing:.3px
}
.inc-btn .inc-ico{font-size:22px}
.inc-btn:hover{transform:translateY(-2px);box-shadow:0 6px 20px rgba(0,0,0,.4)}
.inc-btn:active{transform:scale(.96)}
.inc-kill{background:#ff305010;border-color:#ff305040;color:var(--red)}
.inc-kill:hover{background:#ff305025;border-color:var(--red)}
.inc-block{background:#ffb80010;border-color:#ffb80040;color:var(--yel)}
.inc-block:hover{background:#ffb80025;border-color:var(--yel)}
.inc-roll{background:#3ab8e810;border-color:#3ab8e840;color:var(--acc)}
.inc-roll:hover{background:#3ab8e825;border-color:var(--acc)}
.inc-back{background:#9050e010;border-color:#9050e040;color:var(--pur)}
.inc-back:hover{background:#9050e025;border-color:var(--pur)}

/* ═══ FEEDBACK ═══ */
.fb{font-size:11px;padding:4px 10px;border-radius:var(--r2);margin-left:8px;opacity:0;transition:opacity .3s}
.fb.show{opacity:1}
.fb-ok{background:#00d88015;color:var(--grn);border:1px solid #00d88040}
.fb-err{background:#ff305015;color:var(--red);border:1px solid #ff305040}

/* ═══ PHASE BARS ═══ */
.phase-item{margin-bottom:14px}
.phase-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:5px}
.phase-name{font-size:12px;color:var(--txt2);font-weight:600}
.phase-target{font-size:11px;color:var(--acc);font-weight:700}
.phase-pct{font-size:10px;color:var(--txt3);margin-top:3px}

/* ═══ GRADE BADGE ═══ */
.grade-a{font-size:15px;font-weight:800;color:var(--grn)}
.grade-b{font-size:15px;font-weight:800;color:var(--acc)}
.grade-c{font-size:15px;font-weight:800;color:var(--yel)}
.grade-d,.grade-f{font-size:15px;font-weight:800;color:var(--red)}
</style>
</head>
<body>

<!-- ═══════════════════ HEADER ═══════════════════ -->
<div id="hdr">
  <div id="logo">
    <div id="logo-icon">⚡</div>
    <div>
      <div id="logo-text">MaxAI</div>
      <div id="logo-ver">Корпорация MaxAI</div>
    </div>
  </div>
  <div id="hdr-chips">
    <div class="hchip hchip-y" id="chip-svc"><span class="pulse"></span><span>ЗАГРУЗКА</span></div>
    <div class="hchip hchip-b" id="chip-agents">— агентов</div>
    <div class="hchip hchip-g" id="chip-tasks">— задач</div>
    <div class="hchip hchip-b" id="chip-cost">$0.0000</div>
    <div class="hchip hchip-g" id="chip-balance">$—</div>
    <div class="hchip hchip-b" id="chip-pnl">PnL $0</div>
  </div>
  <span id="hdr-time">--:--:--</span>
  <button id="hdr-refresh" onclick="refreshAll()">↻ Обновить</button>
</div>

<!-- ═══════════════════ TABS ═══════════════════ -->
<div id="tabs">
  <div class="tb on"  onclick="go('dash')"><span class="tb-ico">🏠</span>Главная</div>
  <div class="tb" onclick="go('revenue')"><span class="tb-ico">💰</span>Доходы</div>
  <div class="tb" onclick="go('agents')"><span class="tb-ico">🤖</span>Агенты</div>
  <div class="tb" onclick="go('tasks')"><span class="tb-ico">📋</span>Задачи</div>
  <div class="tb" onclick="go('quality')"><span class="tb-ico">⭐</span>Качество</div>
  <div class="tb" onclick="go('failures')"><span class="tb-ico">🔥</span>Инциденты</div>
  <div class="tb" onclick="go('evolution')"><span class="tb-ico">🧬</span>Эволюция</div>
  <div class="tb" onclick="go('platforms')"><span class="tb-ico">🌐</span>Платформы</div>
  <div class="tb" onclick="go('skills')"><span class="tb-ico">🧠</span>Навыки</div>
  <div class="tb" onclick="go('scout')"><span class="tb-ico">🔭</span>Скаут</div>
  <div class="tb" onclick="go('llm')"><span class="tb-ico">💡</span>Модели ИИ</div>
  <div class="tb" onclick="go('chat')"><span class="tb-ico">💬</span>Чат</div>
  <div class="tb" onclick="go('logs')"><span class="tb-ico">📜</span>Логи</div>
  <div class="tb" onclick="go('browser')"><span class="tb-ico">🖥</span>Браузер</div>
</div>

<!-- ═══════════════════ ГЛАВНАЯ ═══════════════════ -->
<div id="sc-dash" class="sc on">
  <div class="g5" id="dash-kpis">
    <div class="stat"><div class="loader" style="margin:8px auto 6px"></div><div class="stat-lbl">Загрузка...</div></div>
  </div>
  <div class="g2">
    <div class="card">
      <div class="card-title"><span class="card-title-ico">🟢</span>Состояние подсистем</div>
      <div id="dash-health"><div class="loading-wrap"><div class="loader"></div></div></div>
    </div>
    <div class="card">
      <div class="card-title"><span class="card-title-ico">📊</span>Параметры системы</div>
      <div id="dash-params"></div>
    </div>
  </div>
  <div class="g2">
    <div class="card">
      <div class="card-title"><span class="card-title-ico">⚡</span>KPI Корпорации MaxAI</div>
      <div id="dash-hkpi"></div>
    </div>
    <div class="card">
      <div class="card-title"><span class="card-title-ico">🚨</span>Сигналы и тревоги</div>
      <div id="dash-alerts"></div>
    </div>
  </div>
  <div class="g2">
    <div class="card">
      <div class="card-title"><span class="card-title-ico">📈</span>Bybit — Открытые позиции</div>
      <div id="dash-positions"><div class="loading-wrap"><div class="loader"></div></div></div>
    </div>
    <div class="card">
      <div class="card-title"><span class="card-title-ico">🔮</span>Торговые сигналы (15m)</div>
      <div id="dash-signals"><div class="loading-wrap"><div class="loader"></div></div></div>
    </div>
  </div>
</div>

<!-- ═══════════════════ ДОХОДЫ ═══════════════════ -->
<div id="sc-revenue" class="sc">
  <div class="g4" id="rev-kpis"></div>
  <div class="g2">
    <div class="card">
      <div class="card-title"><span class="card-title-ico">💸</span>Потоки доходов</div>
      <div class="tbl-wrap">
        <table>
          <thead><tr><th>Поток</th><th>Агент</th><th>Доход $</th><th>Статус</th></tr></thead>
          <tbody id="rev-tbl"><tr><td colspan="4" style="text-align:center;padding:20px"><div class="loader" style="margin:0 auto"></div></td></tr></tbody>
        </table>
      </div>
    </div>
    <div class="card">
      <div class="card-title"><span class="card-title-ico">🌍</span>Фазы глобального роста</div>
      <div id="rev-phases"></div>
    </div>
  </div>
</div>

<!-- ═══════════════════ АГЕНТЫ ═══════════════════ -->
<div id="sc-agents" class="sc">
  <div class="g4" id="ag-kpis"></div>
  <div class="g2">
    <div class="card">
      <div class="card-title"><span class="card-title-ico">🏅</span>По уровню</div>
      <div id="ag-rank"></div>
    </div>
    <div class="card">
      <div class="card-title"><span class="card-title-ico">🏢</span>По отделу</div>
      <div id="ag-dept"></div>
    </div>
  </div>
  <div class="card">
    <div class="card-title"><span class="card-title-ico">🤖</span>Весь флот агентов</div>
    <div class="tbl-wrap">
      <table>
        <thead><tr><th>Агент</th><th>Отдел</th><th>Уровень</th><th>Качество</th><th>Статус</th><th>Описание</th></tr></thead>
        <tbody id="ag-tbl"><tr><td colspan="6" style="text-align:center;padding:20px"><div class="loader" style="margin:0 auto"></div></td></tr></tbody>
      </table>
    </div>
  </div>
</div>

