function FilesTab() {
  const ROOT = '/root/my_personal_ai';
  const [path, setPath] = useState(ROOT);
  const [items, setItems] = useState([]);
  const [loading, setLoading] = useState(false);
  const [modal, setModal] = useState(null); // { name, content }
  const [error, setError] = useState('');

  const loadDir = async (p) => {
    setLoading(true);
    setError('');
    const r = await apiFetch(`/api/files?path=${encodeURIComponent(p)}`);
    if (r.ok) {
      setItems(Array.isArray(r.data) ? r.data : (r.data?.items || r.data?.files || []));
    } else {
      setError('Ошибка загрузки директории');
      setItems([]);
    }
    setLoading(false);
  };

  useEffect(() => { loadDir(path); }, [path]);

  const navigate = (item) => {
    if (item.type === 'directory' || item.is_dir) {
      setPath(path + '/' + item.name);
    } else {
      openFile(item);
    }
  };

  const openFile = async (item) => {
    const filePath = path + '/' + item.name;
    const r = await apiFetch(`/api/files/read?path=${encodeURIComponent(filePath)}`);
    if (r.ok) {
      setModal({ name: item.name, content: r.data?.content || r.data?.text || JSON.stringify(r.data, null, 2) });
    } else {
      setModal({ name: item.name, content: 'Ошибка чтения файла' });
    }
  };

  const breadcrumbs = () => {
    const parts = path.replace(/\/+$/, '').split('/').filter(Boolean);
    const crumbs = [];
    let cumPath = '';
    parts.forEach((part, i) => {
      cumPath += '/' + part;
      crumbs.push({ label: part || '/', fullPath: cumPath });
    });
    return crumbs;
  };

  const goUp = () => {
    const parts = path.replace(/\/+$/, '').split('/');
    if (parts.length > 2) {
      parts.pop();
      setPath(parts.join('/'));
    }
  };

  return (
    <div>
      <div className="tab-title">🗂 Файлы</div>

      <div className="breadcrumb">
        {breadcrumbs().map((b, i) => (
          <React.Fragment key={i}>
            {i > 0 && <span className="bread-sep">/</span>}
            <span className="bread-item" onClick={() => setPath(b.fullPath)}>{b.label}</span>
          </React.Fragment>
        ))}
      </div>

      <div className="card" style={{padding:0,overflow:'hidden'}}>
        {path !== ROOT && path !== '/' && (
          <div className="file-item" onClick={goUp} style={{borderBottom:'1px solid var(--border)'}}>
            <span style={{fontSize:20}}>📁</span>
            <span className="file-name" style={{color:'var(--accent)'}}>.. (вверх)</span>
          </div>
        )}
        {loading ? (
          <div className="empty-state"><span className="spinner"></span></div>
        ) : error ? (
          <div className="error-state">{error}</div>
        ) : items.length === 0 ? (
          <div className="empty-state">Папка пуста</div>
        ) : items.map((item, i) => {
          const isDir = item.type === 'directory' || item.is_dir || item.isDirectory;
          return (
            <div key={i} className="file-item" onClick={() => navigate(item)} style={{borderBottom:'1px solid var(--border)'}}>
              <span style={{fontSize:20}}>{isDir ? '📁' : '📄'}</span>
              <span className="file-name">{item.name}</span>
              {item.size !== undefined && <span className="file-size">{item.size < 1024 ? `${item.size}B` : item.size < 1048576 ? `${(item.size/1024).toFixed(1)}KB` : `${(item.size/1048576).toFixed(1)}MB`}</span>}
              {item.modified && <span style={{fontSize:11,color:'var(--text2)'}}>{item.modified}</span>}
            </div>
          );
        })}
      </div>

      {modal && (
        <div className="modal-overlay" onClick={() => setModal(null)}>
          <div className="modal" onClick={e => e.stopPropagation()}>
            <div className="modal-header">
              <span className="modal-title">📄 {modal.name}</span>
              <button className="modal-close" onClick={() => setModal(null)}>×</button>
            </div>
            <div className="modal-body">
              <div className="code-block">{modal.content}</div>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}

