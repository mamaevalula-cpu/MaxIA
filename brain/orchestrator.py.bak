# -*- coding: utf-8 -*-
"""
brain/orchestrator.py — Главный ИИ-оркестратор с мульти-агентными дебатами.

Алгоритм обработки каждого запроса:
  1. Classify   — определить намерение (trading / code / analysis / chat / ...)
  2. RAG        — загрузить релевантный контекст из памяти
  3. Route      — выбрать путь: агент (Coder/Trading/...) или DEBATE
  4. DEBATE     — декомпозиция → параллельные специалисты → дебаты → синтез
  5. Apply      — если в ответе есть код → применить через CoderAgent
  6. Learn      — сохранить удачные паттерны в MemoryStore
  7. Notify     — вернуть ответ в GUI/Telegram

Принципы:
  • DeepSeek R1 (reasoner) — основной провайдер для всех задач
  • Если качество ответа < 0.4 → повтор с Claude
  • Агенты обучаются: сохраняют успешные паттерны после каждого взаимодействия
  • Все шаги видны пользователю в реальном времени через progress_callback
"""

from __future__ import annotations

import concurrent.futures
import json
import logging
import re
import threading
import time
from dataclasses import dataclass, field
from typing import Any, Callable, Dict, List, Optional, Tuple

from brain.llm_router import LLMProvider, LLMRequest, LLMResponse, LLMRouter
from core.config import cfg
from core.event_bus import EventBus
from core.system_prompt import build_system_prompt
from memory.memory_store import KnowledgeEntry, MemoryStore
from memory.rag_engine import RAGEngine

log = logging.getLogger("brain.orchestrator")


@dataclass
class OrchestratorRequest:
    text: str
    source: str = "gui"
    session_id: str = ""
    user_id: str = ""
    require_verification: bool = False
    metadata: Dict = field(default_factory=dict)
    progress_callback: Optional[Callable[[str], None]] = None


@dataclass
class OrchestratorResponse:
    text: str
    intent: str = "chat"
    agent_used: str = ""
    verified: bool = False
    sources: List[str] = field(default_factory=list)
    task_id: Optional[int] = None


