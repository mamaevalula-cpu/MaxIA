    loadExecLog();

    const iv = setInterval(() => { loadStatus(); loadExecLog(); }, 15000);

    return () => clearInterval(iv);

  }, []);



  function loadStatus() {

    apiFetch('/api/arbitrage/status').then(r => { if (r.ok) setStatus(r.data); });

    apiFetch('/api/arbitrage/live').then(r => { if (r.ok) setLiveOpps(r.data); });

  }

