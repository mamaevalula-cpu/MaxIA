              <tr style={{borderTop:'1px solid var(--border)'}}><td style={{padding:'6px 0',fontWeight:600}}>Итого расходы/день</td><td style={{textAlign:'right',fontWeight:700,color:'#ef4444'}}>${((costs.server_usd_month/30)+(costs.api_today_usd||0)).toFixed(2)}</td></tr>
