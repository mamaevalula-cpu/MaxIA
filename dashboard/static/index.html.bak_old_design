function TasksTab() {

  const [tasks, setTasks] = useState([]);

  const [stats, setStats] = useState({ pending: 0, running: 0, completed: 0, failed: 0 });

  const [cancelling, setCancelling] = useState({});



  const load = useCallback(async () => {

    const r = await apiFetch('/api/tasks');

    if (r.ok) {

      const d = r.data;

      const list = Array.isArray(d) ? d : (d?.tasks || []);

      setTasks(list);

      if (d?.stats) {

        setStats(d.stats);

      } else {

        setStats({

          pending: list.filter(t => t.status === 'pending').length,

          running: list.filter(t => t.status === 'running').length,

          completed: list.filter(t => t.status === 'completed' || t.status === 'done').length,

          failed: list.filter(t => t.status === 'failed' || t.status === 'error').length,

        });

      }

    }

  }, []);



  usePolling(load, 10000, []);



  const cancel = async (id) => {

    setCancelling(prev => ({ ...prev, [id]: true }));

    await apiFetch(`/api/tasks/${id}/cancel`, { method: 'POST' });

    setCancelling(prev => ({ ...prev, [id]: false }));

    load();

  };



  const statusBadge = s => {

    if (s === 'pending') return 'badge-warn';

    if (s === 'running') return 'badge-blue';

    if (s === 'completed' || s === 'done') return 'badge-green';

    if (s === 'failed' || s === 'error') return 'badge-danger';

    return 'badge-gray';

  };

  const statusLabel = s => {

    if (s === 'pending') return 'Ожидание';

    if (s === 'running') return 'Выполняется';

    if (s === 'completed' || s === 'done') return 'Завершена';

    if (s === 'failed') return 'Ошибка';

    return s || '—';

  };



  return (

    <div>

      <div className="tab-title">📋 Задачи</div>

      <div style={{display:'flex',gap:12,marginBottom:20,flexWrap:'wrap'}}>

        {[

          { label: 'Ожидание', value: stats.pending, cls: 'badge-warn' },

          { label: 'Выполняется', value: stats.running, cls: 'badge-blue' },

          { label: 'Завершено', value: stats.completed, cls: 'badge-green' },

          { label: 'Ошибок', value: stats.failed, cls: 'badge-danger' },

        ].map((s, i) => (

          <div key={i} className="card" style={{flex:'1',minWidth:120,textAlign:'center',padding:12}}>

            <div className="card-title" style={{marginBottom:6}}>{s.label}</div>

            <span className={`badge ${s.cls}`} style={{fontSize:20,padding:'4px 12px'}}>{s.value}</span>

          </div>

        ))}

      </div>



      <div className="table-wrap">

        <table className="table">

          <thead>

            <tr><th>ID</th><th>Агент</th><th>Описание</th><th>Статус</th><th>Создана</th><th>Действие</th></tr>

          </thead>

          <tbody>

            {tasks.length === 0 ? (

              <tr><td colSpan={6} className="empty-state" style={{padding:20}}>Нет активных задач</td></tr>

            ) : tasks.map((t, i) => (

              <tr key={i}>

                <td style={{fontFamily:'monospace',fontSize:11,color:'var(--text2)'}}>{String(t.id || i).slice(0,12)}</td>

                <td>{t.agent || t.agent_name || '—'}</td>

                <td style={{maxWidth:200,overflow:'hidden',textOverflow:'ellipsis',whiteSpace:'nowrap'}}>{t.description || t.name || t.task || '—'}</td>

                <td><span className={`badge ${statusBadge(t.status)}`}>{statusLabel(t.status)}</span></td>

                <td style={{fontSize:11,color:'var(--text2)'}}>{t.created_at || t.created || '—'}</td>

                <td>

                  {(t.status === 'pending' || t.status === 'running') && (

                    <button

                      className="btn btn-danger btn-sm"

                      onClick={() => cancel(t.id)}

                      disabled={cancelling[t.id]}

                    >

                      {cancelling[t.id] ? <span className="spinner" style={{width:12,height:12}}></span> : 'Отмена'}

                    </button>

                  )}

                </td>

              </tr>

            ))}

          </tbody>

        </table>

      </div>

    </div>

  );

}



