                                        if _re.get('nonce') == nonce:
                                            _already = True
                                            break
                                    except Exception:
                                        pass
                        if _already:
                            _seen_approval_nonces.add(nonce)
                            continue
                        _seen_approval_nonces.add(nonce)
                        _sym   = _req.get('symbol', '?')
                        _side  = _req.get('side', '?')
                        _qty   = _req.get('qty', 0)
