        @_check_access(AccessLevel.ADMIN)
        async def _backup_cmd(update: Update, context) -> None:
            """
            /backup           — создать резервную копию прямо сейчас
            /backup list      — показать последние 5 бэкапов
            /backup restore   — инструкция по восстановлению
            """
            args = context.args or []
            sub = args[0].lower() if args else "create"

            if sub == "list":
                try:
                    from pathlib import Path as _P
                    backup_dir = _P(__file__).parent.parent / "backups"
                    archives = sorted(
                        backup_dir.glob("personal_ai_backup_*.tar.gz"),
                        key=lambda p: p.stat().st_mtime, reverse=True
                    ) if backup_dir.exists() else []
                    if not archives:
                        await _reply(update, "📦 Бэкапов нет. Запусти /backup для создания.")
                        return
                    lines = [f"📦 <b>Последние бэкапы ({len(archives)}):</b>\n"]
                    import datetime as _dt
                    for a in archives[:5]:
                        size_mb = a.stat().st_size / 1_048_576
                        ts = _dt.datetime.fromtimestamp(a.stat().st_mtime).strftime("%d.%m.%Y %H:%M")
                        lines.append(f"  • <code>{a.name}</code>\n    📅 {ts} | 📦 {size_mb:.1f} MB")
                    await _reply(update, "\n".join(lines))
                except Exception as e:
                    await _reply(update, f"❌ Ошибка: {e}")
                return

            if sub == "restore":
                await _reply(update,
                    "📖 <b>Восстановление из бэкапа</b>\n\n"
                    "1. Найди нужный архив в папке <code>backups/</code>\n"
                    "2. Запусти:\n"
                    "<pre>python scripts/restore.py backups/personal_ai_backup_YYYYMMDD_HHMMSS.tar.gz</pre>\n"
                    "3. Перезапусти бота:\n"
                    "<pre>python main.py --no-gui</pre>\n\n"
                    "⚠️ Restore перезапишет данные! Сделай бэкап текущего состояния перед восстановлением."
                )
                return

            # create (по умолчанию)
            await _reply(update, "⏳ Создаю резервную копию...")
            await _typing(update, context)
            import asyncio as _aio
            import concurrent.futures as _cf

            def _do_backup():
                from scripts.backup import create_backup
                return create_backup()

            try:
                loop = _aio.get_running_loop()
                with _cf.ThreadPoolExecutor(max_workers=1) as pool:
                    archive = await loop.run_in_executor(pool, _do_backup)
                size_mb = archive.stat().st_size / 1_048_576
                await _reply(update,
                    f"✅ <b>Бэкап создан!</b>\n\n"
                    f"📦 Файл: <code>{archive.name}</code>\n"
                    f"📏 Размер: <b>{size_mb:.1f} MB</b>\n"
                    f"📁 Папка: <code>backups/</code>\n\n"
                    f"Используй /backup list для просмотра всех бэкапов."
                )
            except Exception as e:
                await _reply(update, f"❌ Ошибка создания бэкапа: {e}")

