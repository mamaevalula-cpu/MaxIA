# ДОСТУПНЫЕ ИНСТРУМЕНТЫ И БИБЛИОТЕКИ
# ══════════════════════════════════════════════════════════════════
# AI имеет доступ к следующим инструментам и библиотекам.
# Всегда используй их когда задача требует анализа данных, торговли,
# или работы с сервером.
#
# ── 1. ТЕХНИЧЕСКИЙ АНАЛИЗ РЫНКА ──────────────────────────────────
# Инструмент: market_analysis (tool_registry)
# Использование через tool_registry:
#   tool = ToolRegistry.get().find_by_name("market_analysis")
#   result = tool.run_fn("BTCUSDT анализ")
#
# Прямой Python API (если нужны raw данные):
#   from tools.analysis import analyze_market, calc_indicators, MarketAnalyzer
#   from tools.data_tools import df_from_candles, detect_pattern, calc_position_size
#
#   # Полный анализ:
#   result = analyze_market(candles, "BTCUSDT")
#   # result["signal"]     → "BUY" | "SELL" | "HOLD"
#   # result["regime"]     → "trending_up" | "ranging" | ...
#   # result["indicators"] → dict с RSI, MACD, BB, ATR, EMA...
#   # result["summary"]    → строка для ответа пользователю
#
#   # Только индикаторы (DataFrame):
#   df = calc_indicators(candles)
#   df[["rsi","macd","bb_upper","bb_lower","atr"]].tail(5)
#
#   # Определить паттерн:
#   patterns = detect_pattern(df)  # ["hammer", "doji", ...]
#
#   # Размер позиции:
#   size = calc_position_size(balance=1000, risk_pct=0.01, entry=94000, stop_loss=92000)
#   # size["qty"] → количество контрактов
#
# ── 2. PANDAS / NUMPY (данные) ────────────────────────────────────
# Всегда доступны для анализа данных:
#   import pandas as pd
#   import numpy as np
#
#   df = pd.DataFrame(data)
#   df.describe()             # статистика
#   df.corr()                 # корреляция
#   df.resample("1h").agg(...)# ресэмплинг OHLCV
#
# ── 3. МОНИТОРИНГ СЕРВЕРА ─────────────────────────────────────────
#   from tools.server_monitor import ServerMonitor
#   stats = ServerMonitor.get().get_stats()
#   # CPU: 1.5%, RAM: 166MB/23GB, Disk: 18GB/484GB
#
# ── 4. ТОРГОВЫЙ БОТ (Bybit V5 API) ──────────────────────────────
#   sys.path.insert(0, "/root/bybit-bot")
#   from core.exchange import BybitExchange
#   ex = BybitExchange(api_key, api_secret, testnet=True)
#
#   candles   = ex.get_klines("BTCUSDT", "15", 200)  # OHLCV
