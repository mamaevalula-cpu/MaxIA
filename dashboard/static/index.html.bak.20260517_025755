              <tr><td style={{color:'var(--text-secondary)',padding:'4px 0'}}>Прогноз на месяц</td><td style={{textAlign:'right',fontWeight:600,color:'#22c55e'}}>+${(revenue.forecasted_month||0).toFixed(0)}</td></tr>
              <tr><td style={{color:'var(--text-secondary)',padding:'4px 0'}}>SFE: Compute wallet</td><td style={{textAlign:'right',fontWeight:600}}>${(revenue.sfe_compute_wallet||0).toFixed(2)}</td></tr>
              <tr><td style={{color:'var(--text-secondary)',padding:'4px 0'}}>SFE: Yield vault</td><td style={{textAlign:'right',fontWeight:600}}>${(revenue.sfe_yield_vault||0).toFixed(2)}</td></tr>
