    const iv = setInterval(load, 60000);
    return () => clearInterval(iv);
  }, []);

  if (loading) return <div className="tab-content"><div className="empty-state">⏳ Загружаю матрицу навыков...</div></div>;
  if (!data) return <div className="tab-content"><div className="empty-state">❌ Нет данных</div></div>;

  const categories = ['all', ...new Set((data.skills||[]).map(s => s.category))];
  const filtered = filter === 'all' ? data.skills : data.skills.filter(s => s.category === filter);

  const barColor = m => m >= 70 ? '#22c55e' : m >= 50 ? '#f59e0b' : '#ef4444';

  return (
    <div className="tab-content">
      <h2 className="section-title">🎓 AI Competency Matrix</h2>

      {/* Summary */}
      <div className="grid" style={{gridTemplateColumns:'repeat(4,1fr)',gap:12,marginBottom:20}}>
        <div className="card" style={{textAlign:'center'}}>
          <div style={{fontSize:32,fontWeight:800,color:'#3b82f6'}}>{data.overall_mastery}%</div>
          <div style={{color:'var(--text-secondary)',fontSize:12}}>Общий уровень</div>
        </div>
        <div className="card" style={{textAlign:'center'}}>
          <div style={{fontSize:32,fontWeight:800}}>{data.total_skills}</div>
          <div style={{color:'var(--text-secondary)',fontSize:12}}>Всего навыков</div>
        </div>
        <div className="card" style={{textAlign:'center'}}>
          <div style={{fontSize:32,fontWeight:800,color:'#22c55e'}}>{data.skills_above_70}</div>
          <div style={{color:'var(--text-secondary)',fontSize:12}}>Освоено (≥70%)</div>
        </div>
        <div className="card" style={{textAlign:'center'}}>
          <div style={{fontSize:32,fontWeight:800,color:'#f59e0b'}}>{data.in_training}</div>
          <div style={{color:'var(--text-secondary)',fontSize:12}}>В обучении</div>
        </div>
      </div>

      {/* Filter */}
      <div style={{display:'flex',gap:8,marginBottom:16,flexWrap:'wrap'}}>
        {categories.map(c => (
          <button key={c} onClick={() => setFilter(c)} style={{
            padding:'4px 14px',borderRadius:20,border:'1px solid var(--border)',
            background: filter===c ? 'var(--accent)' : 'transparent',
            color: filter===c ? '#fff' : 'var(--text-secondary)',
            cursor:'pointer',fontSize:12,fontWeight:500
          }}>{c === 'all' ? '🔍 Все' : c}</button>
        ))}
      </div>

      {/* Skills grid */}
      <div className="grid" style={{gridTemplateColumns:'repeat(auto-fill,minmax(320px,1fr))',gap:16}}>
        {(filtered||[]).map(skill => (
          <div key={skill.id} className="card" style={{position:'relative'}}>
            <div style={{display:'flex',justifyContent:'space-between',alignItems:'flex-start',marginBottom:8}}>
              <div style={{fontWeight:700,fontSize:14}}>{skill.name}</div>
              <span style={{fontSize:11,padding:'2px 8px',borderRadius:10,background:'rgba(59,130,246,0.15)',color:'#60a5fa',whiteSpace:'nowrap'}}>{skill.category}</span>
            </div>

            {/* Progress bar */}
            <div style={{marginBottom:10}}>
              <div style={{display:'flex',justifyContent:'space-between',fontSize:11,color:'var(--text-secondary)',marginBottom:4}}>
                <span>Уровень мастерства</span>
                <span style={{fontWeight:700,color:barColor(skill.mastery)}}>{skill.mastery}%</span>
              </div>
              <div style={{height:6,background:'var(--border)',borderRadius:3,overflow:'hidden'}}>
                <div style={{
                  height:'100%',width:skill.mastery+'%',
                  background:barColor(skill.mastery),
                  borderRadius:3,transition:'width 0.5s'
                }}></div>
