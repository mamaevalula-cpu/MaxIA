def build_system_prompt(task_type: str = "chat", extra: str = "") -> str:
    """Build complete system prompt for a task type."""
    addon = TASK_PROMPTS.get(task_type, TASK_PROMPTS["chat"])
    if extra:
        addon += f"\n\nAdditional context:\n{extra}"
    return BASE_SYSTEM_PROMPT + "\n\n" + addon
