    <div class="card-title"><span class="card-title-ico">📋</span>Список задач</div>
    <div class="tbl-wrap">
      <table>
        <thead><tr><th>ID</th><th>Агент</th><th>Описание</th><th>Статус</th><th>Источник</th><th>Обновлено</th></tr></thead>
