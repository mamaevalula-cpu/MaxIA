function LogsTab() {

  const [file, setFile] = useState('system');

  const [lines, setLines] = useState([]);

  const [autoRefresh, setAutoRefresh] = useState(true);

  const [loading, setLoading] = useState(false);

  const bottomRef = useRef(null);



  const load = useCallback(async () => {

    try {

      setLoading(true);

      const r = await apiFetch(`/api/logs?file=${file}&lines=200`);

      if (r.ok && r.data) {

        const raw = r.data?.lines || r.data?.content

                    || (typeof r.data === 'string' ? r.data : '');

        const parsed = typeof raw === 'string'

          ? raw.split('\n').filter(Boolean)

          : (Array.isArray(raw) ? raw.map(String) : []);

        setLines(parsed.slice(-200));

      }

    } catch(e) {

      console.warn('LogsTab:', e);

    } finally {

      setLoading(false);

      try { bottomRef.current?.scrollIntoView({ behavior: 'smooth' }); } catch(_) {}

    }

  }, [file]);



  useEffect(() => { load(); }, [file]);



  useEffect(() => {

    if (!autoRefresh) return;

    const id = setInterval(load, 5000);

    return () => clearInterval(id);

  }, [autoRefresh, file]);



  const levelOf = line => {

    if (/ERROR|CRITICAL/.test(line)) return 'ERROR';

    if (/WARNING|WARN/.test(line)) return 'WARNING';

    if (/\bINFO\b/.test(line)) return 'INFO';

    if (/DEBUG/.test(line)) return 'DEBUG';

    return 'default';

  };



  return (

    <div>

      <div style={{display:'flex',alignItems:'center',justifyContent:'space-between',marginBottom:16}}>

        <div className="tab-title" style={{marginBottom:0}}>📜 Логи</div>

        <div style={{display:'flex',gap:12,alignItems:'center'}}>

          <label className="toggle">

            <input type="checkbox" checked={autoRefresh} onChange={e => setAutoRefresh(e.target.checked)} />

            <span className="toggle-slider"></span>

            <span style={{fontSize:12,color:'var(--text2)'}}>Автообновление (5с)</span>

          </label>

          <button className="btn btn-ghost btn-sm" onClick={load} disabled={loading}>

            {loading ? <span className="spinner" style={{width:14,height:14}}></span> : '↻ Обновить'}

          </button>

        </div>

      </div>



      <div style={{display:'flex',gap:8,marginBottom:12,flexWrap:'wrap'}}>

        {LOG_FILES.map(f => (

          <button

            key={f.id}

            className={`btn btn-sm ${file === f.id ? 'btn-primary' : 'btn-ghost'}`}

            onClick={() => setFile(f.id)}

          >

            {f.label}

          </button>

        ))}

      </div>



      <div className="log-box">

        {lines.length === 0 && !loading && <div className="empty-state">Лог пуст</div>}

        {lines.map((line, i) => {

          const level = levelOf(line);

          return <div key={i} className={`log-line ${level}`}>{line}</div>;

        })}

        <div ref={bottomRef}></div>

      </div>

    </div>

  );

}



