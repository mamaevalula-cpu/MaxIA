function BrowserTab() {
  const [status, setStatus] = React.useState({running:false});
  const [screenshot, setScreenshot] = React.useState('');
  const [url, setUrl] = React.useState('');
  const [query, setQuery] = React.useState('');
  const [log, setLog] = React.useState([]);
  const [loading, setLoading] = React.useState(false);
  const [aiCmd, setAiCmd] = React.useState('');

  const fetchStatus = async () => {
    try {
      const r = await apiFetch('/api/browser/status');
      if(r.ok && r.data) setStatus(prev => ({...prev, ...r.data}));
      const s = await apiFetch('/api/browser/screenshot');
      if(s.ok && s.data && s.data.screenshot_b64) setScreenshot(s.data.screenshot_b64);
    } catch(e) {}
  };

  React.useEffect(() => {
    fetchStatus();
    const t = setInterval(fetchStatus, 10000);
    return () => clearInterval(t);
  }, []);

  const doAction = async (action, extra) => {
    extra = extra || {};
    setLoading(true);
    try {
      const r = await apiFetch('/api/browser/action', {
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body: JSON.stringify(Object.assign({action}, extra))
      });
      if(r.ok && r.data) {
        if(r.data.screenshot_b64) setScreenshot(r.data.screenshot_b64);
        if(r.data.status) setStatus(prev => Object.assign({}, prev, r.data.status));
        setLog(prev => [{
          ts: new Date().toLocaleTimeString(),
          action: action,
          result: r.data.ok ? '✅ OK' : '❌ ' + (r.data.error || '?')
        }].concat(prev).slice(0, 20));
      }
    } catch(e) {
      setLog(prev => [{ts: new Date().toLocaleTimeString(), action: action, result: '❌ ' + e.message}].concat(prev).slice(0, 20));
    }
    setLoading(false);
  };

  const startBrowser = async () => {
    setLoading(true);
    try {
      const r = await apiFetch('/api/browser/start', {method:'POST'});
      if(r.ok && r.data && r.data.status) setStatus(prev => Object.assign({}, prev, r.data.status));
      setTimeout(fetchStatus, 3000);
    } catch(e) {}
    setLoading(false);
  };

  const stopBrowser = async () => {
    try {
      await apiFetch('/api/browser/stop', {method:'POST'});
      setStatus(prev => Object.assign({}, prev, {running: false}));
    } catch(e) {}
  };

  const sendAICommand = async () => {
    if(!aiCmd.trim()) return;
    const cmd = aiCmd.trim().toLowerCase();
    if(/^(go to|navigate to|открой)\s/i.test(cmd)) {
      const u = aiCmd.replace(/^(go to|navigate to|открой)\s*/i,'').trim();
      await doAction('navigate', {url: u});
    } else if(/^(search|search for|найди|поищи)/i.test(cmd)) {
      const q = aiCmd.replace(/^(search for|search|найди|поищи)\s*/i,'').trim();
      await doAction('search', {query: q});
    } else if(/^(click|нажми)/i.test(cmd)) {
      const t = aiCmd.replace(/^(click|нажми)\s*/i,'').trim();
      await doAction('click', {target: t});
    } else if(aiCmd.match(/^https?:\/\//i) || aiCmd.match(/\.\w{2,}$/)) {
      await doAction('navigate', {url: aiCmd.trim()});
    } else {
      await doAction('search', {query: aiCmd.trim()});
    }
    setAiCmd('');
  };

  const isRunning = !!(status.running || status.active);

  return React.createElement('div', null,
    React.createElement('h2', {style:{marginBottom:16}}, '🌐 Автономный Браузер (Playwright)'),

    React.createElement('div', {className:'card', style:{marginBottom:12,padding:'8px 14px',borderLeft:'3px solid '+(isRunning?'#10b981':'#6b7280')}},
      React.createElement('div', {style:{display:'flex',justifyContent:'space-between',alignItems:'center'}},
        React.createElement('div', null,
          React.createElement('span', {style:{fontWeight:700}}, isRunning ? '🟢 Активен' : '⚫ Остановлен'),
          status.title ? React.createElement('span', {style:{marginLeft:12,fontSize:13,color:'var(--text2)'}}, status.title) : null,
          status.actions_count > 0 ? React.createElement('span', {style:{marginLeft:10,fontSize:11,color:'var(--text2)'}}, 'Действий: '+status.actions_count) : null
        ),
        React.createElement('div', {style:{display:'flex',gap:8}},
