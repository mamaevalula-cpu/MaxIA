      <input class="inp" id="pipe-tags" placeholder="finance, revenue" style="margin-bottom:8px" value="general">
      <label style="font-size:11px;color:var(--txt3);display:block;margin-bottom:4px">Промпт</label>
      <textarea class="inp" id="pipe-prompt" rows="3" placeholder="Опишите задачу подробнее...">Проанализируй текущие потоки доходов</textarea>
      <div style="margin-top:10px;display:flex;align-items:center;gap:8px;flex-wrap:wrap">
        <button class="btn btn-g" onclick="runPipeline()" id="pipe-btn">▶ Запустить</button>
        <div class="fb" id="pipe-fb"></div>
      </div>
    </div>
    <div class="card">
      <div class="card-title"><span class="card-title-ico">📄</span>Результат</div>
      <div class="logbox" id="pipe-res" style="height:160px">Результат появится здесь...</div>
