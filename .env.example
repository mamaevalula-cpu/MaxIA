# ============================================================
# my_personal_ai — .env.example
# Скопируй в .env и заполни своими ключами
# ============================================================
# Система автоматически выбирает лучшую модель по задаче.
# Чем больше ключей подключено — тем умнее ИИ.

# ── OpenAI (GPT-4o, o3, o4-mini) ──────────────────────────────
# Получить: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Anthropic / Claude (Opus 4.5, Sonnet 4.5, Haiku 3.5) ──────
# Получить: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5

# ── Google Gemini (2.5 Pro, 2.5 Flash) ────────────────────────
# Получить: https://aistudio.google.com/app/apikey (БЕСПЛАТНО)
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-preview-05-20

# ── xAI / Grok (Grok 3, Grok 3 Mini) ──────────────────────────
# Получить: https://console.x.ai/
XAI_API_KEY=
GROK_MODEL=grok-3

# ── DeepSeek (R1 reasoner, V3 chat) ───────────────────────────
# Получить: https://platform.deepseek.com/api_keys (дешёво)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-reasoner

# ── Groq (Llama 4, Llama 3.3, Mixtral — быстрый) ──────────────
# Получить: https://console.groq.com/keys (БЕСПЛАТНО)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Together AI (Llama 4, Qwen 3, Mistral Large) ───────────────
# Получить: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Llama-4-Scout-17B-16E-Instruct

# ── Mistral (Large, Small) ─────────────────────────────────────
# Получить: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest

# ── Perplexity (Online search + AI) ───────────────────────────
# Получить: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# ── Ollama (локально, полностью бесплатно) ─────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── Telegram ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=         # @BotFather → /newbot
TELEGRAM_CHAT_ID=           # твой chat_id (@userinfobot)

# ── Bybit ─────────────────────────────────────────────────────
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=true          # ВАЖНО: true до полной проверки!

# ── Торговля на реальные деньги ───────────────────────────────
TRADING_LIVE_CONFIRMED=false # true только если уверен в рисках

# ── Почта ─────────────────────────────────────────────────────
EMAIL_ADDRESS=
EMAIL_PASSWORD=             # для Gmail: App Password (не основной пароль)
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993

# ── Векторные базы ────────────────────────────────────────────
VECTOR_BACKEND=sqlite       # sqlite | chroma | faiss | pinecone
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=gcp-starter

# ── Безопасность ─────────────────────────────────────────────
MASTER_PASSWORD=            # Мастер-пароль для шифрования secrets.db

# ── Система ───────────────────────────────────────────────────
LOG_LEVEL=INFO
MAX_PARALLEL_AGENTS=5
AGENT_TASK_TIMEOUT=120
