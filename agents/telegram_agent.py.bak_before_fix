        async def _approval_watcher_task() -> None:
            import os as _os, json as _json, time as _time
            while True:
                try:
                    await asyncio.sleep(5)
                    if not _os.path.exists(_PENDING_APPROVALS_PATH):
                        continue
                    with open(_PENDING_APPROVALS_PATH, encoding='utf-8') as _f:
                        lines = _f.readlines()
                    for _line in lines:
                        _line = _line.strip()
                        if not _line:
                            continue
                        try:
                            _req = _json.loads(_line)
                        except Exception:
                            continue
                        nonce = _req.get('nonce', '')
                        if not nonce or nonce in _seen_approval_nonces:
                            continue
                        if _req.get('status') != 'pending':
                            _seen_approval_nonces.add(nonce)
                            continue
                        _already = False
                        if _os.path.exists(_APPROVAL_RESPONSES_PATH):
                            with open(_APPROVAL_RESPONSES_PATH, encoding='utf-8') as _rf:
                                for _rl in _rf:
                                    try:
