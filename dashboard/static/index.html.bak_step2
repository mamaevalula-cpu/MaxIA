async function loadPlatforms() {
  const d = window.__PL__ || await api(HYP+'/api/v2/fleet/control');
  window.__PL__ = null;
  if (!d) return;
  const adp=d.adapters||[], cl=d.clusters||[];

  $('pl-kpis').innerHTML = [
    statCard(d.total_adapters||0,'Адаптеров всего','','stat-acc'),
    statCard(d.live_count||0,'Подключено','Live режим','stat-grn'),
    statCard((d.total_adapters||0)-(d.live_count||0),'В режиме Mock','тестовый режим'),
    statCard((d.graph||{}).active_skills||30,'Навыков в графе','Skill Graph'),
  ].join('');

  const clusterNames = {A:'Труд (Labor)',B:'DePIN',C:'Дивизионы',D:'Discovery'};
  $('pl-clusters').innerHTML = cl.map(c => `<div class="card" style="padding:14px">
    <div style="font-size:10px;color:var(--txt3);text-transform:uppercase;letter-spacing:1px;margin-bottom:6px">Кластер ${esc(c.cluster)}</div>
    <div style="font-size:14px;font-weight:700;color:#ddeeff;margin-bottom:2px">${esc(clusterNames[c.cluster]||c.name)}</div>
    <div style="font-size:24px;font-weight:800;color:var(--acc);margin:6px 0">${c.total}</div>
    <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:8px">
      ${bdg(c.live_connections+' live','g')} ${bdg(c.mock_mode+' mock','y')}
    </div>
    ${bar(c.readiness_pct||0,'acc')}
    <div style="font-size:10px;color:var(--txt3);margin-top:3px">${(c.readiness_pct||0).toFixed(0)}% подключено</div>
  </div>`).join('');

  $('pl-tbl').innerHTML = adp.map(a => `<tr>
    <td style="font-family:'Consolas',monospace;color:var(--acc);font-weight:700">${esc(a.id)}</td>
    <td>${bdg('C'+a.cluster,'b')}</td>
    <td>${bdg(a.mock?'Mock':'Live',a.mock?'y':'g')}</td>
    <td style="font-weight:700;color:${(+a.ev||0)>0.8?'var(--grn)':(+a.ev||0)>0.5?'var(--acc)':'var(--yel)'}">${a.ev||'—'}</td>
    <td>${a.key_set?bdg('Ключ есть','g'):bdg('Нет ключа','y')}</td>
  </tr>`).join('');


  // Registration status section
  const pd = await api('/api/v1/platforms');
  if (pd) {
    const s = pd.summary || {};
    $('pl-reg-kpis').innerHTML = [
      statCard(s.ok||0,'Зарегистрировано','платформ','stat-grn'),
      statCard(s.pending||0,'Ожидают верификации','email verify'),
      statCard(s.not_done||0,'Не готовы','нужна работа'),
      statCard((pd.assets||[]).length,'Content assets','файлов'),
    ].join('');

    const stColors = {
      logged_in:'g', registered:'g', already_exists:'g', bot_created:'g', agent_created:'g',
      verify_email:'y', partial:'y', login_attempted:'y',
      no_form_found:'r', captcha_blocked:'r', error:'r', unknown:'r', not_started:'r'
    };
    const stLabels = {
      logged_in:'✅ Залогинен', registered:'✅ Зарег.', already_exists:'✅ Аккаунт есть',
      bot_created:'✅ Бот создан', agent_created:'✅ Агент создан',
      verify_email:'📧 Верифик.', partial:'⏳ Частично', login_attempted:'⏳ Вход попытка',
      no_form_found:'❌ Форма не найдена', captcha_blocked:'⛔ Каптча', error:'❌ Ошибка',
      unknown:'❓ Неизвестно', not_started:'⬜ Не начато'
    };
    $('pl-reg-tbl').innerHTML = (pd.platforms||[]).map(p => `<tr>
      <td style="font-family:'Consolas',monospace;font-weight:700;color:var(--acc)">${esc(p.name)}</td>
      <td>${bdg(stLabels[p.status]||p.status, stColors[p.status]||'r')}</td>
      <td style="font-size:11px;color:var(--txt3)">${esc((p.note||'').toString().slice(0,50))}</td>
    </tr>`).join('');

    $('pl-api-list').innerHTML = (pd.api_endpoints||[]).map(ep =>
      `<div style="font-family:'Consolas',monospace;font-size:12px;padding:3px 0;color:var(--acc)">${esc(ep)}</div>`
    ).join('') + '<div style="font-size:11px;color:var(--txt3);margin-top:8px">Все endpoints: POST /api/v1/webhook, /ai, /lead | GET /api/v1/packs, /manifest, /status</div>';
  }

}


  // Registration status section

async function loadSkills() {
  const d = await api(HYP+'/api/v2/skillgraph');
  if (!d) return;
  const g=d.skill_graph||{}, dv=d.divisions||{}, top=d.top_ev_opportunities||[];
  const pipe=(d.pipeline||{}).strategic||{};

  $('sk-kpis').innerHTML = [
    statCard(g.total_skills||0,'Навыков в графе','','stat-acc'),
    statCard(g.active_skills||0,'Активных','','stat-grn'),
    statCard(Object.keys(dv).length,'Дивизионов','Кластер C'),
    statCard('$'+(pipe.budget_remaining_usd||50),'Бюджет сегодня','осталось'),
  ].join('');

  $('sk-top').innerHTML = top.slice(0,12).map((s,i) => {
    const ev=+(s.ev||0), ec=ev>0.8?'var(--grn)':ev>0.6?'var(--acc)':'var(--yel)';
    return `<div class="skill-item">
      <span class="skill-rank">${i+1}</span>
      <span class="skill-name">${esc(s.id||'?')}</span>
      <span class="skill-ev" style="color:${ec}">${s.ev}</span>
    </div>`;
  }).join('') || '<div style="color:var(--txt3);padding:10px;font-size:12px">Загрузка данных...</div>';

  const divNames={div_revenue:'Доходы',div_content:'Контент',div_media:'Медиа',div_website:'Сайты',div_social:'Соцсети',div_finance:'Финансы',div_hr:'HR',div_infra:'Инфраструктура'};
  $('sk-divs').innerHTML = Object.entries(dv).map(([n,h]) => {
    const av=h.agents_available||0, tot=h.agents_total||1, p=Math.round(av/tot*100);
    return `<div class="row"><span class="row-left">${esc(divNames[n]||n.replace('div_',''))}</span>${bdg(p+'%',p>80?'g':'y')}</div>`;
  }).join('') || '<div style="color:var(--txt3);padding:10px">Нет данных</div>';
}

