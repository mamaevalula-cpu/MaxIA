        <div style={{marginTop:12,fontSize:13,color:'var(--text2)'}}>

          Агент работает каждые 5 минут · Логи: /root/defai-agent/logs/defai.log

        </div>

      </div>



      {/* Live Control */}

      <div className="card">

        <div style={{fontWeight:700,marginBottom:10}}>⚙️ Управление</div>

        <div style={{display:'flex',gap:10,flexWrap:'wrap'}}>

          {status?.paper_mode && (

            <button onClick={async()=>{

              if(!confirm('Переключить DeFAI в LIVE режим? Требуется USDC баланс.'))return;

              const r = await apiFetch('/api/defai/control',{method:'POST',body:JSON.stringify({action:'enable_live'})});

              alert(r.ok?'✅ Переключено в LIVE!':'❌ '+JSON.stringify(r.data));

            }} style={{background:'#10b981',color:'#fff',border:'none',borderRadius:6,padding:'7px 14px',cursor:'pointer',fontWeight:700}}>

              ⚡ Включить LIVE

            </button>

          )}

          <button onClick={async()=>{

            const r = await apiFetch('/api/defai/status');

            if(r.ok) setStatus(r.data);

            alert('✅ Обновлено');

          }} style={{background:'var(--bg)',border:'1px solid var(--border)',borderRadius:6,padding:'7px 14px',cursor:'pointer'}}>

            🔄 Обновить

          </button>

        </div>


      {/* Signals feed */}
      <SignalsFeed />
      </div>

    </div>

  );

}



