# ── Константы ─────────────────────────────────────────────────────────────────

TELEGRAM_CHUNK_SIZE = 4000       # чуть меньше лимита Telegram для запаса
MAX_CHUNKS          = 12         # максимум чанков за один ответ (48 000 chars max)
RECONNECT_DELAYS    = [5, 10, 30, 60, 120, 300]
DEFAULT_INVITE_TTL  = 24 * 3600  # 24 часа по умолчанию

AUTH_DB_PATH = Path(__file__).parent.parent / "data" / "telegram_auth.db"


# ── Уровни доступа ────────────────────────────────────────────────────────────

class AccessLevel(IntEnum):
    BLOCKED = 0
    USER    = 1
    ADMIN   = 2
    OWNER   = 3


@dataclass
class TelegramUser:
    user_id:      int
    username:     str
    full_name:    str
    access:       AccessLevel
    joined_at:    float
    last_seen:    float
    message_count: int = 0
    invited_by:   Optional[int] = None


# ── База данных авторизации ────────────────────────────────────────────────────

class AuthDB:
    """SQLite-хранилище авторизованных пользователей и инвайт-токенов."""

    _CREATE_USERS = """
    CREATE TABLE IF NOT EXISTS tg_users (
        user_id       INTEGER PRIMARY KEY,
        username      TEXT,
        full_name     TEXT,
        access        INTEGER DEFAULT 1,
        joined_at     REAL,
        last_seen     REAL,
        message_count INTEGER DEFAULT 0,
        invited_by    INTEGER
    )"""

    _CREATE_INVITES = """
    CREATE TABLE IF NOT EXISTS tg_invites (
        token       TEXT PRIMARY KEY,
        created_by  INTEGER NOT NULL,
        created_at  REAL NOT NULL,
        expires_at  REAL NOT NULL,
        used_by     INTEGER,
        used_at     REAL,
        label       TEXT DEFAULT ''
    )"""

    def __init__(self, path: Path = AUTH_DB_PATH) -> None:
        path.parent.mkdir(parents=True, exist_ok=True)
        self._path = path
        self._init_db()

    def _connect(self) -> sqlite3.Connection:
        conn = sqlite3.connect(str(self._path), timeout=5, check_same_thread=False)
        conn.row_factory = sqlite3.Row
        return conn

    def _init_db(self) -> None:
        with self._connect() as conn:
            conn.execute(self._CREATE_USERS)
            conn.execute(self._CREATE_INVITES)
            conn.commit()

    # ── Пользователи ─────────────────────────────────────────────────────────

    def get_user(self, user_id: int) -> Optional[TelegramUser]:
        with self._connect() as conn:
            row = conn.execute(
                "SELECT * FROM tg_users WHERE user_id = ?", (user_id,)
            ).fetchone()
        if not row:
            return None
        return TelegramUser(
            user_id=row["user_id"], username=row["username"] or "",
            full_name=row["full_name"] or "", access=AccessLevel(row["access"]),
            joined_at=row["joined_at"], last_seen=row["last_seen"],
            message_count=row["message_count"], invited_by=row["invited_by"],
        )

    def upsert_user(self, user: TelegramUser) -> None:
        with self._connect() as conn:
            conn.execute("""
                INSERT INTO tg_users
                    (user_id, username, full_name, access, joined_at, last_seen,
                     message_count, invited_by)
                VALUES (?, ?, ?, ?, ?, ?, ?, ?)
                ON CONFLICT(user_id) DO UPDATE SET
                    username=excluded.username,
                    full_name=excluded.full_name,
                    access=excluded.access,
                    last_seen=excluded.last_seen,
                    message_count=tg_users.message_count + excluded.message_count
            """, (user.user_id, user.username, user.full_name, int(user.access),
                  user.joined_at, user.last_seen, user.message_count, user.invited_by))
            conn.commit()

    def set_access(self, user_id: int, access: AccessLevel) -> bool:
        with self._connect() as conn:
            n = conn.execute(
                "UPDATE tg_users SET access = ? WHERE user_id = ?",
                (int(access), user_id)
            ).rowcount
            conn.commit()
        return n > 0

    def bump_seen(self, user_id: int) -> None:
        with self._connect() as conn:
            conn.execute(
                "UPDATE tg_users SET last_seen = ?, message_count = message_count + 1 WHERE user_id = ?",
                (time.time(), user_id)
            )
            conn.commit()

    def list_users(self) -> List[TelegramUser]:
        with self._connect() as conn:
            rows = conn.execute(
                "SELECT * FROM tg_users ORDER BY joined_at DESC"
            ).fetchall()
        return [
            TelegramUser(
                user_id=r["user_id"], username=r["username"] or "",
                full_name=r["full_name"] or "", access=AccessLevel(r["access"]),
                joined_at=r["joined_at"], last_seen=r["last_seen"],
                message_count=r["message_count"], invited_by=r["invited_by"],
            )
            for r in rows
        ]

    # ── Инвайты ──────────────────────────────────────────────────────────────

    def create_invite(self, created_by: int, ttl_sec: float = DEFAULT_INVITE_TTL,
                      label: str = "") -> str:
        token = uuid.uuid4().hex[:16]
        now   = time.time()
        with self._connect() as conn:
            conn.execute(
                "INSERT INTO tg_invites (token, created_by, created_at, expires_at, label) "
                "VALUES (?, ?, ?, ?, ?)",
                (token, created_by, now, now + ttl_sec, label)
            )
            conn.commit()
        return token

    def use_invite(self, token: str, user_id: int) -> bool:
        """Проверить и сжечь инвайт-токен. Возвращает True если валиден."""
        now = time.time()
        with self._connect() as conn:
            row = conn.execute(
                "SELECT * FROM tg_invites WHERE token = ?", (token,)
            ).fetchone()
            if not row:
                return False
            if row["used_by"] is not None:
                return False   # уже использован
            if row["expires_at"] < now:
                return False   # истёк
            conn.execute(
                "UPDATE tg_invites SET used_by = ?, used_at = ? WHERE token = ?",
                (user_id, now, token)
            )
            conn.commit()
        return True

    def list_invites(self, active_only: bool = True) -> List[Dict]:
        with self._connect() as conn:
            if active_only:
                rows = conn.execute(
                    "SELECT * FROM tg_invites WHERE used_by IS NULL AND expires_at > ? "
                    "ORDER BY created_at DESC",
                    (time.time(),)
                ).fetchall()
            else:
                rows = conn.execute(
                    "SELECT * FROM tg_invites ORDER BY created_at DESC LIMIT 20"
                ).fetchall()
        return [dict(r) for r in rows]


# ── Вспомогательные функции ────────────────────────────────────────────────────

def _split_message(text: str, chunk_size: int = TELEGRAM_CHUNK_SIZE) -> List[str]:
    """Разбить длинный текст на чанки ≤ chunk_size по абзацам/строкам."""
    if len(text) <= chunk_size:
        return [text]
    chunks = []
    remaining = text
    while remaining:
        if len(remaining) <= chunk_size:
            chunks.append(remaining)
            break
        split_at = remaining.rfind("\n\n", 0, chunk_size)
        if split_at == -1:
            split_at = remaining.rfind("\n", 0, chunk_size)
        if split_at == -1:
            split_at = remaining.rfind(" ", 0, chunk_size)
        if split_at == -1:
            split_at = chunk_size
        chunks.append(remaining[:split_at].rstrip())
        remaining = remaining[split_at:].lstrip()
    return chunks[:MAX_CHUNKS]


def _escape_md(text: str) -> str:
    """Экранировать спецсимволы MarkdownV2."""
    escape_chars = r"_*[]()~`>#+-=|{}.!\\"
    return re.sub(f"([{re.escape(escape_chars)}])", r"\\\1", text)


# ── Главный агент ─────────────────────────────────────────────────────────────

class TelegramAgent(BaseAgent):
    """
    Telegram-агент v4.0 с системой инвайтов и уровнями доступа.
    Работает в отдельном потоке. Полностью thread-safe.
    """

    def __init__(self) -> None:
        super().__init__("telegram")
        self._application = None
        self._loop: Optional[asyncio.AbstractEventLoop] = None
        self._thread: Optional[threading.Thread] = None
        self._brain_callback: Optional[Callable] = None
        self._watchdog: Optional[Any] = None
        self._reconnect_attempt = 0
        self._db = AuthDB()
        self._bot_username: str = ""

        # Owner ID из .env (всегда имеет полный доступ)
        self._owner_id: int = int(cfg.telegram_chat_id) if cfg.telegram_chat_id else 0

        # Дополнительные admin IDs из .env (через запятую)
        admin_env = cfg.telegram_admin_ids if hasattr(cfg, "telegram_admin_ids") else ""
        self._admin_ids: Set[int] = set()
        for aid in (admin_env or "").split(","):
            aid = aid.strip()
            if aid.isdigit():
                self._admin_ids.add(int(aid))

        # Auto-register owner as OWNER level
        if self._owner_id:
            self._ensure_owner_registered()

    def _ensure_owner_registered(self) -> None:
        """Убедиться что owner зарегистрирован в БД."""
        existing = self._db.get_user(self._owner_id)
        if not existing:
            self._db.upsert_user(TelegramUser(
                user_id=self._owner_id, username="owner", full_name="Owner",
                access=AccessLevel.OWNER, joined_at=time.time(),
                last_seen=time.time(),
            ))
        elif existing.access != AccessLevel.OWNER:
            self._db.set_access(self._owner_id, AccessLevel.OWNER)

    # ── Проверка доступа ──────────────────────────────────────────────────────

    def _get_access(self, user_id: int) -> AccessLevel:
        """Определить уровень доступа пользователя."""
        if user_id == self._owner_id:
            return AccessLevel.OWNER
        if user_id in self._admin_ids:
            return AccessLevel.ADMIN
        user = self._db.get_user(user_id)
        if user:
            return user.access
        return AccessLevel.BLOCKED

    def _is_authorized(self, user_id: int, min_level: AccessLevel = AccessLevel.USER) -> bool:
        return self._get_access(user_id) >= min_level

    # ── Public API ─────────────────────────────────────────────────────────────

    def info(self) -> AgentInfo:
        return AgentInfo(
            name="telegram",
            description="Telegram-бот v4.0 (invite-only). Управление AI и торговым ботом.",
            capabilities=[
                "send_message", "receive_message", "notify",
                "broadcast", "chunked_reply", "command_routing",
                "invite_system", "access_control",
            ],
        )

    def can_handle(self, text: str) -> bool:
        patterns = [
            r"(отправь|пошли|send).*(telegram|телеграм|сообщени)",
            r"(telegram|телеграм).*(бот|bot|уведомлени|notification)",
        ]
        return any(re.search(p, text, re.IGNORECASE) for p in patterns)

    def process(self, text: str, source: str = "gui") -> str:
        t = text.lower()
        if any(w in t for w in ["статус", "status"]):
            return self._get_status_str()
        if any(w in t for w in ["запусти", "старт", "start"]):
            return self.start_polling()
        if any(w in t for w in ["останови", "стоп", "stop"]):
            self.stop()
            return "🔴 Telegram-бот остановлен."
        m = re.search(r'(?:отправь|send|пошли)\s+["\']?(.+)["\']?', text, re.IGNORECASE)
        if m:
            return self.send_message(m.group(1).strip())
        return self._get_status_str()

    def set_brain_callback(self, cb: Callable) -> None:
        self._brain_callback = cb

    def set_watchdog(self, watchdog: Any) -> None:
        self._watchdog = watchdog

    # ── Жизненный цикл ────────────────────────────────────────────────────────

    def start(self) -> None:
        if not cfg.telegram_token:
            log.warning("Telegram token not set — agent disabled")
            self._set_status(AgentStatus.STOPPED)
            return
        self._stop_event.clear()
        self._reconnect_attempt = 0
        self._thread = threading.Thread(
            target=self._run_bot_with_restart, name="telegram-agent", daemon=True
        )
        self._thread.start()
        self._set_status(AgentStatus.RUNNING)
        log.info("TelegramAgent v4.0 started (invite-only mode)")

    def start_polling(self) -> str:
        if not cfg.telegram_token:
            return "⚠️ Telegram токен не настроен. Добавь TELEGRAM_BOT_TOKEN в .env"
        self.start()
        return "🟢 Telegram-бот v4.0 запущен (invite-only)."

    def stop(self) -> None:
        super().stop()
        if self._application and self._loop:
            try:
                asyncio.run_coroutine_threadsafe(
                    self._application.stop(), self._loop
                ).result(timeout=5)
            except Exception:
                pass

    # ── Отправка ──────────────────────────────────────────────────────────────

    def send_message(self, text: str, chat_id: str = "") -> str:
        chat_id = chat_id or cfg.telegram_chat_id
        if not chat_id:
            return "⚠️ TELEGRAM_CHAT_ID не настроен."
        chunks = _split_message(text)
        if self._loop and self._application:
            try:
                for chunk in chunks:
                    asyncio.run_coroutine_threadsafe(
                        self._application.bot.send_message(
                            chat_id=chat_id, text=chunk, parse_mode="HTML"
                        ),
                        self._loop
                    ).result(timeout=10)
                suffix = f" ({len(chunks)} частей)" if len(chunks) > 1 else ""
                return f"✅ Сообщение отправлено{suffix}."
            except Exception as e:
                log.warning("send_message via app failed: %s — trying direct", e)
                return self._send_direct(text, chat_id)
        return self._send_direct(text, chat_id)

    def send_notification(self, text: str, chat_id: str = "") -> None:
        try:
            self.send_message(text, chat_id)
        except Exception:
            pass

    notify = send_notification

    def _send_direct(self, text: str, chat_id: str) -> str:
        if not cfg.telegram_token:
            return "⚠️ TELEGRAM_BOT_TOKEN не настроен."
        try:
            import httpx
            url = f"https://api.telegram.org/bot{cfg.telegram_token}/sendMessage"
            chunks = _split_message(text)
            for chunk in chunks:
                self._send_direct_chunk(url, chat_id, chunk)
            suffix = f" ({len(chunks)} частей)" if len(chunks) > 1 else ""
            return f"✅ Отправлено{suffix}."
        except Exception as e:
            log.error("_send_direct failed: %s", e)
            # Попробовать добавить в offline-очередь
            try:
                from agents.telegram_resilience import get_resilient_bot
                get_resilient_bot().enqueue(chat_id, text, priority=3)
                return f"⚠️ В очереди: {e}"
            except Exception:
                return f"❌ Ошибка: {e}"

    def _send_direct_chunk(self, url: str, chat_id: str, text: str) -> None:
        """Отправить один чанк с retry (exponential backoff)."""
        import httpx
        import random as _random

        delays = [1, 3, 10, 30, 60]
        last_err: Optional[Exception] = None

        for attempt, delay in enumerate(delays):
            try:
                resp = httpx.post(url, json={
                    "chat_id": chat_id, "text": text, "parse_mode": "HTML"
                }, timeout=12, verify=False)

                if resp.status_code == 429:
                    retry_after = float(resp.json().get("parameters", {}).get("retry_after", delay))
                    log.warning("Telegram 429 — retry after %.0fs", retry_after)
                    time.sleep(retry_after + _random.uniform(0, 2))
                    continue

                if resp.status_code >= 500:
                    raise IOError(f"Telegram server error {resp.status_code}")

                resp.raise_for_status()
                return  # success

            except Exception as e:
                last_err = e
                if attempt < len(delays) - 1:
                    jitter = _random.uniform(0, 1.5)
                    log.warning("Send chunk attempt %d failed: %s — retry in %.1fs",
                                attempt + 1, e, delay + jitter)
                    time.sleep(delay + jitter)

        raise last_err or IOError("All send attempts failed")

    def _get_status_str(self) -> str:
        users = self._db.list_users()
        invites = self._db.list_invites(active_only=True)
        return (
            f"📱 Telegram-агент v4.0 [{self._status.value}]\n"
            f"  Токен: {'✅' if cfg.telegram_token else '❌'}\n"
            f"  Chat ID: {'✅' if cfg.telegram_chat_id else '❌'}\n"
            f"  Авторизовано: {len(users)} пользователей\n"
            f"  Активных инвайтов: {len(invites)}\n"
            f"  Owner ID: {self._owner_id or '—'}"
        )

    # ── Перезапуск ────────────────────────────────────────────────────────────

    def _reset_telegram_session(self) -> None:
        """
        Сбросить polling-сессию через Telegram Bot API.
        Вызывается перед каждым рестартом чтобы избежать Conflict 409.
        """
        try:
            import urllib.request as _ur
            token = cfg.telegram_token
            base  = f"https://api.telegram.org/bot{token}"
            # 1. Удалить webhook (если есть)
            _ur.urlopen(f"{base}/deleteWebhook?drop_pending_updates=true", timeout=8)
            # 2. getUpdates с timeout=0 — сбивает предыдущую long-poll сессию
            _ur.urlopen(f"{base}/getUpdates?timeout=0&offset=-1", timeout=8)
            log.info("Telegram polling session reset OK")
        except Exception as e:
            log.warning("Telegram session reset failed (non-critical): %s", e)

    def _run_bot_with_restart(self) -> None:
        # ALWAYS reset the session on startup (not just on restart).
        # After systemctl restart, the previous getUpdates long-poll may still
        # be alive on Telegram's servers for up to 45s — reset it first.
        log.info("Telegram: resetting session before first start...")
        self._reset_telegram_session()
        self._stop_event.wait(timeout=30)  # give Telegram time to expire old session (was 5s, now 30s)

        while not self._stop_event.is_set():
            try:
                self._run_bot()
            except Exception as e:
                err_str = str(e)
                log.error("Telegram bot crashed: %s", e)
                self._set_status(AgentStatus.ERROR)
                # Conflict 409 требует длинной паузы (Telegram держит сессию ~30с)
                is_conflict = "conflict" in err_str.lower() or "409" in err_str
                if is_conflict:
                    log.warning("Telegram Conflict detected — waiting 65s for session to expire...")
                    self._stop_event.wait(timeout=90)
                    log.info("Resetting Telegram session after conflict wait...")
                    self._reset_telegram_session()
                    self._stop_event.wait(timeout=5)
                    continue  # после паузы сразу пробуем — delay ниже пропускаем
            if self._stop_event.is_set():
                break
            # Normal restart path: reset session + wait
            log.info("Resetting Telegram session before restart...")
            self._reset_telegram_session()
            delay = RECONNECT_DELAYS[min(self._reconnect_attempt, len(RECONNECT_DELAYS) - 1)]
            self._reconnect_attempt += 1
            log.warning("Telegram reconnecting in %ds (attempt #%d)...", delay, self._reconnect_attempt)
            self._set_status(AgentStatus.WAITING)
            self._stop_event.wait(timeout=max(delay, 10))
        self._set_status(AgentStatus.STOPPED)

    # ── Основной bot loop ─────────────────────────────────────────────────────

    def _run_bot(self) -> None:
        try:
            from telegram import (Update, InlineKeyboardButton, InlineKeyboardMarkup,
                                   BotCommand)
            from telegram.ext import (Application, CommandHandler,
                                       MessageHandler, CallbackQueryHandler,
                                       filters, ContextTypes)
            from telegram.constants import ParseMode, ChatAction
        except ImportError:
            log.error("python-telegram-bot не установлен! pip install python-telegram-bot")
            self._set_status(AgentStatus.ERROR)
            return

        self._loop = asyncio.new_event_loop()
        asyncio.set_event_loop(self._loop)

        # ── ResilientBot — queue drainer + connection guard ────────────────────
        try:
            from agents.telegram_resilience import get_resilient_bot
            self._resilient = get_resilient_bot()

            async def _async_send(chat_id, text, **kw):
                await app_holder[0].bot.send_message(
                    chat_id=chat_id, text=text, parse_mode="HTML", **kw)

            self._resilient.set_send_fn(_async_send)
            self._resilient.start_queue_drainer(self._loop)
            self._resilient.mark_connected()
        except Exception as _re:
            log.debug("ResilientBot init skipped: %s", _re)
            self._resilient = None
        app_holder: list = [None]  # filled after Application is built below

        # ── Вспомогательные функции ───────────────────────────────────────────

        async def _reply(update: Update, text: str,
                         parse_mode: str = ParseMode.HTML) -> None:
            """Ответить с авто-чанкингом. При > 6000 символов — отправляет файл .txt."""
            if not text:
                text = "(пустой ответ)"
            # Очень длинный ответ → отправить как файл
            if len(text) > 6000:
                try:
                    import io as _bio
                    # Для очень длинных ответов отправляем как файл
                    filename = "response.txt"
                    caption = f"📄 Ответ ({len(text):,} симв.) прикреплён как файл."
                    doc = _bio.BytesIO(text.encode("utf-8"))
                    doc.name = filename
                    await update.message.reply_document(
                        document=doc,
                        filename=filename,
                        caption=caption,
                        parse_mode=None
                    )
                    return
                except Exception as _fe:
                    log.warning("File send failed, fallback to chunks: %s", _fe)
            chunks = _split_message(text)
            for i, chunk in enumerate(chunks):
                sent = False
                for pm in (parse_mode, None):
                    try:
                        await update.message.reply_text(chunk, parse_mode=pm)
                        sent = True
                        break
                    except Exception:
                        if pm is None:
                            log.warning("Failed to send chunk %d of message", i)
                if not sent:
                    break

        async def _typing(update: Update, context) -> None:
            await context.bot.send_chat_action(
                chat_id=update.effective_chat.id, action=ChatAction.TYPING
            )

        def _access_denied_text(user_id: int) -> str:
            return (
                "🚫 <b>Доступ запрещён</b>\n\n"
                "Этот бот работает только по приглашениям.\n"
                "Если у тебя есть инвайт-ссылка — нажми на неё.\n\n"
                f"Твой ID: <code>{user_id}</code>"
            )

        # ── Middleware: проверка доступа ──────────────────────────────────────

        def _check_access(min_level: AccessLevel = AccessLevel.USER):
            """Декоратор для проверки уровня доступа."""
            def decorator(func):
                async def wrapper(update: Update, context) -> None:
                    user = update.effective_user
                    if not user:
                        return
                    uid = user.id
                    level = self._get_access(uid)
                    if level < min_level:
                        log.warning("Unauthorized access attempt: uid=%d username=%s",
                                    uid, user.username)
                        # Логируем в файл
                        with open("logs/telegram_blocked.log", "a",
                                  encoding="utf-8") as f:
                            f.write(
                                f"{time.strftime('%Y-%m-%d %H:%M:%S')} "
                                f"BLOCKED uid={uid} @{user.username} "
                                f"'{(update.message.text or '')[:60]}'\n"
                            )
                        await update.message.reply_text(
                            _access_denied_text(uid), parse_mode=ParseMode.HTML
                        )
                        return
                    # Обновить last_seen
                    self._db.bump_seen(uid)
                    await func(update, context)
                return wrapper
            return decorator

        # ── /start — авторизация через инвайт ────────────────────────────────

        async def _start_cmd(update: Update, context) -> None:
            user = update.effective_user
            uid  = user.id
            args = context.args or []

            # Проверка инвайт-токена
            if args and args[0].startswith("INVITE_"):
                token = args[0][7:]   # убрать "INVITE_"
                existing = self._db.get_user(uid)
                if existing and existing.access >= AccessLevel.USER:
                    await update.message.reply_text(
                        "✅ Ты уже авторизован!\nНапиши что-нибудь или /help",
                        parse_mode=ParseMode.HTML
                    )
                    return
                if self._db.use_invite(token, uid):
                    # Добавить пользователя
                    new_user = TelegramUser(
                        user_id=uid,
                        username=user.username or "",
                        full_name=user.full_name or "",
                        access=AccessLevel.USER,
                        joined_at=time.time(),
                        last_seen=time.time(),
                    )
                    self._db.upsert_user(new_user)
                    log.info("New user authorized via invite: uid=%d @%s", uid, user.username)
                    # Уведомить владельца
                    if self._owner_id and uid != self._owner_id:
                        try:
                            await context.bot.send_message(
                                chat_id=self._owner_id,
                                text=(
                                    f"🔔 <b>Новый пользователь авторизован</b>\n"
                                    f"ID: <code>{uid}</code>\n"
                                    f"Имя: {user.full_name}\n"
                                    f"Username: @{user.username or '—'}"
                                ),
                                parse_mode=ParseMode.HTML
                            )
                        except Exception:
                            pass
                    await update.message.reply_text(
                        f"✅ <b>Добро пожаловать, {user.first_name}!</b>\n\n"
                        f"Ты авторизован и теперь можешь использовать бота.\n"
                        f"Напиши /help для списка команд или просто задай вопрос!",
                        parse_mode=ParseMode.HTML
                    )
                    return
                else:
                    await update.message.reply_text(
                        "❌ <b>Инвайт-ссылка недействительна</b>\n\n"
                        "Возможные причины:\n"
                        "• Ссылка уже использована\n"
                        "• Ссылка истекла (срок 24 часа)\n"
                        "• Неверный токен\n\n"
                        "Попроси новую ссылку у владельца.",
                        parse_mode=ParseMode.HTML
                    )
                    return

            # Обычный /start (без токена)
            level = self._get_access(uid)
            if level >= AccessLevel.USER:
                self._db.bump_seen(uid)
                await update.message.reply_text(
                    f"👋 <b>Привет, {user.first_name}!</b>\n\n"
                    f"Уровень доступа: <b>{level.name}</b>\n"
                    f"Напиши /help для списка всех команд.",
                    parse_mode=ParseMode.HTML
                )
            else:
                await update.message.reply_text(
                    _access_denied_text(uid), parse_mode=ParseMode.HTML
                )

