        @_check_access(AccessLevel.USER)
        async def _task_cmd(update: Update, context) -> None:
            """Запустить автономную задачу: /task <описание задачи>"""
            task_text = " ".join(context.args) if context.args else ""
            if not task_text:
                await _reply(update, "⚡ Использование: /task <описание задачи>\n\nПример:\n/task Найди все TODO в проекте и создай список")
                return
            await _typing(update, context)
            chat_id = update.effective_chat.id
            try:
                from agents.task_executor_agent import TaskExecutorAgent, ProgressEvent
                agent = TaskExecutorAgent.get()

                sent_steps = [0]

                def on_progress(evt: ProgressEvent) -> None:
                    if evt.is_final:
                        text = f"✅ <b>Задача [{evt.task_id}] завершена</b>\n\n{evt.observation[:600]}"
                    elif evt.step_num % 3 == 0:
                        tool = evt.tool_name or "thinking"
                        text = f"⚙ <b>[{evt.task_id}] Шаг {evt.step_num}</b>: {tool}\n<code>{evt.observation[:200]}</code>"
                    else:
                        return
                    import asyncio
                    asyncio.run_coroutine_threadsafe(
                        context.application.bot.send_message(
                            chat_id=chat_id, text=text, parse_mode="HTML"
                        ),
                        context.application.loop,
                    )

                task_id = await agent.submit(task_text, on_progress=on_progress)
                await _reply(update, f"⚡ Задача <code>{task_id}</code> запущена.\nПолучу уведомление по завершении каждых ~3 шагов.")
            except Exception as e:
                await _reply(update, f"❌ Ошибка запуска задачи: {e}")

