        async def _on_message(update: Update, context) -> None:
            if not update.message or not update.message.text:
                return
            user = update.effective_user
            uid  = user.id

            # -- Sales lead routing for unauthorized users -------------------
            # Unauthorized users are routed through SalesAgent funnel instead
            # of receiving the generic access-denied block message.
            if not self._is_authorized(uid):
                text_raw = (update.message.text or "").strip()
                if not text_raw:
                    return

                # Log new leads to JSONL
                _is_new_lead = False
                try:
                    import json as _json, time as _time
                    from pathlib import Path as _Path
                    _leads_path = "/root/my_personal_ai/data/sales_leads.jsonl"
                    _existing_ids: set = set()
                    if _Path(_leads_path).exists():
                        for _ln in _Path(_leads_path).read_text(encoding="utf-8").splitlines():
                            _ln = _ln.strip()
                            if _ln:
                                try:
                                    _existing_ids.add(_json.loads(_ln).get("user_id"))
                                except Exception:
                                    pass
                    _is_new_lead = uid not in _existing_ids
                    if _is_new_lead:
                        with open(_leads_path, "a", encoding="utf-8") as _lf:
                            _lf.write(_json.dumps({
                                "ts":        _time.time(),
                                "user_id":   uid,
                                "username":  getattr(user, "username", "") or "",
                                "full_name": getattr(user, "full_name", "") or "",
                                "first_msg": text_raw[:500],
                                "chat_id":   update.effective_chat.id,
                            }, ensure_ascii=False) + "\n")
                        log.info("[SalesLead] New lead uid=%d @%s: %s", uid,
                                 getattr(user, "username", "?") or "?", text_raw[:80])
                except Exception as _le:
                    log.warning("[SalesLead] Lead log error: %s", _le)

                # Route through SalesAgent
                sales_reply = ""
                try:
                    import sys as _sys
                    _aib = "/root/autonomous-ai-business"
                    if _aib not in _sys.path:
                        _sys.path.insert(0, _aib)
                    from aib_loader import get_sales_agent
                    _handle = get_sales_agent()
                    _loop = asyncio.get_running_loop()
                    _result = await asyncio.wait_for(
                        _loop.run_in_executor(
                            None,
                            lambda: _handle(
                                lead_id=str(uid),
                                message=text_raw,
                                channel="telegram",
                                name=(
                                    getattr(user, "full_name", "")
                                    or getattr(user, "first_name", "")
                                    or "Lead"
                                ),
                            )
                        ),
                        timeout=45,
                    )
                    if isinstance(_result, dict):
                        sales_reply = _result.get("response", "")
                    else:
                        sales_reply = str(_result)
                except Exception as _se:
                    log.warning("[SalesLead] SalesAgent error uid=%d: %s", uid, _se)
                    # Graceful fallback via /api/chat
                    try:
                        import urllib.request as _ur, json as _js
                        _payload = _js.dumps({
                            "message": text_raw,
                            "context": "sales_lead",
                            "from_id": str(uid),
                        }).encode()
                        _req = _ur.Request(
                            "http://localhost:8080/api/chat",
                            data=_payload,
                            headers={"Content-Type": "application/json"},
                        )
                        with _ur.urlopen(_req, timeout=25) as _r:
                            _d = _js.loads(_r.read())
                        sales_reply = _d.get("response") or _d.get("reply") or ""
                    except Exception as _fe:
                        log.error("[SalesLead] Fallback /api/chat error: %s", _fe)

                if not sales_reply:
                    sales_reply = (
                        "Thanks for reaching out! "
                        "Tell me a bit about what you're looking for and I'll be happy to help."
                    )

                await _typing(update, context)
                await update.message.reply_text(sales_reply, parse_mode=None)

                # Notify owner about a brand-new lead
                if self._owner_id and _is_new_lead:
                    try:
                        await context.bot.send_message(
                            chat_id=self._owner_id,
                            text=(
                                f"\U0001f4e5 <b>New Sales Lead</b>\n"
                                f"ID: <code>{uid}</code>\n"
                                f"Name: {getattr(user, 'full_name', '') or chr(8212)}\n"
                                f"@{getattr(user, 'username', '') or chr(8212)}\n"
                                f"First message: {text_raw[:200]}"
                            ),
                            parse_mode="HTML",
                        )
                    except Exception:
                        pass
                return
            # -- End sales lead routing --------------------------------------

            text = update.message.text.strip()
            if not text:
                return
            self._db.bump_seen(uid)

            # Сохранить в память
            try:
                self._memory.add_message(Message(
                    role="user", content=text,
                    source="telegram", session_id=str(uid)
                ))
            except Exception:
                pass

            log.info("MSG uid=%d @%s: %s",
                     uid, getattr(user, "username", "?") or "?", text[:100])
            await _typing(update, context)
            await _process_message(update, context, text)

        async def _process_message(update: Update, context,
                                    text: str) -> None:
            """Обработать текст через мозг и ответить."""
            uid = update.effective_user.id
            if self._brain_callback:
                try:
                    from brain.orchestrator import OrchestratorRequest
                    req = OrchestratorRequest(
                        text=text, source="telegram",
                        session_id=str(uid), user_id=str(uid),
                    )
                    loop = asyncio.get_running_loop()
                    response = await asyncio.wait_for(
                        loop.run_in_executor(None, self._brain_callback, req),
                        timeout=120
                    )
                    reply_text = response.text if response else "Нет ответа"
                except asyncio.TimeoutError:
                    reply_text = (
                        "⏳ Обработка заняла >120с. "
                        "Попробуй упростить вопрос или напиши ещё раз."
                    )
                    log.warning("Brain timeout uid=%d text=%r", uid, text[:60])
                except Exception as e:
                    log.error("Brain error uid=%d: %s", uid, e, exc_info=True)
                    reply_text = f"❌ Ошибка: {type(e).__name__}: {str(e)[:200]}"
            else:
                reply_text = "⚠️ Мозг не подключён. Перезапусти сервис."

            await _reply(update, reply_text)

            try:
                self._memory.add_message(Message(
                    role="assistant", content=reply_text,
                    source="telegram", session_id=str(uid)
                ))
            except Exception:
                pass

        # ── Сборка приложения ─────────────────────────────────────────────────

        async def _run_async() -> None:
            # ── SSL fix для Windows (антивирус/корп-прокси перехватывают TLS) ─
            # Стратегия (в порядке приоритета):
            #   1. Windows cert store (load_default_certs) — корп. CA уже там
            #   2. verify=False — если и Windows store не помогает
            #   3. Дефолт — для Linux/Mac где нет этой проблемы
            import ssl as _ssl
            import httpx as _httpx

            def _make_ssl_context() -> "_ssl.SSLContext | bool":
                """Вернуть SSL контекст или False (verify=False) или True (default)."""
                # Попытка 1: certifi (стандартный пакет с CA)
                try:
                    import certifi
                    _httpx.get("https://api.telegram.org", timeout=3,
                               verify=certifi.where())
                    log.debug("SSL: certifi OK")
                    return certifi.where()     # строка-путь, httpx принимает это
                except Exception:
                    pass

                # Попытка 2: Windows системное хранилище сертификатов
                try:
                    win_ctx = _ssl.SSLContext(_ssl.PROTOCOL_TLS_CLIENT)
                    win_ctx.load_default_certs()   # Windows cert store (есть корп. CA)
                    win_ctx.check_hostname = True
                    win_ctx.verify_mode    = _ssl.CERT_REQUIRED
                    _httpx.get("https://api.telegram.org", timeout=3,
                               verify=win_ctx)
                    log.info("SSL: using Windows system cert store")
                    return win_ctx
                except Exception:
                    pass

                # Попытка 3: verify=False (последний резерв)
                try:
                    import urllib3
                    urllib3.disable_warnings()
                except Exception:
                    pass
                _ssl._create_default_https_context = _ssl._create_unverified_context
                log.warning("SSL: verify=False (Windows TLS interception, no CA found)")
                return False

            _ssl_verify = _make_ssl_context()   # str | SSLContext | bool

            # ── Создать Application с правильным SSL для ОБОИХ request handlers ─
            # PTB использует два отдельных httpx клиента:
            #   .request()            → обычные API вызовы (get_me, send_message...)
            #   .get_updates_request()→ polling get_updates (ОТДЕЛЬНЫЙ клиент!)
            # Нужно патчить ОБА, иначе polling будет падать с SSL.
            try:
                from telegram.request import HTTPXRequest

                def _make_req(pool_size: int = 8) -> HTTPXRequest:
                    return HTTPXRequest(
                        connection_pool_size=pool_size,
                        http_version="1.1",
                        httpx_kwargs={"verify": _ssl_verify},
                    )

                _req          = _make_req(pool_size=8)   # для обычных запросов
                _req_polling  = _make_req(pool_size=4)   # для get_updates polling

                builder = (
                    Application.builder()
                    .token(cfg.telegram_token)
                    .request(_req)
                    .get_updates_request(_req_polling)   # ← ключевой фикс!
                )
                app = builder.build()
                log.info("Telegram: dual HTTPXRequest built (verify=%s)",
                         type(_ssl_verify).__name__)
            except Exception as _build_err:
                log.warning("Custom request build failed (%s), fallback default", _build_err)
                app = Application.builder().token(cfg.telegram_token).build()
            self._application = app
            app_holder[0] = app  # make available to ResilientBot send fn
