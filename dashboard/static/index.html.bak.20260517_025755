            {healthData.ok ? '\u2705' : '\u26A0\uFE0F'} \u0421\u0430\u043C\u043E\u0434\u0438\u0430\u0433\u043D\u043E\u0441\u0442\u0438\u043A\u0430
            <span style={{fontWeight:400, fontSize:11, color:'var(--text2)', marginLeft:8}}>
              \u0438\u0441\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0439: {healthData.fixes_applied||0}
            </span>
          </div>
          {Object.entries(healthData.details||{}).map(([check, res]) => (
            <div key={check} style={{fontSize:12, display:'flex', gap:8, padding:'3px 0', color:'var(--text)'}}>
              <span>{res.ok ? '\u2705' : '\u274C'}</span>
              <span style={{color:'var(--text2)'}}>{check}</span>
              {res.error && <span style={{color:'#ef4444'}}>{res.error}</span>}
              {res.used_pct !== undefined && <span style={{color:'#d29922'}}>\u0434\u0438\u0441\u043A {res.used_pct}%</span>}
            </div>
          ))}
        </div>
      )}
    </div>
  );
}


// ============================================================
// AUTONOMOUS SALES AGENT TAB
// ============================================================
function SalesTab() {
  const [sessions, setSessions]   = React.useState({stats:{}, revenue:{}, active_leads:[]});
  const [chatLead, setChatLead]   = React.useState('');
  const [chatMsg, setChatMsg]     = React.useState('');
  const [chatResp, setChatResp]   = React.useState(null);
  const [sending, setSending]     = React.useState(false);
  const [selLead, setSelLead]     = React.useState(null);
  const [newDialog, setNewDialog] = React.useState(false);
  const [newLeadName, setNewLeadName] = React.useState('');
  const [startingLead, setStartingLead] = React.useState(false);

  React.useEffect(() => {
    loadSessions();
    const iv = setInterval(loadSessions, 15000);
    return () => clearInterval(iv);
  }, []);

  function loadSessions() {
    apiFetch('/api/sales/sessions').then(r => { if (r.ok) setSessions(r.data); });
  }

  async function sendMsg() {
    if (!chatLead || !chatMsg) return;
    setSending(true);
    const r = await apiFetch('/api/sales/message', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({lead_id: chatLead, message: chatMsg, channel: 'chat'})
    });
    if (r.ok) setChatResp(r.data);
    setSending(false);
    setChatMsg('');
    loadSessions();
  }

  async function startNewLead() {
    if (!newLeadName.trim()) return;
    setStartingLead(true);
    const leadId = 'lead_' + Date.now();
    const r = await apiFetch('/api/sales/message', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({lead_id: leadId, message: `\u041F\u0440\u0438\u0432\u0435\u0442, \u043C\u0435\u043D\u044F \u0437\u043E\u0432\u0443\u0442 ${newLeadName}`, channel: 'chat'})
    });
    setStartingLead(false);
    if (r.ok) {
      setChatLead(leadId);
      setChatResp(r.data);
      setNewDialog(false);
      setNewLeadName('');
      loadSessions();
    }
  }

  async function loadLead(id) {
    const r = await apiFetch('/api/sales/session/' + id);
    if (r.ok) setSelLead(r.data);
  }

  const PIPELINE_STAGES = [
    { key: 'discovery',           label: 'DISCOVERY',            color: '#6b7280', icon: '\uD83D\uDD0D' },
    { key: 'qualification',       label: 'QUALIFICATION',        color: '#58a6ff', icon: '\uD83D\uDCCB' },
    { key: 'value_presentation',  label: 'VALUE PRESENTATION',   color: '#d29922', icon: '\uD83D\uDCA1' },
    { key: 'objection_handling',  label: 'OBJECTION HANDLING',   color: '#f0883e', icon: '\uD83D\uDEE1\uFE0F' },
    { key: 'closing',             label: 'CLOSING',              color: '#3fb950', icon: '\uD83E\uDD1D' },
    { key: 'invoice_sent',        label: 'INVOICE SENT',         color: '#bc8cff', icon: '\uD83D\uDCC4' },
  ];

  const STAGE_COLORS = {
    discovery: '#6b7280', qualification: '#58a6ff', value_presentation: '#d29922',
    objection_handling: '#f0883e', closing: '#3fb950', invoice_generated: '#bc8cff',
    invoice_sent: '#bc8cff', payment_confirmed: '#10b981', lost: '#ef4444', human_required: '#ef4444'
  };

  const STAGE_LABELS = {
    discovery: 'Discovery', qualification: 'Qualification', value_presentation: 'Value Presentation',
    objection_handling: 'Objection Handling', closing: 'Closing', invoice_generated: 'Invoice Sent',
    invoice_sent: 'Invoice Sent', payment_confirmed: '\u041E\u043F\u043B\u0430\u0447\u0435\u043D\u043E', lost: '\u041F\u043E\u0442\u0435\u0440\u044F\u043D', human_required: '\u041D\u0443\u0436\u0435\u043D \u0447\u0435\u043B\u043E\u0432\u0435\u043A'
  };

  const rev = sessions.revenue || {};
  const stats = sessions.stats || {};
  const activeLeads = sessions.active_leads || [];

  // Count leads per stage
  const stageCounts = {};
  PIPELINE_STAGES.forEach(s => { stageCounts[s.key] = 0; });
  activeLeads.forEach(l => {
    const k = l.stage;
    if (stageCounts[k] !== undefined) stageCounts[k]++;
    else stageCounts[k] = (stageCounts[k]||0) + 1;
  });

  return (
    <div>
      <div style={{display:'flex', justifyContent:'space-between', alignItems:'center', marginBottom:16}}>
        <div className="tab-title" style={{marginBottom:0}}>\uD83D\uDCB8 \u041F\u0440\u043E\u0434\u0430\u0436\u0438 \u2014 \u0412\u043E\u0440\u043E\u043D\u043A\u0430 \u043B\u0438\u0434\u043E\u0432</div>
        <div style={{display:'flex', gap:8}}>
          <button className="btn btn-primary" onClick={() => setNewDialog(!newDialog)}>
            {newDialog ? '\u2715 \u041E\u0442\u043C\u0435\u043D\u0430' : '+ \u041D\u043E\u0432\u044B\u0439 \u0434\u0438\u0430\u043B\u043E\u0433'}
          </button>
        </div>
      </div>

      {/* New dialog form */}
      {newDialog && (
        <div className="card" style={{marginBottom:16, borderLeft:'3px solid var(--accent)'}}>
          <div className="section-title">\u041D\u0430\u0447\u0430\u0442\u044C \u043D\u043E\u0432\u044B\u0439 \u0434\u0438\u0430\u043B\u043E\u0433 \u0441 \u043B\u0438\u0434\u043E\u043C</div>
          <div style={{display:'flex', gap:8}}>
            <input
              className="input flex-1"
              placeholder="\u0418\u043C\u044F \u0438\u043B\u0438 ID \u043B\u0438\u0434\u0430..."
              value={newLeadName}
              onChange={e => setNewLeadName(e.target.value)}
              onKeyDown={e => { if (e.key === 'Enter') startNewLead(); }}
              autoFocus
            />
            <button className="btn btn-primary" onClick={startNewLead} disabled={startingLead || !newLeadName.trim()}>
              {startingLead ? '\u23F3...' : '\u25B6 \u0417\u0430\u043F\u0443\u0441\u0442\u0438\u0442\u044C \u043F\u0440\u043E\u0434\u0430\u0436\u0443'}
            </button>
          </div>
        </div>
      )}

      {/* KPIs */}
      <div className="grid-4" style={{marginBottom:16}}>
        <MetricCard title="\u0412\u044B\u0440\u0443\u0447\u043A\u0430" value={'$' + (rev.total_revenue_usd||0).toFixed(2)} sub="\u041F\u043E\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0451\u043D\u043D\u0430\u044F" />
        <MetricCard title="Pipeline" value={'$' + (rev.pending_pipeline_usd||0).toFixed(2)} sub="\u0412 \u0440\u0430\u0431\u043E\u0442\u0435" />
        <MetricCard title="\u0412\u0441\u0435\u0433\u043E \u043B\u0438\u0434\u043E\u0432" value={stats.total_leads||0} sub="\u0412\u0441\u0435\u0433\u043E \u0437\u0430\u0432\u0435\u0434\u0435\u043D\u043E" />
        <MetricCard title="\u0410\u043A\u0442\u0438\u0432\u043D\u044B\u0445" value={activeLeads.length} sub="\u0412 \u0432\u043E\u0440\u043E\u043D\u043A\u0435 \u0441\u0435\u0439\u0447\u0430\u0441" />
      </div>

      {/* Pipeline stages */}
      <div className="section-title" style={{marginBottom:10}}>\u0412\u043E\u0440\u043E\u043D\u043A\u0430 \u043F\u0440\u043E\u0434\u0430\u0436</div>
      <div style={{display:'flex', gap:6, marginBottom:20, overflowX:'auto', paddingBottom:4}}>
        {PIPELINE_STAGES.map((stage, i) => (
          <div key={stage.key} style={{
            flex:'1 1 120px', minWidth:110, background:'var(--bg2)',
            border:`1px solid ${stage.color}44`, borderTop:`3px solid ${stage.color}`,
            borderRadius:8, padding:'10px 12px', textAlign:'center'
          }}>
            <div style={{fontSize:18, marginBottom:4}}>{stage.icon}</div>
            <div style={{fontSize:10, color:'var(--text2)', fontWeight:600, marginBottom:6, lineHeight:1.3}}>
              {stage.label}
            </div>
            <div style={{fontSize:22, fontWeight:700, color: stageCounts[stage.key] > 0 ? stage.color : 'var(--text2)'}}>
              {stageCounts[stage.key] || 0}
            </div>
            <div style={{fontSize:10, color:'var(--text2)'}}>\u043B\u0438\u0434\u043E\u0432</div>
            {i < PIPELINE_STAGES.length - 1 && (
              <div style={{fontSize:12, color:'var(--text2)', marginTop:4}}>\u2192</div>
            )}
          </div>
        ))}
      </div>

      {/* Simulator + Leads list */}
      <div className="grid-2" style={{marginBottom:16}}>
        <div className="card">
          <div className="section-title">\uD83E\uDD16 \u0421\u0438\u043C\u0443\u043B\u044F\u0442\u043E\u0440 \u0434\u0438\u0430\u043B\u043E\u0433\u0430</div>
          <input
            className="input"
            style={{marginBottom:8}}
            value={chatLead}
            onChange={e=>setChatLead(e.target.value)}
            placeholder="ID \u043B\u0438\u0434\u0430 (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440: lead_001)"
          />
          <textarea
            className="input"
            value={chatMsg}
            onChange={e=>setChatMsg(e.target.value)}
            rows={3}
            placeholder="\u0421\u043E\u043E\u0431\u0449\u0435\u043D\u0438\u0435 \u043E\u0442 \u043B\u0438\u0434\u0430..."
            style={{marginBottom:8, resize:'vertical'}}
          />
          <button
            className="btn btn-primary"
            onClick={sendMsg}
            disabled={sending || !chatLead || !chatMsg}
            style={{width:'100%'}}
          >
            {sending ? '\u23F3 \u041E\u0431\u0440\u0430\u0431\u0430\u0442\u044B\u0432\u0430\u0435\u0442\u0441\u044F...' : '\u25B6 \u041E\u0442\u043F\u0440\u0430\u0432\u0438\u0442\u044C \u0430\u0433\u0435\u043D\u0442\u0443'}
          </button>
          {chatResp && (
            <div style={{marginTop:10, padding:10, background:'var(--bg2)', borderRadius:8, borderLeft:'3px solid #10b981'}}>
              <div style={{fontSize:11, color:'#10b981', marginBottom:4, fontWeight:600}}>
                \u0421\u0442\u0430\u0434\u0438\u044F: {STAGE_LABELS[chatResp.stage] || chatResp.stage}
              </div>
              <div style={{fontSize:12, color:'var(--text)', lineHeight:1.5}}>{chatResp.response}</div>
              {chatResp.human_flag && (
                <div style={{color:'#ef4444', marginTop:6, fontSize:12, fontWeight:600}}>
                  \u26A0\uFE0F {chatResp.flag || '\u0422\u0440\u0435\u0431\u0443\u0435\u0442\u0441\u044F \u0443\u0447\u0430\u0441\u0442\u0438\u0435 \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430'}
                </div>
              )}
            </div>
          )}
        </div>

        <div className="card" style={{padding:0, overflow:'hidden'}}>
          <div style={{padding:'12px 14px', borderBottom:'1px solid var(--border)'}}>
            <span className="section-title" style={{marginBottom:0}}>\uD83D\uDC65 \u0410\u043A\u0442\u0438\u0432\u043D\u044B\u0435 \u043B\u0438\u0434\u044B</span>
          </div>
          <div style={{maxHeight:320, overflowY:'auto'}}>
            {activeLeads.map(lead => (
              <div
                key={lead.lead_id}
                onClick={()=>loadLead(lead.lead_id)}
                style={{
                  padding:'10px 14px', borderBottom:'1px solid var(--border)', cursor:'pointer',
                  borderLeft:`3px solid ${STAGE_COLORS[lead.stage]||'#6b7280'}`,
                  transition:'background 0.15s'
                }}
                onMouseEnter={e => e.currentTarget.style.background='var(--bg2)'}
                onMouseLeave={e => e.currentTarget.style.background='transparent'}
              >
                <div style={{display:'flex', justifyContent:'space-between', marginBottom:3}}>
                  <span style={{fontWeight:600, fontSize:13, color:'var(--text)'}}>{lead.name||lead.lead_id}</span>
                  <span style={{
                    fontSize:10, padding:'2px 7px', borderRadius:20,
                    background:(STAGE_COLORS[lead.stage]||'#6b7280')+'22',
                    color:STAGE_COLORS[lead.stage]||'#6b7280', fontWeight:600
                  }}>
                    {STAGE_LABELS[lead.stage] || lead.stage}
                  </span>
                </div>
                <div style={{fontSize:11, color:'var(--text2)'}}>
                  \u0411\u044E\u0434\u0436\u0435\u0442: ${lead.budget||0} | \u0421\u0447\u0451\u0442: ${lead.invoice||0}
                  {lead.paid && <span style={{color:'#10b981', marginLeft:8}}>\u2705 \u041E\u043F\u043B\u0430\u0447\u0435\u043D\u043E</span>}
                </div>
              </div>
            ))}
            {!activeLeads.length && <div className="empty-state">\u041D\u0435\u0442 \u0430\u043A\u0442\u0438\u0432\u043D\u044B\u0445 \u043B\u0438\u0434\u043E\u0432</div>}
          </div>
        </div>
      </div>

      {/* Lead detail */}
      {selLead && (
        <div className="card" style={{borderLeft:'3px solid #d29922'}}>
          <div style={{display:'flex', justifyContent:'space-between', alignItems:'center', marginBottom:10}}>
            <div className="section-title" style={{marginBottom:0}}>\uD83D\uDCC4 \u0421\u0435\u0441\u0441\u0438\u044F: {selLead.lead?.lead_id}</div>
            <button className="btn" onClick={()=>setSelLead(null)} style={{padding:'2px 10px'}}>\u2715</button>
          </div>
          <div style={{display:'grid', gridTemplateColumns:'1fr 1fr', gap:8, fontSize:12, marginBottom:10}}>
            <div><span style={{color:'var(--text2)'}}>\u0421\u0442\u0430\u0434\u0438\u044F: </span><span style={{color:'#d29922', fontWeight:600}}>{STAGE_LABELS[selLead.stage]||selLead.stage}</span></div>
            <div><span style={{color:'var(--text2)'}}>\u0411\u044E\u0434\u0436\u0435\u0442: </span><span style={{color:'#58a6ff'}}>${selLead.lead?.budget_capacity||0}</span></div>
            <div><span style={{color:'var(--text2)'}}>\u041F\u0440\u043E\u0431\u043B\u0435\u043C\u0430: </span>{selLead.lead?.pain_point||'N/A'}</div>
            <div><span style={{color:'var(--text2)'}}>\u0421\u0447\u0451\u0442: </span>${selLead.invoice_amount||0}</div>
          </div>
          <div style={{maxHeight:200, overflowY:'auto'}}>
            {(selLead.history||[]).slice(-8).reverse().map((h, i) => (
              <div key={i} style={{padding:'5px 0', borderBottom:'1px solid var(--border)', fontSize:11}}>
                <span style={{color: h.role==='agent'?'#3fb950':'#58a6ff', fontWeight:600, marginRight:6}}>
                  {h.role === 'agent' ? '\uD83E\uDD16 \u0410\u0433\u0435\u043D\u0442' : '\uD83D\uDC64 \u041B\u0438\u0434'}:
                </span>
                <span style={{color:'var(--text)'}}>{(h.content||'').slice(0,160)}</span>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  );
}


