//  МОДЕЛИ ИИ
// ═══════════════════════════════════════════════════════════════════════════
async function loadLLM() {
  const [llm,st] = await Promise.all([api('/api/llm'), api('/api/status')]);
  if (!llm) { $('llm-prov').innerHTML='<div class="alert alert-r">Нет данных о моделях</div>'; return; }

  const provs = Object.entries(llm);
  const active = provs.filter(([,v])=>v&&(typeof v!=='object'||v.available!==false)).length;
  $('llm-kpis').innerHTML = [
    statCard(provs.length,'Провайдеров','',''),
    statCard(active,'Активных','','stat-grn'),
    statCard(st?('$'+(+(st.daily_cost_usd||0)).toFixed(4)):'—','Расходы сегодня',''),
    statCard(st?(st.groq_only_mode?'ВКЛ':'ВЫКЛ'):'—','Режим Groq-only',st&&st.groq_only_mode?'экономия токенов':'',''),
  ].join('');

  const provRu = {openai:'OpenAI',anthropic:'Anthropic',groq:'Groq',together:'Together AI',cohere:'Cohere'};
  $('llm-prov').innerHTML = provs.map(([name,v]) => {
    if (!v||typeof v!=='object') return `<div class="row"><span class="row-left">${dot(false)}<span>${esc(provRu[name]||name)}</span></span>${bdg('N/A','y')}</div>`;
    const ok = v.available!==false && !v.error && !v.tokens_exhausted && !v.rate_limited;
    const issue = v.tokens_exhausted?'лимит токенов':v.rate_limited?'rate limit':v.error?'ошибка':'';
    const model = v.model||v.models?.[0]||'';
    return `<div class="row">
      <span class="row-left">${dot(ok)}<span style="font-weight:600">${esc(provRu[name]||name)}</span>${model?`<span style="font-size:10px;color:var(--txt3);margin-left:4px">${esc(String(model).slice(0,25))}</span>`:''}</span>
      <div style="display:flex;gap:6px;align-items:center">
        ${issue?bdg(issue,'r'):''}
        ${bdg(ok?'OK':'ОШИБКА',ok?'g':'r')}
      </div>
    </div>`;
  }).join('');

  if (st) {
    $('llm-sys').innerHTML = [
      ['Расходы сегодня','$'+(+(st.daily_cost_usd||0)).toFixed(4)],
      ['Лимит расходов','$'+(st.cost_limit_usd||0)],
      ['Режим Groq-only',st.groq_only_mode?'ВКЛЮЧЁН':'ВЫКЛЮЧЕН'],
      ['Автономный режим',st.autonomy_enabled?'включён':'выключен'],
      ['Уровень защиты',st.guardrail_level||0],
      ['Brain',st.brain||'?'],
      ['Watchdog',st.watchdog||'?'],
    ].map(([l,v]) => `<div class="row"><span class="row-left">${esc(l)}</span><span style="color:var(--acc);font-weight:600">${esc(String(v))}</span></div>`).join('');
  }
}

// ═══════════════════════════════════════════════════════════════════════════
//  ЧАТ
// ═══════════════════════════════════════════════════════════════════════════
function appendMsg(text, isUser) {
  const box = $('chat-box');
  const div = document.createElement('div');
  div.className = isUser?'msg-user':'msg-ai';
  const time = new Date().toLocaleTimeString('ru-RU');
  if (isUser) {
    div.innerHTML = esc(text)+'<div class="msg-time">'+time+'</div>';
  } else {
    div.innerHTML = '<pre>'+esc(text)+'</pre><div class="msg-time">'+time+'</div>';
  }
  box.appendChild(div);
  box.scrollTop = box.scrollHeight;
  return div;
}

async function sendChat() {
  const inp=$('chat-inp'), msg=inp.value.trim();
  if (!msg) return;
  inp.value='';
  appendMsg(msg, true);
  const btn=$('chat-btn');
  btn.disabled=true; btn.textContent='...';
  const thinking=appendMsg('Думаю...', false);
  const r = await api('/api/chat',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({message:msg,source:'panel'})});
  thinking.remove();
  btn.disabled=false; btn.textContent='Отправить';
  appendMsg(r?(r.reply||r.response||r.text||JSON.stringify(r)):'Нет ответа от сервера', false);
}

function quickChat(msg) { $('chat-inp').value=msg; sendChat(); }

// ═══════════════════════════════════════════════════════════════════════════
//  ЛОГИ
// ═══════════════════════════════════════════════════════════════════════════
async function loadLogs() {
  const file=$('log-file').value, lines=$('log-lines').value||100;
  $('log-name-fb').textContent = '↻ ' + file;
  const d = await api('/api/logs?file='+encodeURIComponent(file)+'&lines='+lines);
  const el=$('log-out');
  if (!d||!d.lines) { el.textContent='Нет данных для файла: '+file; return; }
  el.textContent = d.lines.join('\n') || 'Лог пустой';
  el.scrollTop = el.scrollHeight;
  $('log-name-fb').textContent = file + ' (' + (d.lines.length||0) + ' строк)';
}

function toggleAutolog() {
  const btn=$('autolog-btn');
  if (autologT) {
    clearInterval(autologT); autologT=null;
    btn.textContent='▶ Авто';
    btn.classList.remove('btn-g');
  } else {
    loadLogs();
    autologT=setInterval(loadLogs,3000);
    btn.textContent='⏸ Стоп';
    btn.classList.add('btn-g');
  }
}

// ─── Utility ───────────────────────────────────────────────────────────────
function showNoData(ids) { ids.forEach(id=>{ const el=$(id); if(el)el.innerHTML='<div class="alert alert-y">⚠ Нет данных</div>'; }); }

// ═══════════════════════════════════════════════════════════════════════════
//  BROWSER CONTROL v2
// ═══════════════════════════════════════════════════════════════════════════
let _brToken = '';
let _brAutoT = null;

function _brLog(msg, ok) {
  const el = $('br-log');
  if (!el) return;
  const t = new Date().toLocaleTimeString();
  const c = (ok===false) ? 'var(--red)' : 'var(--grn)';
  el.innerHTML += '<div style="color:'+c+'">['+t+'] '+String(msg).replace(/</g,'&lt;')+'</div>';
  el.scrollTop = el.scrollHeight;
}

function _brStateColor(s) {
  const m = {INIT:'#6366f1',READY:'#22c55e',AI_ACTIVE:'#0ea5e9',
    HUMAN_PENDING:'#f59e0b',HUMAN_ACTIVE:'#f97316',RECONCILING:'#8b5cf6',
    RECOVERY:'#ec4899',SAFE_MODE:'#ef4444',QUARANTINED:'#dc2626',TERMINATED:'#374151'};
  return m[s]||'#64748b';
}

async function loadBrowser() {
  // State
  try {
    const d = await api('/api/browser/v2/state');
    if (!d) return;
    const sc = $('br-state-chip'); const oc = $('br-owner-chip');
    if (sc) { sc.textContent = d.state||'UNKNOWN'; sc.style.background = _brStateColor(d.state); sc.style.color='#fff'; sc.style.border='none'; }
    if (oc && d.lease) { oc.textContent = d.lease.owner||'no owner'; oc.style.color = (d.lease.owner&&d.lease.owner!=='none') ? 'var(--yel)' : 'var(--txt3)'; }
  } catch(e) {}
  // Screenshot
  try {
    const d2 = await api('/api/browser/v2/screenshot');
    const img = $('br-screenshot'); const ns = $('br-no-screen');
    if (d2&&d2.ok&&d2.image_b64&&img) {
      img.src='data:image/png;base64,'+d2.image_b64; img.style.opacity='1';
      if (ns) ns.style.display='none';
    }
    if (d2&&d2.url) { const u=$('br-current-url'); if(u) u.textContent=d2.url; }
  } catch(e) {}
  // Checkpoints
  try {
    const d3 = await api('/api/browser/v2/checkpoints');
    const el = $('br-checkpoints-list');
    if (el&&d3&&d3.checkpoints) {
      if (!d3.checkpoints.length) { el.textContent='нет чекпоинтов'; return; }
      el.innerHTML = d3.checkpoints.map(cp=>'<div style="padding:2px 0;border-bottom:1px solid var(--brd)"><span style="color:var(--acc)">'+
        (cp.id||'?')+'</span> <span style="color:var(--txt3)">'+(cp.url||'')+'</span></div>').join('');
    }
  } catch(e) {}
}

async function browserStart() {
  try {
    const d = await api('/api/browser/v2/start','POST',{});
    _brLog('Start: '+JSON.stringify(d), d&&d.ok);
    await loadBrowser();
    if (!_brAutoT) _brAutoT = setInterval(loadBrowser, 5000);
  } catch(e) { _brLog('Start error: '+e, false); }
}

async function browserStop() {
  try {
    const d = await api('/api/browser/v2/stop','POST',{fencing_token:_brToken});
    _brLog('Stop: '+JSON.stringify(d), d&&d.ok);
    if (_brAutoT) { clearInterval(_brAutoT); _brAutoT=null; }
    await loadBrowser();
  } catch(e) { _brLog('Stop error: '+e, false); }
}

async function browserAcquireLease() {
  try {
    const d = await api('/api/browser/v2/lease/acquire','POST',{owner:'panel'});
    if (d&&d.fencing_token) { _brToken=d.fencing_token; const el=$('br-token-display'); if(el)el.textContent=_brToken; }
    _brLog('Lease: '+JSON.stringify(d), d&&d.ok);
  } catch(e) { _brLog('Lease error: '+e, false); }
}

async function browserReleaseLease() {
  try {
    const d = await api('/api/browser/v2/lease/release','POST',{fencing_token:_brToken});
    _brLog('Release: '+JSON.stringify(d), d&&d.ok);
    _brToken=''; const el=$('br-token-display'); if(el)el.textContent='—';
  } catch(e) { _brLog('Release error: '+e, false); }
}

async function browserNavigate() {
  const url=($('br-url-input')||{}).value||''; if(!url) return;
  try {
    const d = await api('/api/browser/v2/action','POST',{fencing_token:_brToken,action:'navigate',params:{url}});
    _brLog('Navigate '+url+': stage='+d.stage, d&&d.ok);
    setTimeout(loadBrowser,1200);
  } catch(e) { _brLog('Navigate error: '+e, false); }
}

async function browserExecuteAction() {
  const action=($('br-action-select')||{}).value||'inspect';
  let params={};
  try { params=JSON.parse(($('br-action-params')||{}).value||'{}'); } catch(e) {}
  try {
    const d = await api('/api/browser/v2/action','POST',{fencing_token:_brToken,action,params});
    _brLog(action+': '+JSON.stringify(d).slice(0,220), d&&d.ok);
    if (['navigate','click','type','scroll'].includes(action)) setTimeout(loadBrowser,800);
  } catch(e) { _brLog(action+' error: '+e, false); }
}

async function browserTakeoverRequest() {
  try {
    const d = await api('/api/browser/v2/takeover/request','POST',{fencing_token:_brToken});
    _brLog('Takeover req: '+JSON.stringify(d), d&&d.ok); await loadBrowser();
  } catch(e) { _brLog('Takeover error: '+e, false); }
}

async function browserTakeoverRelease() {
  try {
    const d = await api('/api/browser/v2/takeover/release','POST',{corrections:[]});
    _brLog('Takeover release: '+JSON.stringify(d), d&&d.ok); await loadBrowser();
  } catch(e) { _brLog('Release error: '+e, false); }
}

async function browserReconcile() {
  try {
    const d = await api('/api/browser/v2/reconcile','POST',{fencing_token:_brToken});
    _brLog('Reconcile: '+JSON.stringify(d), d&&d.ok);
  } catch(e) { _brLog('Reconcile error: '+e, false); }
}

async function browserRecover() {
  try {
    const d = await api('/api/browser/v2/recover','POST',{checkpoint_id:null});
    _brLog('Recover: '+JSON.stringify(d), d&&d.ok); await loadBrowser();
  } catch(e) { _brLog('Recover error: '+e, false); }
}

// ─── Init ──────────────────────────────────────────────────────────────────
go('dash');
</script>
</body>
</html>
