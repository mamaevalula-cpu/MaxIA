// ============================================================
// AUTONOMOUS AI BUSINESS SYSTEM TAB
// ============================================================
function BusinessTab() {
  const [status, setStatus] = React.useState(null);
  const [projects, setProjects] = React.useState({});
  const [trends, setTrends] = React.useState({trends:[], niches:[]});
  const [events, setEvents] = React.useState([]);
  const [running, setRunning] = React.useState(false);
  const [looping, setLooping] = React.useState(false);
  const [healthData, setHealthData] = React.useState(null);
  const [analyzing, setAnalyzing] = React.useState(false);
  const [analysisResult, setAnalysisResult] = React.useState(null);

  React.useEffect(() => {
    loadAll();
    const iv = setInterval(loadAll, 15000);
    return () => clearInterval(iv);
  }, []);

  function loadAll() {
    apiFetch('/api/business/status').then(r => { if (r.ok) { setStatus(r.data); setRunning(r.data.running||false); }});
    apiFetch('/api/business/projects').then(r => { if (r.ok) setProjects(r.data.projects||{});});
    apiFetch('/api/business/trends').then(r => { if (r.ok) setTrends(r.data);});
    apiFetch('/api/business/events').then(r => { if (r.ok) setEvents(r.data.events||[]);});
  }

  async function triggerLoop() {
    setLooping(true);
    await apiFetch('/api/business/loop', {method:'POST'});
    setLooping(false);
    loadAll();
  }

  async function toggleOrchestrator() {
    const ep = running ? '/api/business/stop' : '/api/business/start';
    const r = await apiFetch(ep, {method:'POST'});
    if (r.ok) loadAll();
  }

  async function runHealth() {
    const r = await apiFetch('/api/business/health');
    if (r.ok) setHealthData(r.data);
  }

  async function runAnalysis() {
    setAnalyzing(true);
    setAnalysisResult(null);
    const r = await apiFetch('/api/chat', {
      method: 'POST',
      body: JSON.stringify({ message: '\u0437\u0430\u043F\u0443\u0441\u0442\u0438 \u0430\u043D\u0430\u043B\u0438\u0437 \u0431\u0438\u0437\u043D\u0435\u0441-\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u0435\u0439' })
    });
    setAnalyzing(false);
    if (r.ok && r.data) {
      setAnalysisResult(r.data.response || r.data.reply || r.data.message || JSON.stringify(r.data));
    }
  }

  const PROJECT_ICONS = {media_247:'\uD83D\uDCF1', pod_merch:'\uD83D\uDC55', micro_saas:'\uD83D\uDCBB', edtech_gen:'\uD83C\uDF93', fin_agent:'\uD83D\uDCCA'};
  const PROJECT_LABELS = {media_247:'\u041C\u0435\u0434\u0438\u0430 24/7', pod_merch:'POD \u041C\u0435\u0440\u0447', micro_saas:'Micro SaaS', edtech_gen:'EdTech', fin_agent:'\u0424\u0438\u043D. \u0430\u0433\u0435\u043D\u0442'};

  const integrityOk = status?.system_integrity === 'OK';

  return (
    <div>
      <div style={{display:'flex', justifyContent:'space-between', alignItems:'center', marginBottom:16}}>
        <div className="tab-title" style={{marginBottom:0}}>\uD83C\uDFE2 \u0410\u0432\u0442\u043E\u043D\u043E\u043C\u043D\u044B\u0439 \u0431\u0438\u0437\u043D\u0435\u0441-\u0434\u0432\u0438\u0436\u043E\u043A</div>
        <div style={{display:'flex', gap:8, flexWrap:'wrap'}}>
          <button className="btn btn-primary" onClick={runAnalysis} disabled={analyzing}>
            {analyzing ? '\u23F3 \u0410\u043D\u0430\u043B\u0438\u0437\u0438\u0440\u0443\u0435\u0442\u0441\u044F...' : '\uD83D\uDD0D \u0417\u0430\u043F\u0443\u0441\u0442\u0438\u0442\u044C \u0431\u0438\u0437\u043D\u0435\u0441-\u0430\u043D\u0430\u043B\u0438\u0437'}
          </button>
          <button
            className="btn"
            onClick={toggleOrchestrator}
            style={{background: running ? '#ef4444' : '#10b981', color:'#fff', border:'none'}}
          >
            {running ? '\u23F9 \u041E\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u044C' : '\u25B6 \u0417\u0430\u043F\u0443\u0441\u0442\u0438\u0442\u044C \u043E\u0440\u043A\u0435\u0441\u0442\u0440\u0430\u0442\u043E\u0440'}
          </button>
          <button className="btn" onClick={triggerLoop} disabled={looping}>
            {looping ? '\u23F3 \u0422\u0438\u043A...' : '\u21BB \u0420\u0443\u0447\u043D\u043E\u0439 \u0442\u0438\u043A'}
          </button>
          <button className="btn" onClick={runHealth}>\uD83D\uDD27 \u041F\u0440\u043E\u0432\u0435\u0440\u0438\u0442\u044C</button>
        </div>
      </div>

      {/* System status */}
      <div className="grid-4" style={{marginBottom:16}}>
        <MetricCard
          title="\u0421\u0442\u0430\u0442\u0443\u0441 \u0441\u0438\u0441\u0442\u0435\u043C\u044B"
          value={status ? (integrityOk ? '\u2705 OK' : '\u26A0\uFE0F \u041E\u0448\u0438\u0431\u043A\u0430') : '\u2014'}
          sub="\u0426\u0435\u043B\u043E\u0441\u0442\u043D\u043E\u0441\u0442\u044C"
        />
        <MetricCard title="\u041F\u0440\u043E\u0435\u043A\u0442\u044B" value={status?.projects_count ?? 0} sub="\u0430\u043A\u0442\u0438\u0432\u043D\u044B\u0445 \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0439" />
        <MetricCard title="\u0418\u0442\u0435\u0440\u0430\u0446\u0438\u0439" value={status?.loop_count ?? 0} sub="\u0446\u0438\u043A\u043B\u043E\u0432 \u043F\u0440\u043E\u0439\u0434\u0435\u043D\u043E" />
        <MetricCard
          title="\u0410\u043F\u0442\u0430\u0439\u043C"
          value={status ? `${Math.round((status.uptime_s||0)/60)} \u043C\u0438\u043D` : '\u2014'}
          sub={running ? '\u25B6 \u0420\u0430\u0431\u043E\u0442\u0430\u0435\u0442' : '\u23F9 \u041E\u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D'}
        />
      <div className="card" style={{padding:"12px",background:"rgba(99,102,241,0.1)",fontSize:"13px",color:"var(--text2)",marginBottom:"12px"}}>
        💡 Система работает автономно и оптимизирует бизнес-процессы
      </div>
      </div>

      {/* Analysis result */}
      {analysisResult && (
        <div className="card" style={{marginBottom:16, borderLeft:'3px solid var(--accent)'}}>
          <div className="section-title">\uD83D\uDCCB \u0420\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442 \u0430\u043D\u0430\u043B\u0438\u0437\u0430</div>
