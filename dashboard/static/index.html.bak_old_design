function ChatTab() {

  const [messages, setMessages] = useState([]);

  const [input, setInput] = useState('');

  const [loading, setLoading] = useState(false);

  const [model, setModel] = useState('');

  const bottomRef = useRef(null);



  useEffect(() => {

    apiFetch('/api/chat/history').then(r => {

      if (r.ok && r.data) { const arr = Array.isArray(r.data) ? r.data : (r.data.messages || []); setMessages(arr); }

    });

  }, []);



  useEffect(() => {

    bottomRef.current?.scrollIntoView({ behavior: 'smooth' });

  }, [messages, loading]);



  const send = async () => {

    if (!input.trim() || loading) return;

    const userMsg = { role: 'user', content: input.trim(), ts: new Date().toISOString() };

    setMessages(prev => [...prev, userMsg]);

    setInput('');

    setLoading(true);

    const r = await apiFetch('/api/chat', { method: 'POST', body: JSON.stringify({ message: userMsg.content }) });

    setLoading(false);

    if (r.ok && r.data) {

      const reply = {

        role: 'assistant',

        content: r.data.response || r.data.reply || r.data.message || r.data.text || JSON.stringify(r.data),

        model: r.data.model || r.data.provider || '',

        ts: new Date().toISOString(),

      };

      if (reply.model) setModel(reply.model);

      setMessages(prev => [...prev, reply]);

    } else {

      setMessages(prev => [...prev, { role: 'assistant', content: `Ошибка: ${r.error || r.status}`, ts: new Date().toISOString() }]);

    }

  };



  const handleKey = e => { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); send(); } };



  const fmtTime = ts => { try { const d = new Date(ts); return `${String(d.getHours()).padStart(2,'0')}:${String(d.getMinutes()).padStart(2,'0')}`; } catch { return ''; } };



  return (

    <div>

      <div className="tab-title">💬 Чат с ИИ {model && <span style={{fontSize:13,color:'var(--text2)',fontWeight:400}}>— {model}</span>}</div>

      <div className="chat-wrap">

        <div className="chat-messages">

          {messages.length === 0 && !loading && <div className="empty-state">Начните диалог с ИИ</div>}

          {messages.map((m, i) => (

            <div key={i} className={`msg msg-${m.role}`}>

              <div>{m.content}</div>

              <div className="msg-meta">{fmtTime(m.ts)}{m.model ? ` · ${m.model}` : ''}</div>

            </div>

          ))}

          {loading && (

            <div className="msg-loading">

              <div className="spinner"></div>

              <span>ИИ думает...</span>

            </div>

          )}

          <div ref={bottomRef}></div>

        </div>

        <div className="chat-input-area">

          <input

            className="input flex-1"

            placeholder="Введите сообщение... (Enter для отправки)"

            value={input}

            onChange={e => setInput(e.target.value)}

            onKeyDown={handleKey}

            disabled={loading}

          />

          <button className="btn btn-primary" onClick={send} disabled={loading || !input.trim()}>

            {loading ? <span className="spinner" style={{width:16,height:16}}></span> : 'Отправить'}

          </button>

        </div>

      </div>

    </div>

  );

}



