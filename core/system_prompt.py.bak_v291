def _get_model_knowledge_text() -> str:
    try:
        from brain.model_profiler import ModelProfiler
        profiler = ModelProfiler.get()
        return profiler.get_model_knowledge_text()
    except Exception:
        return ""


def _get_provider_status_text() -> str:
    try:
        from brain.llm_router import LLMRouter
        router = LLMRouter.get()
        report = router.status_report()
        available = [p for p, s in report.items() if s["available"]]
        unavailable = [p for p, s in report.items()
                       if not s["available"] and not s["tokens_exhausted"]]
        exhausted = [p for p, s in report.items() if s["tokens_exhausted"]]
        lines = []
        if available:
            lines.append(f"✅ Активны: {', '.join(available)}")
        if exhausted:
            lines.append(f"⚠️ Лимит исчерпан: {', '.join(exhausted)}")
        if unavailable:
            lines.append(f"❌ Нет ключа: {', '.join(unavailable)}")
        return "\n".join(lines)
    except Exception:
        return ""


def build_system_prompt(
    task_type: str = "chat",
    rag_context: str = "",
    projects: Optional[list] = None,
    agent_statuses: Optional[dict] = None,
    include_model_knowledge: bool = True,
) -> str:
    """
    Собрать финальный системный промт для конкретного запроса.

    Args:
        task_type: тип задачи ("code", "analysis", "trading", "payment", "freelance", "chat")
        rag_context: релевантный контекст из памяти
        projects: список активных проектов
        agent_statuses: текущие статусы агентов
        include_model_knowledge: добавить знания о доступных AI-моделях
    """
    parts = [BASE_SYSTEM_PROMPT]

    addon = TASK_ADDONS.get(task_type, TASK_ADDONS["chat"])
    parts.append(addon)

    context_parts = []

    if projects:
        names = ", ".join(p.get("name", "?") for p in projects[:5])
        context_parts.append(f"Активные проекты: {names}")

    if agent_statuses:
        running = [k for k, v in agent_statuses.items() if v == "running"]
        if running:
            context_parts.append(f"Агенты в работе: {', '.join(running)}")

    provider_status = _get_provider_status_text()
    if provider_status:
        context_parts.append(f"LLM провайдеры:\n{provider_status}")

    if context_parts:
        parts.append("\n--- ТЕКУЩИЙ КОНТЕКСТ СИСТЕМЫ ---\n" + "\n".join(context_parts))

    if include_model_knowledge:
        model_knowledge = _get_model_knowledge_text()
        if model_knowledge:
            parts.append(
                "\n--- ЗНАНИЯ О ДОСТУПНЫХ AI-МОДЕЛЯХ ---\n"
                + model_knowledge[:3000]
                + "\n\nИспользуй эти знания для умного выбора модели под задачу."
            )

    if rag_context and len(rag_context.strip()) > 50:
        parts.append(
            "\n--- РЕЛЕВАНТНЫЕ ЗНАНИЯ ИЗ ПАМЯТИ ---\n"
            + rag_context[:2000]
            + "\n(Используй эти знания при ответе)"
        )

    return "\n\n".join(parts)


# ══════════════════════════════════════════════════════════════════
# ДОСТУПНЫЕ ИНСТРУМЕНТЫ И БИБЛИОТЕКИ
# ══════════════════════════════════════════════════════════════════
# AI имеет доступ к следующим инструментам и библиотекам.
# Всегда используй их когда задача требует анализа данных, торговли,
# или работы с сервером.
#
# ── 1. ТЕХНИЧЕСКИЙ АНАЛИЗ РЫНКА ──────────────────────────────────
# Инструмент: market_analysis (tool_registry)
# Использование через tool_registry:
#   tool = ToolRegistry.get().find_by_name("market_analysis")
#   result = tool.run_fn("BTCUSDT анализ")
#
# Прямой Python API (если нужны raw данные):
#   from tools.analysis import analyze_market, calc_indicators, MarketAnalyzer
#   from tools.data_tools import df_from_candles, detect_pattern, calc_position_size
#
#   # Полный анализ:
#   result = analyze_market(candles, "BTCUSDT")
#   # result["signal"]     → "BUY" | "SELL" | "HOLD"
#   # result["regime"]     → "trending_up" | "ranging" | ...
#   # result["indicators"] → dict с RSI, MACD, BB, ATR, EMA...
#   # result["summary"]    → строка для ответа пользователю
#
#   # Только индикаторы (DataFrame):
#   df = calc_indicators(candles)
#   df[["rsi","macd","bb_upper","bb_lower","atr"]].tail(5)
#
#   # Определить паттерн:
#   patterns = detect_pattern(df)  # ["hammer", "doji", ...]
#
#   # Размер позиции:
#   size = calc_position_size(balance=1000, risk_pct=0.01, entry=94000, stop_loss=92000)
#   # size["qty"] → количество контрактов
#
# ── 2. PANDAS / NUMPY (данные) ────────────────────────────────────
# Всегда доступны для анализа данных:
#   import pandas as pd
#   import numpy as np
#
#   df = pd.DataFrame(data)
#   df.describe()             # статистика
#   df.corr()                 # корреляция
#   df.resample("1h").agg(...)# ресэмплинг OHLCV
#
# ── 3. МОНИТОРИНГ СЕРВЕРА ─────────────────────────────────────────
#   from tools.server_monitor import ServerMonitor
#   stats = ServerMonitor.get().get_stats()
#   # CPU: 1.5%, RAM: 166MB/23GB, Disk: 18GB/484GB
#
# ── 4. ТОРГОВЫЙ БОТ (Bybit V5 API) ──────────────────────────────
#   sys.path.insert(0, "/root/bybit-bot")
#   from core.exchange import BybitExchange
#   ex = BybitExchange(api_key, api_secret, testnet=True)
#
#   candles   = ex.get_klines("BTCUSDT", "15", 200)  # OHLCV
#   ticker    = ex.get_ticker("BTCUSDT")              # last price
#   balance   = ex.get_balance()                      # USDT balance
#   positions = ex.get_positions()                    # open positions
#
# ── 5. SCIPY / СТАТИСТИКА ────────────────────────────────────────
#   from scipy import stats
#   z = stats.zscore(price_series)
#   corr, pval = stats.pearsonr(series1, series2)
#   stats.linregress(x, y)  # линейная регрессия
#
# ── 6. MACHINE LEARNING (если нужно) ─────────────────────────────
#   import torch
#   from sentence_transformers import SentenceTransformer
#   from sklearn.preprocessing import StandardScaler
#
# ── 7. БЭКТЕСТИНГ ────────────────────────────────────────────────
#   from tools.analysis import backtest_simple
#   def my_strategy(df, i):
#       return "BUY" if df["rsi"].iloc[i] < 30 else "HOLD"
#   results = backtest_simple(candles, my_strategy)
#   # results["total_return_pct"], ["win_rate"], ["sharpe"]
#
# ПРАВИЛА ИСПОЛЬЗОВАНИЯ ИНСТРУМЕНТОВ:
#   1. Всегда оборачивай вызовы в try/except — API может быть недоступен
#   2. Для торговых операций ВСЕГДА используй RiskManager
#   3. Никогда не исполняй ордера напрямую — только через OrderManager
#   4. Кэшируй результаты тяжёлых вычислений
#   5. Используй pandas vectorized операции вместо циклов

