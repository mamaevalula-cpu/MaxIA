# ============================================================
# .env.local — ЛОКАЛЬНЫЕ ПЕРЕОПРЕДЕЛЕНИЯ (НЕ КОММИТИТЬ В GIT!)
# ============================================================
# Этот файл имеет НАИВЫСШИЙ приоритет и перекрывает .env
#
# Используй здесь:
#   • Временные тестовые ключи
#   • Переопределения для dev-окружения
#   • Локальные пути и порты
#
# Загружается первым через: load_dotenv(".env.local", override=True)
# ============================================================

# ── Пример переопределений ───────────────────────────────────

# Принудительно включить testnet (даже если в .env стоит false):
# BYBIT_TESTNET=true

# Временный тестовый Claude ключ:
# ANTHROPIC_API_KEY=sk-ant-api03-...

# Изменить уровень логов для отладки:
# LOG_LEVEL=DEBUG

# Отключить автономную торговлю:
# TRADING_LIVE_CONFIRMED=false

# Локальный Ollama (если на другом порту):
# OLLAMA_URL=http://localhost:11434

# Мастер-пароль (если не хочешь держать в .env):
# MASTER_PASSWORD=my_local_master_password
