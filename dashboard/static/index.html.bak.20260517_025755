            <div style={{fontSize:12,color:'var(--text-secondary)',marginBottom:8}}>{skill.description}</div>

            <div style={{fontSize:11,marginBottom:4}}>
              <span style={{color:'#f59e0b',fontWeight:600}}>📚 Следующий шаг:</span>
