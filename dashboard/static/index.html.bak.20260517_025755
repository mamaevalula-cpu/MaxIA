function ProgressBar({ label, value, max = 100, color }) {
  const pct = Math.min(100, Math.max(0, (value / max) * 100));
  const col = color || (pct > 85 ? 'var(--danger)' : pct > 70 ? 'var(--warn)' : 'var(--accent2)');
  return (
    <div className="prog-wrap">
      <div className="prog-label">
        <span>{label}</span>
        <span>{typeof value === 'number' ? `${pct.toFixed(0)}%` : value}</span>
      </div>
      <div className="prog-track">
        <div className="prog-fill" style={{ width: `${pct}%`, background: col }}></div>
      </div>
    </div>
  );
}

