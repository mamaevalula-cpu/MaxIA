function ArbitrageTab() {
  const [status, setStatus]     = React.useState(null);
  const [scanResult, setScan]   = React.useState(null);
  const [execLog, setExecLog]   = React.useState([]);
  const [liveOpps, setLiveOpps] = React.useState({opportunities:[],profitable:[],prices:{},funding:{}});
  const [scanning, setScanning] = React.useState(false);
  const [prices, setPrices]     = React.useState({BTCUSDT:65000, ETHUSDT:3200, SOLUSDT:150});

  React.useEffect(() => {
    loadStatus();
    loadExecLog();
    const iv = setInterval(() => { loadStatus(); loadExecLog(); }, 15000);
    return () => clearInterval(iv);
  }, []);

  function loadStatus() {
    apiFetch('/api/arbitrage/status').then(r => { if (r.ok) setStatus(r.data); });
    apiFetch('/api/arbitrage/live').then(r => { if (r.ok) setLiveOpps(r.data); });
  }
  function loadExecLog() {
    apiFetch('/api/arbitrage/execution_log').then(r => { if (r.ok) setExecLog(r.data.entries||[]); });
  }

  async function runScan() {
    setScanning(true);
    const r = await apiFetch('/api/arbitrage/scan', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({prices})
    });
    if (r.ok) setScan(r.data);
    setScanning(false);
    loadStatus();
  }

  async function resetCB() {
    await apiFetch('/api/arbitrage/reset_circuit_breaker', {method:'POST'});
    loadStatus();
  }

  return (
    <div style={{padding:16}}>
      <div style={{display:'flex', justifyContent:'space-between', alignItems:'center', marginBottom:16}}>
        <h2 style={{margin:0}}>\u26A1 Crypto Arbitrage Engine</h2>
        <div style={{display:'flex', gap:8}}>
          <button onClick={runScan} disabled={scanning}
            style={{padding:'6px 16px', background:'#0d6efd', color:'#fff', border:'none', borderRadius:6, cursor:'pointer'}}>
            {scanning ? '\u23F3 Scanning...' : '\uD83D\uDD0D Scan Now'}
          </button>
          {status?.circuit_breaker && (
            <button onClick={resetCB}
              style={{padding:'6px 16px', background:'#dc3545', color:'#fff', border:'none', borderRadius:6, cursor:'pointer'}}>
              \u26A0\uFE0F Reset CB
            </button>
          )}
        </div>
      </div>

      {/* Status KPIs */}
      {status && (
        <div style={{display:'grid', gridTemplateColumns:'repeat(5,1fr)', gap:8, marginBottom:16}}>
          {[
            ['Daily PnL', '$' + (status.daily_pnl_usd||0).toFixed(4), status.daily_pnl_usd>=0?'#28a745':'#dc3545'],
            ['Drawdown', (status.daily_drawdown_pct||0).toFixed(2)+'%', status.daily_drawdown_pct>2?'#dc3545':'#888'],
            ['Trades Today', status.trades_today||0, '#0d6efd'],
            ['Errors', status.errors_today||0, status.errors_today>0?'#dc3545':'#888'],
            ['Circuit Breaker', status.circuit_breaker?'ACTIVE':'OFF', status.circuit_breaker?'#dc3545':'#28a745'],
          ].map(([label, val, color]) => (
            <div key={label} style={{background: status.circuit_breaker&&label==='Circuit Breaker'?'#2e0b0b':'#1a1a2e',
                                     border:'1px solid #333', borderRadius:8, padding:12, textAlign:'center'}}>
              <div style={{fontSize:10, color:'#888'}}>{label}</div>
              <div style={{fontWeight:'bold', fontSize:15, color}}>{val}</div>
            </div>
          ))}
        </div>
      )}

      {status?.circuit_breaker && (
        <div style={{background:'#2e0b0b', border:'1px solid #dc3545', borderRadius:8, padding:12, marginBottom:16}}>
          <div style={{color:'#dc3545', fontWeight:'bold'}}>
            \u26A0\uFE0F [ALERT: ARBITRAGE_ENGINE_CIRCUIT_BREAKER_ACTIVE]
          </div>
          <div style={{color:'#aaa', fontSize:11, marginTop:4}}>
            Daily drawdown threshold of 3% reached. All trading halted. Positions closed to USDT.
          </div>
        </div>
      )}

      {/* Live Bybit Price Spreads */}
      {liveOpps.opportunities.length > 0 && (
        <div style={{background:'var(--bg2)',border:'1px solid var(--border)',borderRadius:8,padding:12,marginBottom:16}}>
          <div style={{display:'flex',justifyContent:'space-between',alignItems:'center',marginBottom:8}}>
            <h4 style={{margin:0,fontSize:13}}>&#128308; Live Spot&#8201;vs&#8201;Perp Spreads</h4>
            <span style={{fontSize:10,color:'var(--text2)'}}>Updated: {liveOpps.scan_ts ? new Date(liveOpps.scan_ts*1000).toLocaleTimeString() : 'now'}</span>
          </div>
          <div style={{display:'grid',gridTemplateColumns:'repeat(4,1fr)',gap:6}}>
            {liveOpps.opportunities.map((o,i) => (
              <div key={i} style={{background:'var(--bg)',border:'1px solid var(--border)',borderRadius:6,padding:'8px 10px',textAlign:'center'}}>
                <div style={{fontWeight:600,fontSize:12,marginBottom:4}}>{o.symbol}</div>
                {o.error ? (
                  <div style={{fontSize:10,color:'#ef4444'}}>Error</div>
                ) : (<>
                  <div style={{fontSize:11,color:'var(--text2)'}}>Perp: <span style={{color:'var(--text)'}}>${(o.perp_price||0).toLocaleString()}</span></div>
                  <div style={{fontSize:11,color:'var(--text2)'}}>Spot: <span style={{color:'var(--text)'}}>${(o.spot_price||0).toLocaleString()}</span></div>
                  <div style={{fontSize:13,fontWeight:700,color:o.spread_pct>0?'#22c55e':o.spread_pct<-0.05?'#f59e0b':'#6b7280',marginTop:4}}>
                    {o.spread_pct > 0 ? '+' : ''}{(o.spread_pct||0).toFixed(4)}%
                  </div>
                  <div style={{fontSize:10,color:'var(--text2)',marginTop:2}}>
                    Funding: {((liveOpps.funding||{})[o.symbol]||0).toFixed(4)}%
                  </div>
                  {o.tradeable && <div style={{fontSize:10,color:'#22c55e',fontWeight:600,marginTop:2}}>&#9679; SPREAD OPP</div>}
                </>)}
              </div>
            ))}
          </div>
        </div>
      )}

      {/* Scan Results */}
      {scanResult && (
        <div style={{background:'#1a1a2e', border:'1px solid #333', borderRadius:8, padding:12, marginBottom:16}}>
          <h4 style={{margin:'0 0 8px', fontSize:13}}>\uD83D\uDD0D Last Scan Results — {scanResult.total_found} opportunities</h4>
          <div style={{display:'grid', gridTemplateColumns:'1fr 1fr', gap:8}}>
            <div>
              <div style={{fontSize:11, color:'#888', marginBottom:4}}>Spatial (Cross-Exchange)</div>
              {(scanResult.spatial_opportunities||[]).slice(0,3).map((o, i) => (
                <div key={i} style={{fontSize:10, padding:'3px 0', borderBottom:'1px solid #222'}}>
                  <span style={{color:'#0d6efd'}}>{o.pair}</span>
                  <span style={{color:'#888'}}> {o.buy_exchange}\u2192{o.sell_exchange}</span>
                  <span style={{color: o.net_profit_pct>0?'#28a745':'#dc3545', marginLeft:6}}>
                    {o.net_profit_pct}% | ${o.estimated_pnl}
                  </span>
                </div>
              ))}
              {!(scanResult.spatial_opportunities||[]).length && <div style={{color:'#555', fontSize:11}}>None detected</div>}
            </div>
            <div>
              <div style={{fontSize:11, color:'#888', marginBottom:4}}>Triangular (Intra-Exchange)</div>
              {(scanResult.triangular_opportunities||[]).slice(0,3).map((o, i) => (
                <div key={i} style={{fontSize:10, padding:'3px 0', borderBottom:'1px solid #222'}}>
                  <span style={{color:'#ffc107'}}>{o.pair}</span>
                  <span style={{color: o.net_profit_pct>0?'#28a745':'#dc3545', marginLeft:6}}>
                    {o.net_profit_pct}% | ${o.estimated_pnl}
                  </span>
                </div>
              ))}
              {!(scanResult.triangular_opportunities||[]).length && <div style={{color:'#555', fontSize:11}}>None detected</div>}
            </div>
          </div>
        </div>
      )}

      {/* Execution Log */}
      <div style={{background:'#1a1a2e', border:'1px solid #333', borderRadius:8, padding:12}}>
        <h4 style={{margin:'0 0 8px', fontSize:13}}>\uD83D\uDCC3 Execution Log</h4>
        {execLog.slice(0,10).map((entry, i) => {
          const ts = entry.ts ? new Date(entry.ts*1000).toLocaleTimeString() : '?';
          return (
            <div key={i} style={{fontSize:10, padding:'3px 0', borderBottom:'1px solid #222', color:'#aaa'}}>
              [{ts}]
              <span style={{color:'#0d6efd', marginLeft:4}}>{entry.type||entry.exchange}</span>
              <span style={{marginLeft:4}}>{entry.pair||entry.asset}</span>
              <span style={{color: entry.result?.status==='filled'?'#28a745':'#ffc107', marginLeft:4}}>
                {entry.result?.status || entry.status}
              </span>
              <span style={{color:'#666', marginLeft:4}}>${(entry.usd_value||entry.amount||0).toFixed(2)}</span>
            </div>
          );
        })}
        {!execLog.length && <div style={{color:'#555', fontSize:11}}>No executions yet</div>}
      </div>
    </div>
  );
}

