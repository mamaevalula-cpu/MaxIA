async function loadEvolution() {
  const d = await api(HYP+'/api/v1/evolution/arena');
  if (!d) return;
  const wl=d.wishlist||[], cr=d.recently_created||[];

  $('ev-kpis').innerHTML = [
    statCard(d.factory_created||0,'Создано агентов','','stat-grn'),
    statCard(d.factory_wishlist||0,'В списке желаний',''),
    statCard(d.autonomy_level||0,'Уровень автономии','/10','stat-acc'),
    statCard(d.canary_deployments||0,'Canary деплоев',''),
  ].join('');

  $('ev-wish').innerHTML = wl.slice(0,10).map(w =>
    `<div class="row"><span class="row-left" style="font-size:11px">${esc(w.name||w.class||String(w))}</span>${bdg('P'+(w.priority||1),'b')}</div>`
  ).join('') || '<div style="color:var(--txt3);padding:10px;font-size:12px">Список желаний пуст</div>';

  $('ev-made').innerHTML = cr.slice(0,10).map(a =>
    `<div class="row"><span class="row-left" style="color:var(--grn);font-size:11px">✓ ${esc(a.name||String(a))}</span>${bdg('создан','g')}</div>`
  ).join('') || '<div style="color:var(--txt3);padding:10px;font-size:12px">Ни одного агента ещё не создано</div>';
}

