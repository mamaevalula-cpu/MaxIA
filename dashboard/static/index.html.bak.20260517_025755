                {server.os && <div>ОС: <span style={{color:'var(--text)'}}>{server.os}</span></div>}
                {server.python_version && <div>Python: <span style={{color:'var(--text)'}}>{server.python_version}</span></div>}
                {server.uptime !== undefined && <div>Аптайм: <span style={{color:'var(--text)'}}>{formatUptime(server.uptime_s)}</span></div>}
              </div>
            </>
          ) : <div className="empty-state">Загрузка данных сервера...</div>}
        </div>
      </div>
      {toast && <Toast msg={toast.msg} type={toast.type} onClose={() => setToast(null)} />}
    </div>
  );
}


// ============================================================
// PROJECTS TAB
// ============================================================
function ProjectsTab() {
  const [projects, setProjects] = useState([]);
  const [stats, setStats] = useState({});
  const [creating, setCreating] = useState(false);
  const [form, setForm] = useState({ name: '', description: '', type: 'custom' });
  const [filter, setFilter] = useState('all');
  const [toast, setToast] = useState(null);
  const [continuingId, setContinuingId] = useState(null);
  const [continueMsg, setContinueMsg] = useState('');
  const [sending, setSending] = useState(false);

  const load = useCallback(async () => {
    const r = await apiFetch('/api/projects');
    if (r.ok) {
      setProjects(r.data.projects || []);
      setStats(r.data.stats || {});
    }
  }, []);

  usePolling(load, 15000, []);

  const createProject = async () => {
    if (!form.name.trim()) return;
    const r = await apiFetch('/api/projects', {
      method: 'POST',
      body: JSON.stringify(form),
    });
    if (r.ok) {
      setCreating(false);
      setForm({ name: '', description: '', type: 'custom' });
      setToast('Проект создан!');
      load();
    } else {
      setToast('Ошибка создания');
    }
    setTimeout(() => setToast(null), 3000);
  };

  const continueChat = async (p) => {
    if (!continueMsg.trim() || sending) return;
    setSending(true);
    const msg = `[Проект: ${p.name}] ${continueMsg}`;
    await apiFetch('/api/chat', { method: 'POST', body: JSON.stringify({ message: msg }) });
    setSending(false);
    setContinuingId(null);
    setContinueMsg('');
    setToast('Сообщение отправлено в чат!');
    setTimeout(() => setToast(null), 3000);
  };

  const filtered = filter === 'all' ? projects : projects.filter(p => p.status === filter);

  const statusColor = { running: '#10b981', idle: '#6b7280', failed: '#ef4444', done: '#3b82f6' };
  const typeLabels = { trading_bot: 'Торговый бот', custom: 'Пользовательский', web_service: 'Веб-сервис', data_pipeline: 'Данные', ai_agent: 'AI агент', automation: 'Автоматизация' };
  const typeIcon = t => t === 'trading_bot' ? '💹' : t === 'web_service' ? '🌐' : t === 'ai_agent' ? '🤖' : t === 'automation' ? '⚙️' : t === 'data_pipeline' ? '📊' : '📁';

  return (
    <div>
      <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', marginBottom: 16 }}>
        <div className="tab-title" style={{ marginBottom: 0 }}>Управление проектами</div>
        <button className="btn btn-primary" onClick={() => setCreating(!creating)}>
          {creating ? '✕ Отмена' : '+ Новый проект'}
        </button>
      </div>

      {toast && <div style={{ background: '#10b981', color: '#fff', padding: '8px 16px', borderRadius: 8, marginBottom: 12 }}>{toast}</div>}

      {creating && (
        <div className="card" style={{ marginBottom: 16, padding: 16 }}>
          <div className="section-title">Создать проект</div>
          <div style={{ display: 'flex', flexDirection: 'column', gap: 8 }}>
            <input
              className="input"
              placeholder="Название проекта *"
              value={form.name}
              onChange={e => setForm({ ...form, name: e.target.value })}
            />
            <textarea
              className="input"
              placeholder="Описание (необязательно)"
              rows={2}
              value={form.description}
              onChange={e => setForm({ ...form, description: e.target.value })}
              style={{ resize: 'vertical' }}
            />
            <select
              className="input"
              value={form.type}
              onChange={e => setForm({ ...form, type: e.target.value })}
            >
              <option value="custom">Пользовательский</option>
              <option value="trading_bot">Торговый бот</option>
              <option value="web_service">Веб-сервис</option>
              <option value="data_pipeline">Конвейер данных</option>
              <option value="ai_agent">AI агент</option>
              <option value="automation">Автоматизация</option>
            </select>
            <button className="btn btn-primary" onClick={createProject} style={{ alignSelf: 'flex-start' }}>
              Создать
            </button>
          </div>
        </div>
      )}

      <div className="grid-4" style={{ marginBottom: 16 }}>
        <MetricCard title="Всего" value={stats.total ?? 0} sub="проектов" />
      <div className="card" style={{padding:"12px",background:"rgba(239,68,68,0.1)",fontSize:"13px",color:"var(--text2)",marginBottom:"12px"}}>
        💡 Если проект показывает ошибку — используйте кнопку Перезапустить
      </div>
        <MetricCard title="Активных" value={stats.running ?? 0} sub="работают сейчас" />
        <MetricCard title="Завершено" value={stats.done ?? 0} sub="выполнено" />
        <MetricCard title="Ошибки" value={stats.failed ?? 0} sub="с ошибками" />
      </div>

      <div style={{ display: 'flex', gap: 8, marginBottom: 12, flexWrap: 'wrap' }}>
        {['all', 'running', 'idle', 'done', 'failed'].map(f => (
          <button
            key={f}
            onClick={() => setFilter(f)}
            style={{
              padding: '4px 12px', borderRadius: 20, border: '1px solid var(--border)',
              background: filter === f ? 'var(--accent)' : 'transparent',
              color: filter === f ? '#fff' : 'var(--text)', cursor: 'pointer', fontSize: 12,
            }}
          >
            {f === 'all' ? 'Все' : f === 'running' ? 'Активные' : f === 'idle' ? 'Ожидание' : f === 'done' ? 'Готово' : 'Ошибка'}
          </button>
        ))}
      </div>

      {filtered.length === 0 ? (
        <div className="card" style={{ textAlign: 'center', padding: 40 }}>
          <div style={{ fontSize: 32, marginBottom: 8 }}>📁</div>
          <div style={{ color: 'var(--text2)' }}>
            {projects.length === 0 ? 'Нет проектов. Создайте первый!' : 'Нет проектов с таким фильтром'}
          </div>
        </div>
      ) : (
        <div style={{ display: 'flex', flexDirection: 'column', gap: 8 }}>
          {filtered.map((p, i) => (
            <div key={i} className="card" style={{ padding: 16, borderLeft: `3px solid ${statusColor[p.status] || '#6b7280'}` }}>
              <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between' }}>
                <div style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
                  <span style={{ fontSize: 16 }}>{typeIcon(p.type)}</span>
                  <div>
                    <div style={{ fontWeight: 600, color: 'var(--text)' }}>{p.name || 'Без названия'}</div>
                    <div style={{ fontSize: 11, color: 'var(--text2)' }}>{typeLabels[p.type] || p.type}</div>
                  </div>
                </div>
                <div style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
                  <span style={{
                    fontSize: 11, padding: '3px 8px', borderRadius: 20,
                    background: (statusColor[p.status] || '#6b7280') + '22', color: statusColor[p.status] || '#6b7280',
                    fontWeight: 600,
                  }}>
                    {p.status === 'running' ? '▶ Активен' : p.status === 'failed' ? '✕ Ошибка' : p.status === 'done' ? '✓ Готово' : '◉ Ожидание'}
                  </span>
                  <button
                    className="btn"
                    style={{ fontSize: 11, padding: '3px 10px' }}
                    onClick={() => { setContinuingId(continuingId === p.id ? null : p.id); setContinueMsg(''); }}
                  >
                    💬 Продолжить
                  </button>
                </div>
              </div>
              {p.description && (
                <div style={{ fontSize: 12, color: 'var(--text2)', marginTop: 8 }}>{p.description}</div>
              )}
              {p.last_message && (
                <div style={{ fontSize: 11, color: 'var(--text2)', marginTop: 6, padding: '6px 10px', background: 'var(--bg2)', borderRadius: 6 }}>
                  <span style={{ color: 'var(--text2)', fontWeight: 500 }}>Последнее: </span>{(p.last_message || '').slice(0, 150)}{(p.last_message || '').length > 150 ? '...' : ''}
                </div>
              )}
              {p.created_at && (
                <div style={{ fontSize: 11, color: 'var(--text2)', marginTop: 4 }}>
                  Создан: {new Date(p.created_at * 1000).toLocaleDateString('ru')}
                </div>
              )}
              {continuingId === p.id && (
                <div style={{ marginTop: 10, display: 'flex', gap: 8 }}>
                  <input
                    className="input flex-1"
                    placeholder="Продолжить обсуждение проекта..."
                    value={continueMsg}
                    onChange={e => setContinueMsg(e.target.value)}
                    onKeyDown={e => { if (e.key === 'Enter') continueChat(p); }}
                    autoFocus
                  />
                  <button className="btn btn-primary" onClick={() => continueChat(p)} disabled={sending || !continueMsg.trim()}>
                    {sending ? '...' : 'Отправить'}
                  </button>
                </div>
              )}
            </div>
          ))}
        </div>
      )}
    </div>
  );
}

// ============================================================
// BROWSER TAB (Tor)
// ============================================================
function BrowserTab() {
  const [status, setStatus] = useState(null);
  const [history, setHistory] = useState([]);
  const [url, setUrl] = useState('');
  const [query, setQuery] = useState('');
  const [result, setResult] = useState(null);
  const [loading, setLoading] = useState(false);
  const [prices, setPrices] = useState({});

  const loadStatus = useCallback(async () => {
    const [h, btc, eth, sol] = await Promise.all([
      apiFetch('/api/browser/history'),
      apiFetch('/api/browser/price?symbol=BTC'),
      apiFetch('/api/browser/price?symbol=ETH'),
      apiFetch('/api/browser/price?symbol=SOL'),
    ]);
    if (h.ok) { setHistory(h.data.history || []); setStatus({ tor_active: h.data.tor_active }); }
    const p = {};
    if (btc.ok && btc.data.price) p.BTC = btc.data.price;
    if (eth.ok && eth.data.price) p.ETH = eth.data.price;
    if (sol.ok && sol.data.price) p.SOL = sol.data.price;
    setPrices(p);
  }, []);

  usePolling(loadStatus, 30000, []);

  const browse = async () => {
    if (!url.trim()) return;
    setLoading(true);
    setResult(null);
    const r = await apiFetch('/api/browser/browse', {
      method: 'POST',
      body: JSON.stringify({ url: url.trim() }),
    });
    setLoading(false);
    if (r.ok) setResult({ type: 'page', data: r.data });
    else setResult({ type: 'error', data: r.data });
    loadStatus();
  };

  const search = async () => {
    if (!query.trim()) return;
    setLoading(true);
    setResult(null);
    const r = await apiFetch('/api/browser/search', {
      method: 'POST',
      body: JSON.stringify({ query: query.trim() }),
    });
    setLoading(false);
    if (r.ok) setResult({ type: 'search', data: r.data });
    else setResult({ type: 'error', data: r.data });
  };

  const torColor = status?.tor_active ? '#10b981' : '#f59e0b';

  return (
    <div>
      <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', marginBottom: 16 }}>
        <div className="tab-title" style={{ marginBottom: 0 }}>Браузер Tor</div>
        <div style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
          <div style={{ width: 8, height: 8, borderRadius: '50%', background: torColor }} />
          <span style={{ fontSize: 12, color: torColor }}>
            {status?.tor_active ? 'Tor активен' : 'Прямое соединение'}
          </span>
        </div>
      </div>

      <div className="grid-4" style={{ marginBottom: 16 }}>
        {Object.entries(prices).map(([sym, price]) => (
          <MetricCard
            key={sym}
            title={sym + '/USDT'}
            value={price ? `$${Number(price).toLocaleString('en', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}` : '—'}
            sub={status?.tor_active ? '🧅 Via Tor' : '🌐 Direct'}
          />
        ))}
        <MetricCard title="Страниц" value={history.length} sub="в истории" />
      </div>

      <div className="grid-2" style={{ marginBottom: 16 }}>
        <div className="card" style={{ padding: 16 }}>
          <div className="section-title">Открыть URL</div>
          <div style={{ display: 'flex', gap: 8 }}>
            <input
              className="input"
              style={{ flex: 1 }}
              placeholder="https://example.com"
              value={url}
              onChange={e => setUrl(e.target.value)}
              onKeyDown={e => e.key === 'Enter' && browse()}
            />
            <button className="btn-primary" onClick={browse} disabled={loading}>
              {loading ? '...' : 'Открыть'}
            </button>
          </div>
        </div>
        <div className="card" style={{ padding: 16 }}>
          <div className="section-title">Поиск (DuckDuckGo)</div>
      <div className="card" style={{padding:"12px",background:"rgba(99,102,241,0.1)",fontSize:"13px",color:"var(--text2)",marginBottom:"12px"}}>
        💡 ИИ-браузер с Tor. Здесь вы видите все сайты, которые посетил ваш ИИ.
      </div>
          <div style={{ display: 'flex', gap: 8 }}>
            <input
              className="input"
              style={{ flex: 1 }}
              placeholder="Поисковый запрос..."
              value={query}
              onChange={e => setQuery(e.target.value)}
              onKeyDown={e => e.key === 'Enter' && search()}
            />
            <button className="btn-primary" onClick={search} disabled={loading}>
              {loading ? '...' : 'Найти'}
            </button>
          </div>
        </div>
      </div>

      {result && (
        <div className="card" style={{ padding: 16, marginBottom: 16 }}>
          {result.type === 'page' && (
            <div>
              <div style={{ fontWeight: 600, marginBottom: 8 }}>
                {result.data.title || 'Без заголовка'} — {result.data.status} ({result.data.latency_ms}ms)
              </div>
              <div style={{ fontSize: 12, color: 'var(--text2)', marginBottom: 8 }}>
                {result.data.url} {result.data.via_tor ? '🧅' : '🌐'}
              </div>
              <pre style={{ fontSize: 11, whiteSpace: 'pre-wrap', wordBreak: 'break-word',
                color: 'var(--text)', maxHeight: 300, overflow: 'auto' }}>
                {result.data.text?.slice(0, 2000)}
              </pre>
              {result.data.links?.length > 0 && (
                <div style={{ marginTop: 8 }}>
                  <div style={{ fontSize: 12, color: 'var(--text2)', marginBottom: 4 }}>Ссылки:</div>
                  {result.data.links.slice(0, 5).map((l, i) => (
                    <div key={i} style={{ fontSize: 11 }}>
                      <a href="#" onClick={e => { e.preventDefault(); setUrl(l); }} style={{ color: 'var(--accent)' }}>{l.slice(0, 80)}</a>
                    </div>
                  ))}
                </div>
              )}
            </div>
          )}
          {result.type === 'search' && (
            <div>
              <div className="section-title">Результаты поиска</div>
              {(result.data.results || []).slice(0, 5).map((r, i) => (
                <div key={i} style={{ marginBottom: 12, padding: 8, background: 'var(--bg2)', borderRadius: 6 }}>
                  <div style={{ fontSize: 12, color: 'var(--text)' }}>{r.text?.slice(0, 250)}</div>
                </div>
              ))}
            </div>
          )}
          {result.type === 'error' && (
            <div style={{ color: '#ef4444' }}>Ошибка: {result.data?.error || 'Неизвестная ошибка'}</div>
          )}
        </div>
      )}

      <div className="card" style={{ padding: 0, overflow: 'hidden' }}>
        <div style={{ padding: '12px 16px', borderBottom: '1px solid var(--border)' }}>
          <span className="section-title" style={{ marginBottom: 0 }}>
            История ({history.length} страниц)
          </span>
        </div>
        {history.length === 0 ? (
          <div className="empty-state">История пуста</div>
        ) : (
          history.slice(0, 20).map((h, i) => (
            <div key={i} style={{ padding: '10px 16px', borderBottom: '1px solid var(--border)',
              display: 'flex', gap: 10, alignItems: 'flex-start' }}>
              <span style={{ fontSize: 16 }}>🌐</span>
              <div style={{ flex: 1, minWidth: 0 }}>
                <div style={{ fontSize: 13, fontWeight: 500, color: 'var(--text)',
                  overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' }}>
                  {h.title || h.url}
                </div>
                <div style={{ fontSize: 11, color: 'var(--text2)',
                  overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' }}>
                  {h.url}
                </div>
              </div>
              <div style={{ fontSize: 10, color: 'var(--text2)', whiteSpace: 'nowrap' }}>
                {h.ts ? new Date(h.ts * 1000).toLocaleTimeString('ru') : ''}
              </div>
            </div>
          ))
        )}
      </div>
    </div>
  );
}

// ============================================================
// EMAIL TAB
// ============================================================
function EmailTab() {
  const [status, setStatus] = useState(null);
  const [emails, setEmails] = useState([]);
  const [keys, setKeys] = useState([]);
  const [loading, setLoading] = useState(false);
  const [keysLoading, setKeysLoading] = useState(false);
  const [selected, setSelected] = useState(null);
  const [searchQ, setSearchQ] = useState('');
  const [tab2, setTab2] = useState('inbox');

  const loadStatus = useCallback(async () => {
    const r = await apiFetch('/api/email/status');
    if (r.ok) setStatus(r.data);
  }, []);

  useEffect(() => { loadStatus(); }, []);

  const loadInbox = async () => {
    setLoading(true);
    const r = await apiFetch('/api/email/inbox?count=30');
    setLoading(false);
    if (r.ok) setEmails(r.data.emails || []);
  };

  const scanKeys = async () => {
    setKeysLoading(true);
    const r = await apiFetch('/api/email/keys');
    setKeysLoading(false);
    if (r.ok) setKeys(r.data.keys || []);
  };

  const connColor = status?.connected ? '#10b981' : '#ef4444';

  return (
    <div>
      <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', marginBottom: 16 }}>
        <div className="tab-title" style={{ marginBottom: 0 }}>Электронная почта</div>
        <div style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
          <div style={{ width: 8, height: 8, borderRadius: '50%', background: connColor }} />
          <span style={{ fontSize: 12, color: connColor }}>
            {status ? (status.connected ? 'Подключен' : 'Нет подключения') : 'Проверка...'}
          </span>
        </div>
      </div>

      {status && (
        <div className="card" style={{ padding: 12, marginBottom: 16, display: 'flex', gap: 16, alignItems: 'center', flexWrap: 'wrap' }}>
          <div style={{ flex: 1 }}>
            <div style={{ fontSize: 13, fontWeight: 600 }}>{status.address || 'Не настроено'}</div>
            <div style={{ fontSize: 11, color: 'var(--text2)' }}>
              Писем в inbox: {status.inbox_count} | Кэш: {status.cached}
            </div>
          </div>
          {!status.connected && (
            <div style={{ fontSize: 12, color: '#f59e0b' }}>
              ⚠ Google требует App Password. Создайте на myaccount.google.com/apppasswords
            </div>
          )}
        </div>
      )}

      <div style={{ display: 'flex', gap: 8, marginBottom: 16, flexWrap: 'wrap' }}>
        {['inbox', 'keys'].map(t => (
          <button
            key={t}
            onClick={() => setTab2(t)}
            style={{
              padding: '6px 16px', borderRadius: 20, border: '1px solid var(--border)',
              background: tab2 === t ? 'var(--accent)' : 'transparent',
              color: tab2 === t ? '#fff' : 'var(--text)', cursor: 'pointer', fontSize: 13,
            }}
          >
            {t === 'inbox' ? '📥 Входящие' : '🔑 API ключи'}
          </button>
        ))}
      </div>

      {tab2 === 'inbox' && (
        <div>
          <div style={{ display: 'flex', gap: 8, marginBottom: 12 }}>
            <button className="btn-primary" onClick={loadInbox} disabled={loading}>
              {loading ? 'Загрузка...' : '↻ Обновить inbox'}
            </button>
            <input
              className="input"
              style={{ flex: 1 }}
              placeholder="Поиск по теме..."
              value={searchQ}
              onChange={e => setSearchQ(e.target.value)}
            />
          </div>
          {emails.length === 0 ? (
            <div className="card" style={{ textAlign: 'center', padding: 40 }}>
              <div style={{ fontSize: 32, marginBottom: 8 }}>📭</div>
              <div style={{ color: 'var(--text2)' }}>
                {loading ? 'Загрузка...' : 'Нажмите "Обновить inbox" для загрузки писем'}
              </div>
            </div>
          ) : (
            <div style={{ display: 'flex', flexDirection: 'column', gap: 2 }}>
              {emails
                .filter(e => !searchQ || e.subject?.toLowerCase().includes(searchQ.toLowerCase()) || e.from?.toLowerCase().includes(searchQ.toLowerCase()))
                .map((em, i) => (
                  <div
                    key={i}
                    onClick={() => setSelected(selected?.id === em.id ? null : em)}
                    style={{
                      padding: '10px 14px', background: 'var(--card)', borderRadius: 6,
                      cursor: 'pointer', border: '1px solid var(--border)',
                      borderLeft: em.has_key ? '3px solid #10b981' : '1px solid var(--border)',
                    }}
                  >
                    <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start' }}>
                      <div style={{ flex: 1, minWidth: 0 }}>
                        <div style={{ fontSize: 13, fontWeight: 500, color: 'var(--text)',
                          display: 'flex', alignItems: 'center', gap: 4 }}>
                          {em.has_key && <span title="Содержит API ключ">🔑</span>}
                          <span style={{ overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' }}>
                            {em.subject || '(без темы)'}
                          </span>
                        </div>
                        <div style={{ fontSize: 11, color: 'var(--text2)' }}>{em.from}</div>
                      </div>
                      <div style={{ fontSize: 10, color: 'var(--text2)', whiteSpace: 'nowrap', marginLeft: 8 }}>
                        {em.date?.slice(0, 16)}
                      </div>
                    </div>
                    {selected?.id === em.id && (
                      <div style={{ marginTop: 8, padding: 8, background: 'var(--bg2)',
                        borderRadius: 4, fontSize: 12, color: 'var(--text)', whiteSpace: 'pre-wrap' }}>
                        {em.body || '(пусто)'}
                      </div>
                    )}
                  </div>
                ))}
            </div>
          )}
        </div>
      )}

      {tab2 === 'keys' && (
        <div>
          <button className="btn-primary" onClick={scanKeys} disabled={keysLoading} style={{ marginBottom: 12 }}>
            {keysLoading ? 'Сканирование...' : '🔍 Сканировать почту на API ключи'}
          </button>
          {keys.length === 0 ? (
